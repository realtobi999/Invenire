<Router AppAssembly="@typeof(App).Assembly">
    <Found Context="data">
        <RouteView RouteData="@data" />
    </Found>

    <NotFound>
        @{ Redirect("/login"); }
    </NotFound>
</Router>

@code {
    [Inject] private NavigationManager Navigation { get; set; } = default!;

    private void Redirect(string url)
    {
        Navigation.NavigateTo(url, replace: true);
    }
}
