@using Invenire.Api.Users.Employees
@using System.Net
@using Invenire.Components.Forms.Users.Employees

@if (Employee is not null)
{
    <div class="detail-list">
        <div class="detail-item">
            <span class="detail-label">Id</span>
            <span class="detail-value">@Employee.Id</span>
        </div>
        <div class="detail-item">
            <span class="detail-label">Jméno</span>
            <span class="detail-value">@Employee.FullName</span>
        </div>
        <div class="detail-item">
            <span class="detail-label">Email</span>
            <span class="detail-value">@Employee.EmailAddress</span>
        </div>
        <div class="detail-item">
            <span class="detail-label">Vytvořen</span>
            <span class="detail-value">@Employee.CreatedAt.ToUserTimeString()</span>
        </div>
        <div class="detail-item">
            <span class="detail-label">Naposledy upraven</span>
            <span class="detail-value">@Employee.LastUpdatedAt.ToUserTimeString()</span>
        </div>
    </div>

    <div class="detail-actions">
        <button class="btn-secondary" @onclick="() => ShowUpdateModal = true">Upravit informace</button>
    </div>
}
@if (Employee is not null && ShowUpdateModal)
{
    <div class="modal-overlay">
        <div class="modal-panel">
            <div class="modal-header">
                <h4>Upravit svoje informace</h4>
                <button class="btn-secondary" type="button" @onclick="() => ShowUpdateModal = false">Zavřít</button>
            </div>

            <div class="modal-body">
                <UpdateEmployeeForm Employee="Employee" OnClose="() => ShowUpdateModal = false" OnSuccessfulUpdate="OnSuccessfulEmployeeUpdate" />
            </div>
        </div>
    </div>
}
@code 
{
    [Inject] private HttpClient Client { get; set; } = default!;

    private bool ShowUpdateModal { get; set; }
    private EmployeeDto? Employee { get; set; }

    protected override async Task OnInitializedAsync()
    {
        await LoadEmployee();
    }

    private async Task LoadEmployee()
    {
        var response = await Client.GetAsync("/api/employees/profile");

        if (response.StatusCode != HttpStatusCode.OK) throw new Exception("Something went wrong during the request to get the employee."); 

        Employee = await response.Content.ReadFromJsonAsync<EmployeeDto>();
    }

    private async Task ReloadEmployee()
    {
        await LoadEmployee();
        StateHasChanged();
    }

    private async Task OnSuccessfulEmployeeUpdate()
    {
        ShowUpdateModal = false;
        await ReloadEmployee();
    }
}
