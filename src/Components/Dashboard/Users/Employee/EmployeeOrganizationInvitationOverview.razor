@using System.Net
@using Invenire.Api.Organizations
@using Invenire.Api.Organizations.Invitations
@using Invenire.Api.Organizations.Invitations.IndexByEmployee
@using Invenire.Components.Forms.Organizations.Invitations

@if (Invitations.Any())
{
    var pagedInvitations = Invitations;
    var visibleCount = pagedInvitations.Count;
    var rangeStart = visibleCount == 0 ? 0 : CurrentOffset + 1;
    var rangeEnd = visibleCount == 0 ? 0 : CurrentOffset + visibleCount;

    <div class="stat-grid invitation-summary">
        <div class="stat-card">
            <span class="stat-label">Celkem pozvánek</span>
            <span class="stat-value">@TotalInvitationsCount.ToString("N0")</span>
        </div>
        <div class="stat-card">
            <span class="stat-label">Aktuálně zobrazeno</span>
            <span class="stat-value">@visibleCount</span>
            <p class="muted-text">@(rangeStart == 0 ? "—" : $"{rangeStart}-{rangeEnd} z {TotalInvitationsCount}")</p>
        </div>
    </div>

    <div class="filter-panel invitation-filter-panel">
        <div class="filter-grid">
            <div class="form-control">
                <label for="invitation-order">Řazení</label>
                <select id="invitation-order" @bind="SelectedOrderOption" @bind:after="() => SetInvitations(0)">
                    @foreach (var option in OrderOptions)
                    {
                        <option value="@option.Value">@option.Label</option>
                    }
                </select>
            </div>
            <div class="form-control grow">
                <label for="invitation-search">Hledat</label>
                <input id="invitation-search" type="text" placeholder="Hledat pozvánky..." @bind="SearchTerm" @bind:after="() => SetInvitations(0)" />
            </div>
        </div>
    </div>

    <div class="invitation-list">
        @foreach (var invitation in pagedInvitations)
        {
            <article class="invitation-card">
                <div class="detail-list">
                    <div class="detail-item">
                        <span class="detail-label">Id</span>
                        <span class="detail-value">@invitation.Id</span>
                    </div>
                    <div class="detail-item">
                        <span class="detail-label">Od</span>
                        <span class="detail-value">@invitation.OrganizationDto?.Admin?.FullName</span>
                    </div>
                    <div class="detail-item">
                        <span class="detail-label">Organizace</span>
                        <span class="detail-value">@invitation.OrganizationDto?.Name</span>
                    </div>
                    @if (!string.IsNullOrWhiteSpace(invitation.Description))
                    {
                        <div class="detail-item">
                            <span class="detail-label">Text</span>
                            <span class="detail-value">@invitation.Description</span>
                        </div>
                    }
                    <div class="detail-item">
                        <span class="detail-label">Vytvořeno</span>
                        <span class="detail-value">@invitation.CreatedAt.ToUserTimeString()</span>
                    </div>
                    @if (invitation.LastUpdatedAt is not null)
                    {
                        <div class="detail-item">
                            <span class="detail-label">Naposledy upraveno</span>
                            <span class="detail-value">@invitation.LastUpdatedAt.ToUserTimeString()</span>
                        </div>
                    }
                </div>


                <div class="invitation-actions">
                    <button class="btn-secondary" type="button" @onclick="() => OpenAcceptModal(invitation)">Připojit se</button>
                    <button class="btn-destructive" type="button" @onclick="() => OpenDeletionModal(invitation)">Odstranit</button>
                </div>
            </article>
        }
    </div>

    <div class="invitation-pagination">
        <div class="invitation-pagination-meta">
            <span>Zobrazuji @rangeStart-@rangeEnd z @TotalInvitationsCount pozvánek</span>
        </div>
        <div class="invitation-pagination-controls">
            <button class="btn-secondary" @onclick="async () => await GoToPreviousPage()" disabled="@(!CanGoPrev)">◀</button>
            <span>@CurrentPage / @TotalPages</span>
            <button class="btn-secondary" @onclick="async () => await GoToNextPage()" disabled="@(!CanGoNext)">▶</button>
        </div>
    </div>
}
else
{
    <div class="empty-state">
        <p>Momentálně nemáte žádné pozvánky.</p>
    </div>
}


@if (ShowAcceptInvitationConfirmationModal && SelectedInvitation is not null)
{
    <div class="modal-overlay">
        <div class="modal-panel">
            <div class="modal-header">
                <h4>Připojit se k organizaci</h4>
                <button class="btn-secondary" type="button" @onclick="CloseAcceptModal">Zavřít</button>
            </div>
            <div class="modal-body">
                <p class="modal-description">Opravdu se chcete připojit k organizaci?</p>
                <div class="detail-list">
                    <div class="detail-item">
                        <span class="detail-label">Organizace</span>
                        <span class="detail-value">@SelectedInvitation.OrganizationDto?.Name</span>
                    </div>
                    <div class="detail-item">
                        <span class="detail-label">Od</span>
                        <span class="detail-value">@SelectedInvitation.OrganizationDto?.Admin?.FullName</span>
                    </div>
                </div>
                <div class="modal-footer">
                    <button class="btn-secondary" type="button" @onclick="CloseAcceptModal">Zrušit</button>
                    <button class="btn-success" type="button" @onclick="() => AcceptInvitation(SelectedInvitation)">Ano, připojit se</button>
                </div>
            </div>
        </div>
    </div>
}

@if (ShowDeleteInvitationConfirmationModal && SelectedInvitation is not null)
{
    <div class="modal-overlay">
        <div class="modal-panel">
            <div class="modal-header">
                <h4>Smazat pozvánku</h4>
                <button class="btn-secondary" type="button" @onclick="CloseDeletionModal">Zavřít</button>
            </div>
            <div class="modal-body">
                <p class="modal-description">Opravdu chcete smazat pozvánku?</p>
                <div class="detail-list">
                    <div class="detail-item">
                        <span class="detail-label">Od</span>
                        <span class="detail-value">@SelectedInvitation.OrganizationDto?.Admin?.FullName</span>
                    </div>
                    <div class="detail-item">
                        <span class="detail-label">Organizace</span>
                        <span class="detail-value">@SelectedInvitation.OrganizationDto?.Name</span>
                    </div>
                </div>
                <div class="modal-footer">
                    <button class="btn-secondary" type="button" @onclick="CloseDeletionModal">Zrušit</button>
                    <button class="btn-destructive" type="button" @onclick="() => DeleteInvitation(SelectedInvitation)">Ano, smazat</button>
                </div>
            </div>
        </div>
    </div>
}

@code
{
    [Inject] private HttpClient Client { get; set; } = default!;
    [Parameter] public EventCallback<bool> OnSuccessfulJoin { get; set; }

    private int Limit { get; set; } = 5;
    private int CurrentOffset { get; set; }
    private int TotalInvitationsCount { get; set; }

    private string SearchTerm { get; set; } = string.Empty;
    private string SelectedOrderOption { get; set; } = "created_desc";

    private bool ShowAcceptInvitationConfirmationModal { get; set; }
    private bool ShowDeleteInvitationConfirmationModal { get; set; }

    private OrganizationInvitationDto? SelectedInvitation { get; set; }
    private List<OrganizationInvitationDto> Invitations { get; set; } = [];

    private readonly List<(string Value, string Label)> OrderOptions = new()
    {
        ("created_desc", "Datum vytvoření (novější)"),
        ("created_asc", "Datum vytvoření (starší)"),
        ("updated_desc", "Datum úprav (novější)"),
        ("updated_asc", "Datum úprav (starší)"),
        ("organization_asc", "Organizace (A-Z)"),
        ("organization_desc", "Organizace (Z-A)")
    };

    protected override async Task OnInitializedAsync() => await SetInvitations();

    private async Task SetInvitations(int offset = 0)
    {
        CurrentOffset = Math.Max(0, offset);

        var parameters = new List<string>
        {
            $"limit={Limit}",
            $"offset={CurrentOffset}",
            $"order={SelectedOrderOption}"
        };

        if (!string.IsNullOrWhiteSpace(SearchTerm))
            parameters.Add($"searchQuery={SearchTerm}");

        var response = await Client.GetAsync($"/api/employees/invitations?{string.Join("&", parameters)}");
        if (response.StatusCode != HttpStatusCode.OK) throw new Exception("Something went wrong during the request to index the invitations.");

        var content = await response.Content.ReadFromJsonAsync<IndexByEmployeeOrganizationInvitationResponse>() ?? throw new NullReferenceException();

        Invitations = content.Data;
        TotalInvitationsCount = content.TotalCount;

        foreach (var invitation in Invitations)
        {
            invitation.OrganizationDto = await (await Client.GetAsync($"/api/organizations/{invitation.OrganizationId}")).Content.ReadFromJsonAsync<OrganizationDto>();
        }
    }

    private bool CanGoPrev => CurrentOffset > 0;
    private bool CanGoNext => CurrentOffset + Limit < TotalInvitationsCount;

    private int CurrentPage => TotalInvitationsCount == 0 ? 0 : CurrentOffset / Limit + 1;
    private int TotalPages => TotalInvitationsCount == 0 ? 1 : (int)Math.Ceiling((double)TotalInvitationsCount / Limit);

    private async Task AcceptInvitation(OrganizationInvitationDto invitation)
    {
        var response = await Client.PutAsync($"/api/organizations/invitations/{invitation.Id}/accept", null);

        if (response.StatusCode != HttpStatusCode.NoContent) throw new Exception("Something went wrong during the request to accept the invitation.");

        CloseAcceptModal();
        await OnSuccessfulJoin.InvokeAsync(true);
    }

    private async Task DeleteInvitation(OrganizationInvitationDto invitation)
    {
        var response = await Client.DeleteAsync($"/api/organizations/invitations/{invitation.Id}");

        if (response.StatusCode != HttpStatusCode.NoContent) throw new Exception("Something went wrong during the request to delete the invitation.");

        Invitations.Remove(invitation);
        CloseDeletionModal();
        StateHasChanged();
    }

    private void OpenAcceptModal(OrganizationInvitationDto invitation) => (SelectedInvitation, ShowAcceptInvitationConfirmationModal) = (invitation, true);
    private void CloseAcceptModal() => (ShowAcceptInvitationConfirmationModal, SelectedInvitation) = (false, null);
    private void OpenDeletionModal(OrganizationInvitationDto invitation) => (SelectedInvitation, ShowDeleteInvitationConfirmationModal) = (invitation, true);
    private void CloseDeletionModal() => (ShowDeleteInvitationConfirmationModal, SelectedInvitation) = (false, null);

    private async Task GoToPreviousPage()
    {
        if (CanGoPrev) await SetInvitations(CurrentOffset - Limit);
    }

    private async Task GoToNextPage()
    {
        if (CanGoNext) await SetInvitations(CurrentOffset + Limit);
    }
}
