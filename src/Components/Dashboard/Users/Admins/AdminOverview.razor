@using System.Net
@using Invenire.Api.Users.Admin
@using Invenire.Components.Forms.Users.Admins
@using Invenire.Extensions

@if (Admin is not null)
{
    <section class="section-card">
        <h3>Základní informace</h3>
        
        <div class="detail-list">
            <div class="detail-item">
                <span class="detail-label">Id</span>
                <span class="detail-value">@Admin.Id</span>
            </div>
            <div class="detail-item">
                <span class="detail-label">Jméno</span>
                <span class="detail-value">@Admin.FullName</span>
            </div>
            <div class="detail-item">
                <span class="detail-label">Email</span>
                <span class="detail-value">@Admin.EmailAddress</span>
            </div>
            <div class="detail-item">
                <span class="detail-label">Vytvořen</span>
                <span class="detail-value">@Admin.CreatedAt.ToUserTimeString()</span>
            </div>
            @if (Admin.LastUpdatedAt is not null)
            {
                <div class="detail-item">
                    <span class="detail-label">Naposledy upraven</span>
                    <span class="detail-value">@Admin.LastUpdatedAt.ToUserTimeString()</span>
                </div>
            }
        </div>

<button class="btn-secondary" @onclick="() => ShowUpdateModal = true">Upravit informace</button>
    </section>
}
@if (Admin is not null && ShowUpdateModal)
{
    <div class="modal-overlay">
        <div class="modal-panel">
            <div class="modal-header">
                <h4>Upravit svoje informace</h4>
                <button class="btn-secondary" type="button" @onclick="CloseUpdateModal">Zavřít</button>
            </div>
            <div class="modal-body">
                <UpdateAdminForm Admin="Admin" OnClose="CloseUpdateModal" OnSuccessfulUpdate="OnSuccessfulAdminUpdate" />
            </div>
        </div>
    </div>
}

@code 
{
    [Inject] private HttpClient Client { get; set; } = default!;

    private bool ShowUpdateModal { get; set; }
    private AdminDto? Admin { get; set; }

    protected override async Task OnInitializedAsync()
    {
        await LoadAdmin();
    }

    private async Task LoadAdmin()
    {
        var response = await Client.GetAsync("/api/admins/profile");

        if (response.StatusCode != HttpStatusCode.OK) throw new Exception("Something went wrong during the request to get the admin."); 

        Admin = await response.Content.ReadFromJsonAsync<AdminDto>();
    }

    private async Task OnSuccessfulAdminUpdate()
    {
        CloseUpdateModal();
        await LoadAdmin();
        StateHasChanged();
    }

    private void CloseUpdateModal() => ShowUpdateModal = false;
}
