@using System.Net
@using Invenire.Api.Properties
@using Invenire.Api.Properties.Items
@using Invenire.Api.Properties.Items.IndexByAdmin
@using Invenire.Components.Forms.Properties.Items

@if (Items.Any())
{
    <div>
        <h4 style="display:inline-block;">Všechny položky</h4>
        <button style="display:inline-block;" @onclick="Close">X</button>
    </div>

    <div>
        @if (AllSelected)
        {
            <button @onclick="DeselectAllSelectedCurrentItems">Zrušit výběr na stránce</button>
        }
        else if (ItemsToDelete.Count != Limit && ItemsToUpdate.Count != Limit)
        {
            <button @onclick="SelectAllAsSelected">Vybrat vše na stránce</button>
        }

        @if (AnySelected)
        {
           <button @onclick="DeselectAllSelected">Zrušit výběr všech položek</button>
            <button @onclick="SelectAllAsDeleted">Označit vybrané za smazané</button>
        }
        @if (ItemsToDelete.Count > 0)
        {
            <button @onclick="DeselectAllDeleted">Zrušit všechny smazané položky</button>
        }

        <div style="display:grid;grid-template-columns:repeat(7,1fr);gap:0.5rem;">
            @foreach (var item in Items)
            {
                <div style="border:1px solid #ccc;padding:0.25rem;border-radius:6px;font-size:0.85rem; background-color:@GetItemColor(item);">
                    <ul style="list-style-type:none;padding:0;margin:0; cursor:pointer;" @onclick="() => SelectItem(item)">
                        <li><strong>ID:</strong> @item.Id</li>
                        <li><strong>Název:</strong> @item.Name</li>
                        <li><strong>Cena:</strong> @item.Price Kč</li>
                        <li><strong>Inventární číslo:</strong> @item.InventoryNumber</li>
                        <li><strong>Registrační číslo:</strong> @item.RegistrationNumber</li>
                        <li><strong>Sériové číslo:</strong> @item.SerialNumber</li>
                        <li><strong>Datum nákupu:</strong> @item.DateOfPurchase:d</li>
                        @if (item.DateOfSale is not null)
                        {
                            <li><strong>Datum prodeje:</strong> @item.DateOfSale:d</li>
                        }
                        <li><strong>Umístění:</strong> @item.Location.Building, @item.Location.Room</li>
                        @if (!string.IsNullOrWhiteSpace(item.Location.AdditionalNote))
                        {
                            <li><strong>Poznámka:</strong> @item.Location.AdditionalNote</li>
                        }
                        <li><strong>Popis:</strong> @item.Description</li>
                        <li><strong>Dokument:</strong> @item.DocumentNumber</li>
                        <li><strong>Vytvořeno:</strong> @item.CreatedAt:g</li>
                        @if (item.LastUpdatedAt is not null)
                        {
                            <li><strong>Upraveno:</strong> @item.LastUpdatedAt:g</li>
                        }
                    </ul>
                    @if (!ItemsToUpdate.Any(i => i.Id == item.Id))
                    {
                        <button @onclick="() => SelectItemAsUpdated(item)">Upravit</button>
                    }
                    else
                    {
                        <button @onclick="() => CancelUpdate(item)">Zrušit úpravy</button>
                    }
                    
                    @if (!ItemsToDelete.Any(i => i.Id == item.Id))
                    {
                        <button @onclick="() => SelectItemAsDeleted(item)">Smazat</button>
                    }
                    else
                    {
                        <button @onclick="() => CancelDelete(item)">Zrušit smazání</button>
                    }

                </div>
            }
        </div>

        <div class="pagination">
            <button @onclick="() => LoadItems(CurrentOffset - Limit)" disabled="@( !CanGoPrev )">Předchozí</button>
            <span>Stránka @(CurrentOffset / Limit + 1) / @((int)Math.Ceiling((double)TotalItemsCount / Limit))</span>
            <button @onclick="() => LoadItems(CurrentOffset + Limit)" disabled="@( !CanGoNext )">Další</button>
        </div>
    </div>
}

@code {
    [Inject] public HttpClient Client { get; set; } = default!;
    [Parameter] public EventCallback<bool> OnClose { get; set; }
    [Parameter] public EventCallback<bool> OnChange { get; set; }

    private int Limit { get; set; } = 28;
    private int CurrentOffset { get; set; }
    private int TotalItemsCount { get; set; }

    private List<PropertyItemDto> Items { get; set; } = [];
    private HashSet<PropertyItemDto> ItemsToDelete = new();
    private HashSet<PropertyItemDto> ItemsToUpdate = new();
    private HashSet<PropertyItemDto> SelectedItems { get; set; } = [];

    private void SelectItemAsDeleted(PropertyItemDto item)
    {
        SelectedItems.Remove(item);
        ItemsToUpdate.Remove(item);
        
        if (!ItemsToDelete.Any(i => i.Id == item.Id))
            ItemsToDelete.Add(item);
    }

    private void CancelDelete(PropertyItemDto item)
    {
        ItemsToDelete.RemoveWhere(i => i.Id == item.Id);
    }

    private void SelectItemAsUpdated(PropertyItemDto item)
    {
        SelectedItems.Remove(item);
        ItemsToDelete.Remove(item);
        
        if (!ItemsToUpdate.Any(i => i.Id == item.Id))
            ItemsToUpdate.Add(item);
    }

    private void CancelUpdate(PropertyItemDto item)
    {
        ItemsToUpdate.RemoveWhere(i => i.Id == item.Id);
    }

    private bool AnySelected => SelectedItems.Count > 0;
    private bool AllSelected => Items.All(i => SelectedItems.Any(s => s.Id == i.Id));

    protected override async Task OnInitializedAsync() => await LoadItems(CurrentOffset);

    private void SelectItem(PropertyItemDto item)
    {
        if (ItemsToDelete.Any(i => i.Id == item.Id))
        {
            ItemsToDelete.Remove(item);
            return;
        }
        if (!SelectedItems.Remove(item) && !ItemsToDelete.Any(i => i.Id == item.Id))
        {
           SelectedItems.Add(item);
           return;
        }
    }

    private async Task LoadItems(int offset)
    {
        CurrentOffset = Math.Max(0, offset);

        var response = await Client.GetAsync($"/api/properties/items?limit={Limit}&offset={CurrentOffset}");
        if (response.StatusCode != HttpStatusCode.OK) throw new Exception("Something went wrong during the request to get the items.");

        var content = await response.Content.ReadFromJsonAsync<IndexByAdminPropertyItemResponse>()
        ?? throw new NullReferenceException();

        Items = content.Data;
        Limit = content.Limit;
        TotalItemsCount = content.TotalCount;
    }

    private bool CanGoPrev => CurrentOffset > 0;
    private bool CanGoNext => CurrentOffset + Limit < TotalItemsCount;

    private async Task ReloadAfterDeletion()
    {
        await OnChange.InvokeAsync(true);
        SelectedItems.Clear();
        CurrentOffset = 0;
        await LoadItems(CurrentOffset);
    }

    private void Close() => OnClose.InvokeAsync(true);
    private void SelectAllAsSelected() => SelectedItems.UnionWith(Items);
    private void SelectAllAsDeleted() { ItemsToDelete.UnionWith(SelectedItems); DeselectAllSelected(); }
    private void DeselectAllDeleted() => ItemsToDelete.Clear();
    private void DeselectAllSelected() => SelectedItems.Clear();
    private void DeselectAllSelectedCurrentItems() => SelectedItems.RemoveWhere(si => Items.Any(i => i.Id == si.Id));

    private string GetItemColor(PropertyItemDto item) => 
        ItemsToUpdate.Any(i => i.Id == item.Id) ? "#bbff99" :
        ItemsToDelete.Any(i => i.Id == item.Id) ? "#ff5b5b" : 
        SelectedItems.Any(i => i.Id == item.Id) ? "#e0e0e0" : "ffffff";
}
