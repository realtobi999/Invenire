@using System.Net
@using Invenire.Api.Properties.Items
@using Invenire.Api.Properties.Items.IndexByScan
@using Invenire.Api.Properties.Scans
@using Invenire.Api.Users.Employees
@using Invenire.Common.Errors
@using Invenire.Components.Forms.Properties.Items

<div class="scan-items-overview">

    <div class="items-toolbar">
        <div class="form-control grow">
            <label for="scan-search">Hledat</label>
            <input id="scan-search" class="input-control" type="text" @bind="SearchQuery" @bind:after="() => LoadItemsWithFilter()" placeholder="Hledat položky..." />
        </div>
        <div class="form-control">
            <label for="scan-order">Řazení</label>
            <select id="scan-order" @bind="SelectedOrderOption" @bind:after="() => LoadItemsWithFilter()">
                @foreach (var option in OrderOptions)
                {
                    <option value="@option.Value">@option.Label</option>
                }
            </select>
        </div>
        <button class="btn-secondary" type="button" @onclick="ToggleFilters">
            @(ShowFilteringOptions ? "Zrušit filtrování" : "Filtrovat")
        </button>
    </div>

    @if (ShowFilteringOptions)
    {
        <section class="filter-panel">
            <div class="filter-grid">
                <div class="form-control">
                    <label>Cena od</label>
                    <input class="input-control" type="number" min="0" @bind="PriceMin" />
                </div>
                <div class="form-control">
                    <label>Cena do</label>
                    <input class="input-control" type="number" min="0" @bind="PriceMax" />
                </div>
                <div class="form-control">
                    <label>Datum nákupu od</label>
                    <input class="input-control" type="date" @bind="DateOfPurchaseFrom" />
                </div>
                <div class="form-control">
                    <label>Datum nákupu do</label>
                    <input class="input-control" type="date" @bind="DateOfPurchaseTo" />
                </div>
                <div class="form-control">
                    <label>Datum přidání od</label>
                    <input class="input-control" type="date" @bind="CreatedAtFrom" />
                </div>
                <div class="form-control">
                    <label>Datum přidání do</label>
                    <input class="input-control" type="date" @bind="CreatedAtTo" />
                </div>
                <div class="form-control">
                    <label>Budova</label>
                    <input class="input-control" type="text" @bind="Building" />
                </div>
                <div class="form-control">
                    <label>Místnost</label>
                    <input class="input-control" type="text" @bind="Room" />
                </div>
                <div class="form-control">
                    <label>Vygenerovaný kód</label>
                    <select @bind="WithGeneratedCode">
                        <option value="">Nezáleží</option>
                        <option value="true">S kódem</option>
                        <option value="false">Bez kódu</option>
                    </select>
                </div>
                <div class="form-control">
                    <label>Email správce položky</label>
                    <input class="input-control" type="email" @bind="FilteringEmployeeEmailAddress" placeholder="např. jan.novak@firma.cz" />
                    <div class="chip-actions">
                        <button class="btn-secondary" type="button" @onclick="GetEmployeeForFiltering" disabled="@string.IsNullOrWhiteSpace(FilteringEmployeeEmailAddress)">Najít</button>
                        <button class="btn-secondary" type="button" @onclick="ClearEmployeeFilter" disabled="@(FilteringEmployeeId is null && string.IsNullOrWhiteSpace(FilteringEmployeeEmailAddress))">Vymazat</button>
                    </div>
                    @if (!string.IsNullOrWhiteSpace(FilteringEmployeeErrorMessage))
                    {
                        <p class="error-text">@FilteringEmployeeErrorMessage</p>
                    }
                </div>
            </div>
            <div class="filter-actions">
                <button class="btn-secondary" type="button" @onclick="async () => await LoadItemsWithFilter()">Použít</button>
                <button class="btn-secondary" type="button" @onclick="async () => await ClearFilters()">Vymazat</button>
            </div>
        </section>
    }

    <div class="action-row">
        <button class="btn-secondary" type="button" @onclick="() => ShowScanItemModal = true">Naskenovat položky</button>
    </div>

<div class="scan-groups">
        <section class="items-group">
            <div class="group-header">
                <div>
                    <p class="muted-text">Zpracováno</p>
                    <h4>Naskenované položky</h4>
                </div>
                <span class="group-count">@TotalScannedCount</span>
            </div>
            @if (ScannedItems.Count == 0)
            {
                <div class="items-empty-state">Žádné položky nebyly nalezeny.</div>
            }
            else
            {
                <div class="items-grid">
                    @foreach (var item in ScannedItems)
                    {
                        var scannedCardClass = item.LastCodeGeneratedAt is null
                            ? "scan-item-card scan-item-card--scanned-no-code"
                            : "scan-item-card scan-item-card--scanned";

                        <article class="@scannedCardClass">
                            <div class="item-card-header">
                                <div>
                                    <p class="muted-text item-id">ID: @item.Id</p>
                                    <h5>@item.Name</h5>
                                </div>
                                <span class="item-price"><span>@item.Price</span><span>Kč</span></span>
                            </div>
                            <ul class="item-field-list">
                                <li class="item-field"><span class="field-label">Inventární číslo</span><span class="field-value">@item.InventoryNumber</span></li>
                                <li class="item-field"><span class="field-label">Registrační číslo</span><span class="field-value">@item.RegistrationNumber</span></li>
                                <li class="item-field"><span class="field-label">Sériové číslo</span><span class="field-value">@(item.SerialNumber ?? "-----")</span></li>
                                <li class="item-field"><span class="field-label">Datum nákupu</span><span class="field-value">@item.DateOfPurchase.ToUserTimeString()</span></li>
                                <li class="item-field"><span class="field-label">Datum prodeje</span><span class="field-value">@(item.DateOfSale?.ToUserTimeString() ?? "-----")</span></li>
                                <li class="item-field"><span class="field-label">Umístění</span><span class="field-value">Budova @item.Location.Building, Místnost @item.Location.Room</span></li>
                                <li class="item-field"><span class="field-label">Spravuje</span><span class="field-value">@(!string.IsNullOrEmpty(item.Employee.EmailAddress) ? item.Employee.EmailAddress : "-----")</span></li>
                                <li class="item-field"><span class="field-label">Popis</span><span class="field-value">@(item.Description ?? "-----")</span></li>
                                <li class="item-field"><span class="field-label">Přidáno</span><span class="field-value">@item.CreatedAt.ToUserTimeString()</span></li>
                                <li class="item-field"><span class="field-label">Upraveno</span><span class="field-value">@(item.LastUpdatedAt.ToUserTimeString() ?? "-----")</span></li>
                                <li class="item-field"><span class="field-label">Kód generován</span><span class="field-value">@(item.LastCodeGeneratedAt.ToUserTimeString() ?? "-----")</span></li>
                                <li class="item-field"><span class="field-label">Naskenováno</span><span class="field-value">@(item.LastScannedAt.ToUserTimeString() ?? "-----")</span></li>
                            </ul>
                        </article>
                    }
                </div>
            }
            <div class="scan-pagination">
                <button class="btn-secondary" type="button" @onclick="() => LoadScannedItems(ScannedCurrentOffset - ScannedLimit)" disabled="@(!CanGoPrevScanned)">◀</button>
                <span>@(ScannedCurrentOffset / ScannedLimit + 1) / @ScannedTotalPages</span>
                <button class="btn-secondary" type="button" @onclick="() => LoadScannedItems(ScannedCurrentOffset + ScannedLimit)" disabled="@(!CanGoNextScanned)">▶</button>
            </div>
        </section>

        <section class="items-group">
            <div class="group-header">
                <div>
                    <p class="muted-text">Zbývá</p>
                    <h4>Nenaskenované položky</h4>
                </div>
                <span class="group-count">@TotalNotScannedCount</span>
            </div>
            @if (NotScannedItems.Count == 0)
            {
                <div class="items-empty-state">Žádné položky nebyly nalezeny.</div>
            }
            else
            {
                <div class="items-grid">
                    @foreach (var item in NotScannedItems)
                    {
                        <article class="scan-item-card scan-item-card--pending">
                            <div class="item-card-header">
                                <div>
                                    <p class="muted-text item-id">ID: @item.Id</p>
                                    <h5>@item.Name</h5>
                                </div>
                                <span class="item-price"><span>@item.Price</span><span>Kč</span></span>
                            </div>
                            <ul class="item-field-list">
                                <li class="item-field"><span class="field-label">Inventární číslo</span><span class="field-value">@item.InventoryNumber</span></li>
                                <li class="item-field"><span class="field-label">Registrační číslo</span><span class="field-value">@item.RegistrationNumber</span></li>
                                <li class="item-field"><span class="field-label">Sériové číslo</span><span class="field-value">@(item.SerialNumber ?? "-----")</span></li>
                                <li class="item-field"><span class="field-label">Datum nákupu</span><span class="field-value">@item.DateOfPurchase.ToUserTimeString()</span></li>
                                <li class="item-field"><span class="field-label">Datum prodeje</span><span class="field-value">@(item.DateOfSale?.ToUserTimeString() ?? "-----")</span></li>
                                <li class="item-field"><span class="field-label">Umístění</span><span class="field-value">Budova @item.Location.Building, Místnost @item.Location.Room</span></li>
                                <li class="item-field"><span class="field-label">Spravuje</span><span class="field-value">@(!string.IsNullOrEmpty(item.Employee.EmailAddress) ? item.Employee.EmailAddress : "-----")</span></li>
                                <li class="item-field"><span class="field-label">Popis</span><span class="field-value">@(item.Description ?? "-----")</span></li>
                                <li class="item-field"><span class="field-label">Přidáno</span><span class="field-value">@item.CreatedAt.ToUserTimeString()</span></li>
                                <li class="item-field"><span class="field-label">Kód generován</span><span class="field-value">@(item.LastCodeGeneratedAt.ToUserTimeString() ?? "-----")</span></li>
                            </ul>
                            @if (Scan!.CompletedAt is null)
                            {
                                <div class="item-card-actions">
                                    <button class="btn-secondary" type="button" @onclick="async (args) => await ScanItem(item)" @onclick:stopPropagation="true">Naskenovat</button>
                                </div>
                            }
                        </article>
                    }
                </div>
            }
            <div class="scan-pagination">
                <button class="btn-secondary" type="button" @onclick="() => LoadNotScannedItems(NotScannedCurrentOffset - NotScannedLimit)" disabled="@(!CanGoPrevNotScanned)">◀</button>
                <span>@(NotScannedCurrentOffset / NotScannedLimit + 1) / @NotScannedTotalPages</span>
                <button class="btn-secondary" type="button" @onclick="() => LoadNotScannedItems(NotScannedCurrentOffset + NotScannedLimit)" disabled="@(!CanGoNextNotScanned)">▶</button>
            </div>
        </section>
    </div>
</div>

@if (ShowScanItemModal)
{
    <div class="modal-overlay">
        <div class="modal-panel">
            <div class="modal-header">
                <h4>Naskenovat položky</h4>
                <button class="btn-secondary" type="button" @onclick="() => ShowScanItemModal = false">Zavřít</button>
            </div>

            <div class="modal-body">
                <ScanPropertyItemForm OnSuccessfulScan="async () => { await LoadItemsWithFilter(); await OnChange.InvokeAsync(true); }"/>
            </div>
        </div>
    </div>
}

@code
{
    [Inject] private HttpClient Client { get; set; } = default!;
    [Parameter] public PropertyScanDto? Scan { get; set; }
    [Parameter] public EventCallback<bool> OnChange { get; set; }

    private List<PropertyItemDto> ScannedItems { get; set; } = [];
    private List<PropertyItemDto> NotScannedItems { get; set; } = [];

    private int ScannedLimit { get; set; } = 12;
    private int NotScannedLimit { get; set; } = 12;

    private int ScannedCurrentOffset { get; set; }
    private int NotScannedCurrentOffset { get; set; }

    private int TotalScannedCount { get; set; }
    private int TotalNotScannedCount { get; set; }

    private int ScannedTotalPages => TotalScannedCount == 0 ? 1 : (int)Math.Ceiling((double)TotalScannedCount / ScannedLimit);
    private bool CanGoPrevScanned => ScannedCurrentOffset > 0;
    private bool CanGoNextScanned => ScannedCurrentOffset + ScannedLimit < TotalScannedCount;

    private int NotScannedTotalPages => TotalNotScannedCount == 0 ? 1 : (int)Math.Ceiling((double)TotalNotScannedCount / NotScannedLimit);
    private bool CanGoPrevNotScanned => NotScannedCurrentOffset > 0;
    private bool CanGoNextNotScanned => NotScannedCurrentOffset + NotScannedLimit < TotalNotScannedCount;

    private string SelectedOrderOption { get; set; } = "createdat_asc";
    private readonly List<(string Value, string Label)> OrderOptions = new()
    {
        ("name_asc", "Název (A-Z)"),
        ("name_desc", "Název (Z-A)"),
        ("price_asc", "Cena (nejnižší první)"),
        ("price_desc", "Cena (nejvyšší první)"),
        ("dateofpurchase_asc", "Datum nákupu (nejstarší první)"),
        ("dateofpurchase_desc", "Datum nákupu (nejnovější první)"),
        ("createdat_asc", "Datum přidání (nejstarší první)"),
        ("createdat_desc", "Datum přidání (nejnovější první)")
    };

    private bool ShowFilteringOptions { get; set; }
    private decimal? PriceMin { get; set; }
    private decimal? PriceMax { get; set; }
    private DateTime? CreatedAtFrom { get; set; }
    private DateTime? CreatedAtTo { get; set; }
    private DateTime? DateOfPurchaseFrom { get; set; }
    private DateTime? DateOfPurchaseTo { get; set; }
    private string? Room { get; set; }
    private string? Building { get; set; }
    private string? WithGeneratedCode { get; set; }
    private Guid? FilteringEmployeeId { get; set; }
    private string? FilteringEmployeeEmailAddress { get; set; }
    private string? FilteringEmployeeErrorMessage { get; set; }
    private string? SearchQuery { get; set; }
    private bool ShowScanItemModal { get; set; }

    protected override async Task OnInitializedAsync() => await LoadItemsWithFilter();

    private async Task ToggleFilters()
    {
        ShowFilteringOptions = !ShowFilteringOptions;
        if (!ShowFilteringOptions)
        {
            await ClearFilters();
        }
    }

    private async Task LoadItemsWithFilter()
    {
        ScannedCurrentOffset = 0;
        NotScannedCurrentOffset = 0;
        await LoadScannedItems(ScannedCurrentOffset);
        await LoadNotScannedItems(NotScannedCurrentOffset);
    }

    private async Task LoadScannedItems(int offset)
    {
        try
        {
            ScannedCurrentOffset = Math.Max(0, offset);
            var (sort, descending) = SelectedOrderOption.Split("_") switch { var parts => (parts[0], parts[1] == "desc") };

            var parameters = new List<string>
            {
                $"limit={ScannedLimit}",
                $"offset={ScannedCurrentOffset}",
                $"order={sort}",
                $"desc={descending}",
                "scanned=true"
            };

            AddFilteringParameters(parameters);
            AddSearchParameter(parameters);

            var response = await Client.GetAsync($"/api/properties/scans/{Scan!.Id}/items?{string.Join("&", parameters)}");

            if (response.StatusCode != HttpStatusCode.OK)
                throw new Exception("Something went wrong during the request to get scanned items.");

            var content = await response.Content.ReadFromJsonAsync<IndexByScanPropertyItemResponse>()
                ?? throw new NullReferenceException();

            ScannedItems = content.Data ?? [];
            TotalScannedCount = content.TotalCount;
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error loading scanned items: {ex.Message}");
            ScannedItems = [];
            TotalScannedCount = 0;
        }
    }

    private async Task LoadNotScannedItems(int offset)
    {
        try
        {
            NotScannedCurrentOffset = Math.Max(0, offset);
            var (sort, descending) = SelectedOrderOption.Split("_") switch { var parts => (parts[0], parts[1] == "desc") };

            var parameters = new List<string>
            {
                $"limit={NotScannedLimit}",
                $"offset={NotScannedCurrentOffset}",
                $"order={sort}",
                $"desc={descending}",
                "scanned=false"
            };

            AddFilteringParameters(parameters);
            AddSearchParameter(parameters);

            var response = await Client.GetAsync($"/api/properties/scans/{Scan!.Id}/items?{string.Join("&", parameters)}");

            if (response.StatusCode != HttpStatusCode.OK)
                throw new Exception("Something went wrong during the request to get not scanned items.");

            var content = await response.Content.ReadFromJsonAsync<IndexByScanPropertyItemResponse>()
                ?? throw new NullReferenceException();

            NotScannedItems = content.Data ?? [];
            TotalNotScannedCount = content.TotalCount;
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error loading not scanned items: {ex.Message}");
            NotScannedItems = [];
            TotalNotScannedCount = 0;
        }
    }

    private void AddFilteringParameters(List<string> parameters)
    {
        if (ShowFilteringOptions)
        {
            if (PriceMin is not null)
                parameters.Add($"minPrice={PriceMin}");
            if (PriceMax is not null)
                parameters.Add($"maxPrice={PriceMax}");
            if (CreatedAtFrom is not null)
                parameters.Add($"createdAtFrom={new DateTimeOffset(CreatedAtFrom.Value, TimeSpan.Zero).UtcDateTime:O}");
            if (CreatedAtTo is not null)
                parameters.Add($"createdAtTo={new DateTimeOffset(CreatedAtTo.Value, TimeSpan.Zero).UtcDateTime:O}");
            if (DateOfPurchaseFrom is not null)
                parameters.Add($"dateOfPurchaseFrom={new DateTimeOffset(DateOfPurchaseFrom.Value, TimeSpan.Zero).UtcDateTime:O}");
            if (DateOfPurchaseTo is not null)
                parameters.Add($"dateOfPurchaseTo={new DateTimeOffset(DateOfPurchaseTo.Value, TimeSpan.Zero).UtcDateTime:O}");
            if (FilteringEmployeeId is not null)
                parameters.Add($"employeeId={FilteringEmployeeId}");
            if (!string.IsNullOrEmpty(Room))
                parameters.Add($"room={Room}");
            if (!string.IsNullOrEmpty(Building))
                parameters.Add($"building={Building}");
            if (!string.IsNullOrEmpty(WithGeneratedCode))
                parameters.Add($"withGeneratedCode={WithGeneratedCode}");
        }
    }

    private void AddSearchParameter(List<string> parameters)
    {
        if (!string.IsNullOrEmpty(SearchQuery))
        {
            parameters.Add($"searchQuery={SearchQuery}");
        }
    }

    private async Task GetEmployeeForFiltering()
    {
        FilteringEmployeeErrorMessage = null;
        FilteringEmployeeId = null;

        if (string.IsNullOrWhiteSpace(FilteringEmployeeEmailAddress))
        {
            return;
        }

        var response = await Client.GetAsync($"/api/organizations/employees/{FilteringEmployeeEmailAddress}");

        if (response.StatusCode != HttpStatusCode.OK)
        {
            var exception = await response.Content.ReadFromJsonAsync<ErrorResponse>() ?? throw new NullReferenceException();

            if (exception.Type == "NotFound404Exception" && exception.Detail == "The employee was not found in the system.")
                FilteringEmployeeErrorMessage = "Zaměstnanec s touto adresou nebyl nalezen.";
            else if (exception.Type == "Unauthorized401Exception" && exception.Detail == "The employee is not from the admin's organization.")
                FilteringEmployeeErrorMessage = "Zaměstnanec s touto adresou nepatří k vaší organizaci.";
            else
                throw new Exception("Something went wrong during the request to get the employee.");

            return;
        }

        var content = await response.Content.ReadFromJsonAsync<EmployeeDto>() ?? throw new NullReferenceException();
        FilteringEmployeeId = content.Id;
    }

    private void ClearEmployeeFilter()
    {
        FilteringEmployeeEmailAddress = null;
        FilteringEmployeeErrorMessage = null;
        FilteringEmployeeId = null;
    }

    private async Task ClearFilters()
    {
        PriceMin = null;
        PriceMax = null;
        CreatedAtFrom = null;
        CreatedAtTo = null;
        DateOfPurchaseFrom = null;
        DateOfPurchaseTo = null;
        Room = null;
        Building = null;
        FilteringEmployeeEmailAddress = null;
        FilteringEmployeeErrorMessage = null;
        FilteringEmployeeId = null;
        WithGeneratedCode = null;

        await LoadItemsWithFilter();
    }

    private async Task ScanItem(PropertyItemDto item)
    {
        var response = await Client.PutAsync($"/api/properties/items/{item.Id}/scan", null);

        if (response.StatusCode != HttpStatusCode.NoContent) throw new Exception("Something went wrong during the request to scan the item.");

        await LoadScannedItems(ScannedCurrentOffset);
        await LoadNotScannedItems(NotScannedCurrentOffset);

        await OnChange.InvokeAsync(true);
    }
}
