@using System.Net
@using Invenire.Api.Properties.Scans
@using Invenire.Api.Properties.Scans.IndexByAdmin

<div class="scan-overview">
    <div class="modal-toolbar">
        <div class="modal-toolbar-header">
            <h3>Historie inventur</h3>
            <div class="scan-toolbar-actions">
                <div class="form-control">
                    <label for="scan-order">Řazení</label>
                    <select id="scan-order" @bind="SelectedOrderOption" @bind:after="() => LoadScan(0)">
                        @foreach (var option in OrderOptions)
                        {
                            <option value="@option.Value">@option.Label</option>
                        }
                    </select>
                </div>
            </div>
        </div>
        <p class="muted-text">Procházejte dokončené inventury, sledujte průběh a otevřete detail položek v jednom kroku.</p>
    </div>

    @if (Scan is not null)
    {
        <section class="section-card">
            <div class="section-heading">
                <h4>Základní informace</h4>
            </div>
            <div class="detail-list">
                <div class="detail-item">
                    <span class="detail-label">Id</span>
                    <span class="detail-value">@Scan.Id</span>
                </div>
                <div class="detail-item">
                    <span class="detail-label">Název</span>
                    <span class="detail-value">@Scan.Name</span>
                </div>
                @if (!string.IsNullOrWhiteSpace(Scan.Description))
                {
                    <div class="detail-item">
                        <span class="detail-label">Popis</span>
                        <span class="detail-value">@Scan.Description</span>
                    </div>
                }
                <div class="detail-item">
                    <span class="detail-label">Vytvořeno</span>
                    <span class="detail-value">@Scan.CreatedAt.ToUserTimeString()</span>
                </div>
                @if (Scan.LastUpdatedAt is not null)
                {
                    <div class="detail-item">
                        <span class="detail-label">Naposledy upraveno</span>
                        <span class="detail-value">@Scan.LastUpdatedAt.ToUserTimeString()</span>
                    </div>
                }
            </div>
        </section>

        <section class="section-card">
            <div class="section-heading">
                <h4>Informace o průběhu</h4>
            </div>
            <div class="stat-grid">
                <div class="stat-card">
                    <span class="stat-label">Celkový počet položek</span>
                    <span class="stat-value">@FormatCount(Scan.ScannedItemsSummary?.TotalItemsToScan)</span>
                </div>
                <div class="stat-card stat-card--success">
                    <span class="stat-label">Naskenováno</span>
                    <span class="stat-value">@FormatCount(Scan.ScannedItemsSummary?.TotalScannedItems)</span>
                </div>
                <div class="stat-card stat-card--warning">
                    <span class="stat-label">Nenaskenováno</span>
                    <span class="stat-value">@FormatCount(GetPendingItems())</span>
                </div>
            </div>
        </section>

        <section class="section-card">
            <div class="section-heading">
                <h4>Položky inventury</h4>
            </div>
            <AdminPropertyScanItemOverview Scan="Scan" @key="Scan.Id" />
        </section>

        <div class="scan-pagination">
            <button class="btn-secondary" type="button" @onclick="() => LoadScan(CurrentOffset - Limit)" disabled="@(!CanGoPrev)">◀</button>
            <span>@(CurrentOffset / Limit + 1) / @((int)Math.Ceiling((double)TotalScansCount / Limit))</span>
            <button class="btn-secondary" type="button" @onclick="() => LoadScan(CurrentOffset + Limit)" disabled="@(!CanGoNext)">▶</button>
        </div>
    }
    else
    {
        <div class="items-empty-state">Žádné inventury nebyly nalezeny.</div>
    }
</div>

@code
{
    [Inject] private HttpClient Client { get; set; } = default!;

    private PropertyScanDto? Scan { get; set; }

    private int Limit { get; set; } = 1;
    private int CurrentOffset { get; set; }
    private int TotalScansCount { get; set; }

    private bool CanGoPrev => CurrentOffset > 0;
    private bool CanGoNext => CurrentOffset + Limit < TotalScansCount;

    private string SelectedOrderOption { get; set; } = "createdat_desc";
    private readonly List<(string Value, string Label)> OrderOptions = new()
    {
        ("name_asc", "Název (A-Z)"),
        ("name_desc", "Název (Z-A)"),
        ("createdat_asc", "Datum přidání (nejstarší první)"),
        ("createdat_desc", "Datum přidání (nejnovější první)")
    };

    protected override async Task OnInitializedAsync() => await LoadScan(0);

    private async Task LoadScan(int offset)
    {
        CurrentOffset = Math.Max(0, offset);
        var (sort, descending) = SelectedOrderOption.Split("_") switch { var parts => (parts[0], parts[1] == "desc") };

        var response = await Client.GetAsync($"/api/properties/scans?limit={Limit}&offset={CurrentOffset}&active=false&order={sort}&desc={descending}");

        if (response.StatusCode != HttpStatusCode.OK) throw new Exception("Something went wrong during the request to get the scan.");

        var content = await response.Content.ReadFromJsonAsync<IndexByAdminPropertyScanResponse>() ?? throw new NullReferenceException();

        Scan = content.Data?.FirstOrDefault();
        Limit = content.Limit;
        TotalScansCount = content.TotalCount;

        StateHasChanged();
    }

    private string FormatCount(int? value) => (value ?? 0).ToString("N0");

    private int GetPendingItems()
        => Math.Max(0, (Scan?.ScannedItemsSummary?.TotalItemsToScan ?? 0) - (Scan?.ScannedItemsSummary?.TotalScannedItems ?? 0));
}
