@using Invenire.Api.Properties
@using Invenire.Components.Forms.Properties.Scans

@if (Property?.ScansSummary is PropertyDtoScansSummary summary)
{
    <div class="section-heading">
        <h4>Přehled inventur</h4>
    </div>

    <div class="stat-grid">
        <div class="stat-card">
            <span class="stat-label">Celkový počet</span>
            <span class="stat-value">@((summary.TotalScans ?? 0).ToString("N0"))</span>
        </div>
        <div class="stat-card @(summary.TotalActiveScans.GetValueOrDefault() == 1 ? "stat-card--success" : string.Empty)">
            <span class="stat-label">Aktivní inventura</span>
            <span class="stat-value">@((summary.TotalActiveScans.GetValueOrDefault() == 1) ? "Ano" : "Ne")</span>
        </div>
        <div class="stat-card">
            <span class="stat-label">Poslední dokončení</span>
            <span class="stat-value">@GetLastCompletion(summary)</span>
        </div>
    </div>

    @if (summary.TotalActiveScans.GetValueOrDefault() != 0)
    {
        <div class="active-scan-card">
            <div class="section-heading">
                <h5>Aktivní inventura</h5>
            </div>
            <AdminPropertyScanActiveOverview />
        </div>
    }

    <div class="action-row">
        <button class="btn-secondary" @onclick="OpenScansModal" disabled="@(summary.TotalScans.GetValueOrDefault() - summary.TotalActiveScans.GetValueOrDefault() == 0)">Historie</button>
        <button class="btn-secondary" @onclick="OpenCreationModal" disabled="@(summary.TotalActiveScans.GetValueOrDefault() == 1)">Spustit</button>
        <button class="btn-secondary" @onclick="OpenCompletionModal" disabled="@(summary.TotalActiveScans.GetValueOrDefault() != 1)">Dokončit</button>
    </div>
}
else
{
    <div class="empty-state">
        @if (Property?.ItemsSummary is not null)
        {
            <p>Zatím nebyly zhotovené žádné inventury.</p>
            <div class="action-row">
                <button class="btn-secondary" @onclick="OpenCreationModal">Spustit první inventuru</button>
            </div>
        }
        else
        {
            <p>Zatím nebyly přidané žádné položky.</p>
        }
    </div>
}

@if (ShowCreationModal)
{
    <div class="modal-overlay">
        <div class="modal-panel">
            <div class="modal-header">
                <h4>Začít novou inventuru</h4>
                <button class="btn-secondary" type="button" @onclick="CloseCreationModal">Zavřít</button>
            </div>

            <div class="modal-body">
                <CreatePropertyScanForm OnSuccessfulCreation="HandleScanCreated" OnClose="CloseCreationModal" />
            </div>
        </div>
    </div>
}

@if (ShowCompletionModal)
{
    <div class="modal-overlay">
        <div class="modal-panel">
            <div class="modal-header">
                <h4>Dokončit inventuru</h4>
                <button class="btn-secondary" type="button" @onclick="CloseCompletionModal">Zavřít</button>
            </div>

            <div class="modal-body">
                <CompletePropertyScanForm OnSuccessfulCompletion="HandleScanCompleted" OnClose="CloseCompletionModal" />
            </div>
        </div>
    </div>
}

@if (ShowAllScansModal)
{
    <div class="modal-overlay">
        <div class="modal-panel modal-panel--wide">
            <div class="modal-header">
                <h4>Historie inventur</h4>
                <button class="btn-secondary" type="button" @onclick="CloseScansModal">Zavřít</button>
            </div>

            <AdminPropertyScanOverview />
        </div>
    </div>
}

@code
{
    [Parameter] public PropertyDto? Property { get; set; }
    [Parameter] public EventCallback<bool> OnChange { get; set; }

    private bool ShowCreationModal { get; set; }
    private bool ShowAllScansModal { get; set; }
    private bool ShowCompletionModal { get; set; }

    private static string GetLastCompletion(PropertyDtoScansSummary summary)
        => summary.LastActiveScan?.ToString("dd.MM.yyyy HH:mm") ?? "—";

    private void OpenCreationModal() => ShowCreationModal = true;
    private void CloseCreationModal() => ShowCreationModal = false;
    private void OpenCompletionModal() => ShowCompletionModal = true;
    private void CloseCompletionModal() => ShowCompletionModal = false;
    private void OpenScansModal() => ShowAllScansModal = true;
    private void CloseScansModal() => ShowAllScansModal = false;

    private async Task HandleScanCreated()
    {
        ShowCreationModal = false;
        await OnChange.InvokeAsync(true);
    }

    private async Task HandleScanCompleted()
    {
        ShowCompletionModal = false;
        await OnChange.InvokeAsync(true);
    }
}
