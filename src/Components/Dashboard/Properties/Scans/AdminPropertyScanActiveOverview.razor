@using System.Net
@using Invenire.Api.Properties.Scans
@using Invenire.Api.Properties.Scans.IndexByAdmin

<div>
    @if (ActiveScan is not null && ActiveScan.ScannedItemsSummary is not null)
    {
        <ul>
            <li><strong>Id:</strong> @ActiveScan.Id</li>
            <li><strong>Název:</strong> @ActiveScan.Name</li>
            @if (!string.IsNullOrEmpty(ActiveScan.Description))
            {
                <li><strong>Text: </strong> @ActiveScan.Description</li>
            }
            <li><strong>Naskenováno</strong> @ActiveScan.ScannedItemsSummary.TotalScannedItems / @ActiveScan.ScannedItemsSummary.TotalItemsToScan</li>
            <li><strong>Vytvořeno:</strong> @ActiveScan.CreatedAt.ToString("dd.MM.yyyy HH:mm")</li>
            @if (ActiveScan.LastUpdatedAt is not null)
            {
                <li><strong>Naposledy upraveno:</strong> @ActiveScan.LastUpdatedAt?.ToString("dd.MM.yyyy HH:mm")</li>
            }
        </ul>

        <button @onclick="() => ShowActiveScansItemsModal = true">Zobrazit položky</button>

        @if (ShowActiveScansItemsModal)
        {
            <div style="
                        position: fixed;
                        top: 0;
                        left: 0;
                        width: 100%;
                        height: 100%;
                        background-color: rgba(0,0,0,0.5);
                        z-index: 9999;
                        display: flex;
                        justify-content: center;
                        align-items: center;
                        overflow: auto; /* allow modal to scroll if too tall */
                        padding: 1rem;  /* optional: spacing around modal */
                    ">
                <div style="
                            background: white;
                            border-radius: 6px;
                            max-height: 90vh;  /* don't exceed viewport height */
                            overflow-y: auto;  /* scroll inside modal */
                            padding: 1rem;
                            min-width: 300px;
                            max-width: 90%;
                        ">

                    <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 10px;">
                        <h4 style="margin:0;">Všechny položky inventury</h4>
                        <button @onclick="() => ShowActiveScansItemsModal = false">X</button>
                    </div>

                    <AdminPropertyScanItemOverview Scan="ActiveScan"/>
                </div>
            </div>
        }
    }
    else
    {
        <p>Objevila se nečekaná chyba. Zkuste to prosím později.</p>
    }
</div>

@code 
{
    [Inject] public HttpClient Client { get; set; } = default!;

    private PropertyScanDto? ActiveScan { get; set; }
    private bool ShowActiveScansItemsModal { get; set;}

    protected override async Task OnInitializedAsync() => await LoadActiveScan();

    private async Task LoadActiveScan()
    {
        var response = await Client.GetAsync("/api/properties/scans?limit=1&offset=0&active=true");

        if (response.StatusCode != HttpStatusCode.OK) throw new Exception("Something went wrong during the request to get the active scan.");

        var content = await response.Content.ReadFromJsonAsync<IndexByAdminPropertyScanResponse>() ?? throw new NullReferenceException();

        ActiveScan = content.Data.First();
    }
}