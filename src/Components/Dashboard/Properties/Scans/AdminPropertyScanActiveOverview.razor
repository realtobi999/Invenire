@using System.Net
@using System.Globalization
@using Invenire.Api.Properties.Scans
@using Invenire.Api.Properties.Scans.IndexByAdmin
@using Invenire.Components.Forms.Properties.Scans

<div class="active-scan-overview">
    @if (ActiveScan is not null && ActiveScan.ScannedItemsSummary is not null)
    {
        var summary = ActiveScan.ScannedItemsSummary;
        var totalItems = summary.TotalItemsToScan;
        var scannedItems = summary.TotalScannedItems;
        var pendingItems = GetPendingItems(totalItems, scannedItems);
        var completionPercentage = GetCompletionPercentage(totalItems, scannedItems);
        var completionPercentageValue = FormatPercentageValue(completionPercentage);
        var completionWidth = $"{completionPercentageValue}%";
        var completionLabel = FormatPercentageLabel(completionPercentage);
        var statusDisplay = GetStatusDisplay(ActiveScan.Status);

        <div class="active-scan-progress">
            <div class="progress-meta">
                <span class="progress-label">@completionLabel dokončeno</span>
                <span class="progress-total">@FormatCount(scannedItems) / @FormatCount(totalItems) položek</span>
            </div>
            <div class="progress-bar" role="progressbar" aria-valuenow="@completionPercentageValue" aria-valuemin="0" aria-valuemax="100">
                <span class="progress-value" style="width: @completionWidth"></span>
            </div>
            <div class="progress-stats">
                <span><strong>@FormatCount(scannedItems)</strong> naskenováno</span>
                <span><strong>@FormatCount(pendingItems)</strong> zbývá</span>
            </div>
        </div>

        <div class="stat-grid active-scan-stats">
            <div class="stat-card">
                <span class="stat-label">Celkový počet položek</span>
                <span class="stat-value">@FormatCount(totalItems)</span>
            </div>
            <div class="stat-card stat-card--success">
                <span class="stat-label">Naskenováno</span>
                <span class="stat-value">@FormatCount(scannedItems)</span>
            </div>
            <div class="stat-card stat-card--warning">
                <span class="stat-label">Zbývá naskenovat</span>
                <span class="stat-value">@FormatCount(pendingItems)</span>
            </div>
        </div>

        <div class="detail-list">
            <div class="detail-item">
                <span class="detail-label">ID inventury</span>
                <span class="detail-value">@ActiveScan.Id</span>
            </div>
            <div class="detail-item">
                <span class="detail-label">Název</span>
                <span class="detail-value">@ActiveScan.Name</span>
            </div>
            <div class="detail-item">
                <span class="detail-label">Stav</span>
                <span class="detail-value">
                    <span class="pill">
                        <span class="status-dot @statusDisplay.DotClass"></span>
                        @statusDisplay.Label
                    </span>
                </span>
            </div>
            @if (!string.IsNullOrWhiteSpace(ActiveScan.Description))
            {
                <div class="detail-item">
                    <span class="detail-label">Text</span>
                    <span class="detail-value">@ActiveScan.Description</span>
                </div>
            }
            <div class="detail-item">
                <span class="detail-label">Vytvořeno</span>
                <span class="detail-value">@ActiveScan.CreatedAt.ToUserTimeString()</span>
            </div>
            <div class="detail-item">
                <span class="detail-label">Naposledy upraveno</span>
                <span class="detail-value">@((ActiveScan.LastUpdatedAt?.ToUserTimeString()) ?? "-----")</span>
            </div>
        </div>

        <div class="active-scan-actions">
            <button class="btn-secondary" type="button" @onclick="() => ShowActiveScansItemsModal = true">Zobrazit položky</button>
            <button class="btn-secondary" type="button" @onclick="() => ShowUpdateActiveScanModal = true">Upravit informace</button>
        </div>

       @if (ShowActiveScansItemsModal)
        {
            <div class="modal-overlay">
                <div class="modal-panel modal-panel--wide">
                    <div class="modal-header">
                        <h4>Správa</h4>
                        <button class="btn-secondary" type="button" @onclick="CloseActiveScansItemsModal">Zavřít</button>
                    </div>

                    <AdminPropertyScanItemOverview Scan="ActiveScan" OnChange="() => LoadActiveScan()" />
                </div>
            </div>
        }

        @if (ShowUpdateActiveScanModal)
        {
            <div class="modal-overlay">
                <div class="modal-panel">
                    <div class="modal-header">
                        <h4>Úprava</h4>
                        <button class="btn-secondary" type="button" @onclick="CloseUpdateActiveScanModal">Zavřít</button>
                    </div>
                    <div class="modal-body">
                        <UpdatePropertyScanForm Scan="ActiveScan" OnClose="CloseUpdateActiveScanModal" OnSuccessfulUpdate="() => LoadActiveScan()" />
                    </div>
                </div>
            </div>
        }
    }
    else
    {
        <div class="empty-state">
            <p>Objevila se nečekaná chyba. Zkuste to prosím později.</p>
            <p class="muted-text">Aktivní inventura se nepodařila načíst.</p>
        </div>
    }
</div>

@code 
{
    [Inject] private HttpClient Client { get; set; } = default!;

    private PropertyScanDto? ActiveScan { get; set; }

    private bool ShowActiveScansItemsModal { get; set; }
    private bool ShowUpdateActiveScanModal { get; set; }

    protected override async Task OnInitializedAsync() => await LoadActiveScan();

    private async Task LoadActiveScan()
    {
        var response = await Client.GetAsync("/api/properties/scans?limit=1&offset=0&active=true");

        if (response.StatusCode != HttpStatusCode.OK) throw new Exception("Something went wrong during the request to get the active scan.");

        var content = await response.Content.ReadFromJsonAsync<IndexByAdminPropertyScanResponse>() ?? throw new NullReferenceException();

        ActiveScan = content.Data.FirstOrDefault();
    }

    private void CloseActiveScansItemsModal() => ShowActiveScansItemsModal = false;
    private void CloseUpdateActiveScanModal() => ShowUpdateActiveScanModal = false;

    private static int GetPendingItems(int total, int scanned) => Math.Max(0, total - scanned);

    private static double GetCompletionPercentage(int total, int scanned)
    {
        if (total <= 0) return 0;

        var percentage = (double)scanned / total * 100d;
        return Math.Clamp(percentage, 0, 100);
    }

    private static string FormatCount(int value) => value.ToString("N0");

    private static string FormatPercentageLabel(double percentage) => $"{Math.Round(percentage)}%";

    private static string FormatPercentageValue(double percentage)
        => Math.Clamp(percentage, 0, 100).ToString("0.##", CultureInfo.InvariantCulture);

    private static (string Label, string DotClass) GetStatusDisplay(PropertyScanStatusDto status)
        => status switch
        {
            PropertyScanStatusDto.COMPLETED => ("Dokončeno", "success"),
            _ => ("Probíhá", string.Empty)
        };
}
