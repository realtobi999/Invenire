@using System.Net
@using System.Globalization
@using Invenire.Api.Properties.Scans
@using Invenire.Components.Forms.Properties.Items

<div class="active-scan-overview">
    @if (ActiveScan is not null && ActiveScan.ScannedItemsSummary is not null)
    {
        var total = ActiveScan.ScannedItemsSummary.TotalItemsToScan;
        var scanned = ActiveScan.ScannedItemsSummary.TotalScannedItems;
        var pending = GetPendingItems(total, scanned);
        var percentage = GetCompletionPercentage(total, scanned);
        var display = GetStatusDisplay(ActiveScan.Status);

        <div class="active-scan-progress">
            <div class="progress-meta">
                <span class="progress-label">@FormatPercentageLabel(percentage) dokončeno</span>
                <span class="progress-total">@FormatCount(scanned) / @FormatCount(total) položek</span>
            </div>
            <div class="progress-bar" role="progressbar" aria-valuenow="@FormatPercentageValue(percentage)" aria-valuemin="0" aria-valuemax="100">
                <span class="progress-value" style="width: @($"{FormatPercentageValue(percentage)}%")"></span>
            </div>
            <div class="progress-stats">
                <span><strong>@FormatCount(scanned)</strong> naskenováno</span>
                <span><strong>@FormatCount(pending)</strong> zbývá</span>
            </div>
        </div>

        <div class="stat-grid active-scan-stats">
            <div class="stat-card">
                <span class="stat-label">Celkový počet položek</span>
                <span class="stat-value">@FormatCount(total)</span>
            </div>
            <div class="stat-card stat-card--success">
                <span class="stat-label">Naskenováno</span>
                <span class="stat-value">@FormatCount(scanned)</span>
            </div>
            <div class="stat-card stat-card--warning">
                <span class="stat-label">Zbývá naskenovat</span>
                <span class="stat-value">@FormatCount(pending)</span>
            </div>
        </div>

        <div class="detail-list">
            <div class="detail-item">
                <span class="detail-label">ID inventury</span>
                <span class="detail-value">@ActiveScan.Id</span>
            </div>
            <div class="detail-item">
                <span class="detail-label">Název</span>
                <span class="detail-value">@ActiveScan.Name</span>
            </div>
            <div class="detail-item">
                <span class="detail-label">Stav</span>
                <span class="detail-value">
                    <span class="pill">
                        <span class="status-dot @display.DotClass"></span>
                        @display.Label
                    </span>
                </span>
            </div>
            @if (!string.IsNullOrWhiteSpace(ActiveScan.Description))
            {
                <div class="detail-item">
                    <span class="detail-label">Text</span>
                    <span class="detail-value">@ActiveScan.Description</span>
                </div>
            }
            <div class="detail-item">
                <span class="detail-label">Vytvořeno</span>
                <span class="detail-value">@ActiveScan.CreatedAt.ToUserTimeString()</span>
            </div>
            <div class="detail-item">
                <span class="detail-label">Naposledy upraveno</span>
                <span class="detail-value">@((ActiveScan.LastUpdatedAt?.ToUserTimeString()) ?? "-----")</span>
            </div>
        </div>

        <div class="active-scan-actions">
            <button class="btn-secondary" type="button" @onclick="() => ShowActiveScansItemsModal = true">Spravovat</button>
            <button class="btn-secondary" type="button" @onclick="() => ShowScanItemModal = true">Skenovat</button>
        </div>

        @if (ShowActiveScansItemsModal)
        {
            <div class="modal-overlay">
                <div class="modal-panel modal-panel--wide">
                    <div class="modal-header">
                        <h3>Vaše položky</h3>
                        <button class="btn-secondary" type="button" @onclick="() => ShowActiveScansItemsModal = false">Zavřít</button>
                    </div>

                    <EmployeePropertyScanItemOverview Scan="ActiveScan" OnChange="() => LoadActiveScan()" />
                </div>
            </div>
        }
        @if (ShowScanItemModal)
        {
            <div class="modal-overlay">
                <div class="modal-panel">
                    <div class="modal-header">
                        <h4>Skenování položek</h4>
                        <button class="btn-secondary" type="button" @onclick="() => ShowScanItemModal = false">Zavřít</button>
                    </div>

                    <div class="modal-body">
                        <ScanPropertyItemForm OnSuccessfulScan="LoadActiveScan" />
                    </div>
                </div>
            </div>
        }
    }
    else
    {
        <div class="empty-state">
            <p class="muted-text">Jakmile admin spustí inventuru, budete ji moci sledovat zde.</p>
        </div>
    }
</div>

@code
{
    [Inject] private HttpClient Client { get; set; } = default!;

    private PropertyScanDto? ActiveScan { get; set; }

    private bool ShowScanItemModal { get; set; }
    private bool ShowActiveScansItemsModal { get; set; }

    protected override async Task OnInitializedAsync() => await LoadActiveScan();

    private async Task LoadActiveScan()
    {
        var response = await Client.GetAsync("/api/properties/scans/active");

        if (response.StatusCode != HttpStatusCode.OK)
        {
            if (response.StatusCode == HttpStatusCode.NotFound) return;

            throw new Exception("Something went wrong during the request to get the active scan.");
        }

        ActiveScan = await response.Content.ReadFromJsonAsync<PropertyScanDto>() ?? throw new NullReferenceException();
    }

    private static int GetPendingItems(int total, int scanned) => Math.Max(0, total - scanned);

    private static double GetCompletionPercentage(int total, int scanned)
        => total <= 0 ? 0 : Math.Clamp((double)scanned / total * 100d, 0, 100);

    private static string FormatCount(int value) => value.ToString("N0");

    private static string FormatPercentageLabel(double percentage) => $"{Math.Round(percentage)}%";

    private static string FormatPercentageValue(double percentage)
        => Math.Clamp(percentage, 0, 100).ToString("0.##", CultureInfo.InvariantCulture);

    private static (string Label, string DotClass) GetStatusDisplay(PropertyScanStatusDto status)
        => status switch
        {
            PropertyScanStatusDto.COMPLETED => ("Dokončeno", "success"),
            _ => ("Probíhá", string.Empty)
        };
}
