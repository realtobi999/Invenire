@using System.Net
@using Invenire.Api.Properties.Items
@using Invenire.Api.Properties.Items.Create
@using Invenire.Api.Properties.Items.Update
@using Invenire.Api.Properties.Suggestions
@using Invenire.Api.Properties.Suggestions.IndexByAdmin
@using Invenire.Components.Forms.Properties.Suggestions

<div class="suggestions-overview">
    <div class="modal-toolbar">
        <div class="modal-toolbar-header">
            <h3>Všechny návrhy</h3>
            <button class="btn-secondary" type="button" @onclick="() => OnClose.InvokeAsync(true)">Zavřít</button>
        </div>
    </div>

    <div class="items-toolbar">
        <div class="form-control grow">
            <label for="suggestion-search">Hledat</label>
            <input id="suggestion-search" class="input-control" type="text" @bind="SearchTerm" @bind:after="() => LoadSuggestions(0)" placeholder="Hledat návrhy..." />
        </div>
        <div class="form-control">
            <label for="OrderSelect">Řazení</label>
            <select id="OrderSelect" @bind="SelectedOrderOption" @bind:after="() => LoadSuggestions(0)">
                @foreach (var option in OrderOptions)
                {
                    <option value="@option.Value">@option.Label</option>
                }
            </select>
        </div>
    </div>

    @if (Suggestions.Any())
    {
        <div class="suggestion-list">
            @foreach (var suggestion in Suggestions)
            {
                var status = GetCzechStatus(suggestion.Status);
                var updatedEntries = GetUpdatedEntries(suggestion).ToList();
                var deletedEntries = GetDeletedEntries(suggestion).ToList();

                <article class="suggestion-card">
                    <div class="suggestion-card-header">
                        <div>
                            <p class="muted-text">Název</p>
                            <h4>@suggestion.Name</h4>
                        </div>
                        <span class="@($"suggestion-status suggestion-status--{status.Color.ToLowerInvariant()}")">@status.Text</span>
                    </div>

                    <div class="detail-list">
                        <div class="detail-item">
                            <span class="detail-label">Předloženo</span>
                            <span class="detail-value">@suggestion.Employee.EmailAddress</span>
                        </div>
                        @if (!string.IsNullOrEmpty(suggestion.Description))
                        {
                            <div class="detail-item">
                                <span class="detail-label">Text</span>
                                <span class="detail-value">@suggestion.Description</span>
                            </div>
                        }
                        @if (!string.IsNullOrEmpty(suggestion.Feedback))
                        {
                            <div class="detail-item">
                                <span class="detail-label">Feedback</span>
                                <span class="detail-value">@suggestion.Feedback</span>
                            </div>
                        }
                        <div class="detail-item">
                            <span class="detail-label">Vytvořeno</span>
                            <span class="detail-value">@suggestion.CreatedAt.ToUserTimeString()</span>
                        </div>
                        @if (suggestion.LastUpdatedAt is not null)
                        {
                            <div class="detail-item">
                                <span class="detail-label">Upraveno</span>
                                <span class="detail-value">@suggestion.LastUpdatedAt.Value.ToString("g")</span>
                            </div>
                        }
                    </div>

                    @if (suggestion.Payload is not null)
                    {
                        var createdCommands = suggestion.Payload.CreateCommands ?? new List<CreatePropertyItemRequest>();

                        if (createdCommands.Any())
                        {
                            <section class="payload-section">
                                <div class="payload-header">
                                    <h5>Vytvořené položky</h5>
                                    <span class="payload-count">@createdCommands.Count()</span>
                                </div>
                                <div class="payload-grid">
                                    @foreach (var command in createdCommands)
                                    {
                                        <article class="payload-card payload-card--created">
                                            <ul class="item-field-list">
                                                <li class="item-field">
                                                    <span class="field-label">Název</span>
                                                    <span class="field-value">@command.Name</span>
                                                </li>
                                                <li class="item-field">
                                                    <span class="field-label">Cena</span>
                                                    <span class="field-value">@command.Price Kč</span>
                                                </li>
                                                <li class="item-field">
                                                    <span class="field-label">Inventární číslo</span>
                                                    <span class="field-value">@command.InventoryNumber</span>
                                                </li>
                                                <li class="item-field">
                                                    <span class="field-label">Registrační číslo</span>
                                                    <span class="field-value">@command.RegistrationNumber</span>
                                                </li>
                                                <li class="item-field">
                                                    <span class="field-label">Sériové číslo</span>
                                                    <span class="field-value">@(command.SerialNumber ?? "-----")</span>
                                                </li>
                                                <li class="item-field">
                                                    <span class="field-label">Datum nákupu</span>
                                                    <span class="field-value">@command.DateOfPurchase:d</span>
                                                </li>
                                                @if (command.DateOfSale is not null)
                                                {
                                                    <li class="item-field">
                                                        <span class="field-label">Datum prodeje</span>
                                                        <span class="field-value">@command.DateOfSale:d</span>
                                                    </li>
                                                }
                                                <li class="item-field">
                                                    <span class="field-label">Umístění</span>
                                                    <span class="field-value">Budova @command.Location.Building, Místnost @command.Location.Room</span>
                                                </li>
                                                @if (!string.IsNullOrWhiteSpace(command.Location.AdditionalNote))
                                                {
                                                    <li class="item-field">
                                                        <span class="field-label">Poznámka</span>
                                                        <span class="field-value">@command.Location.AdditionalNote</span>
                                                    </li>
                                                }
                                                <li class="item-field">
                                                    <span class="field-label">Popis</span>
                                                    <span class="field-value">@command.Description</span>
                                                </li>
                                                <li class="item-field">
                                                    <span class="field-label">Číslo dokladu</span>
                                                    <span class="field-value">@command.DocumentNumber</span>
                                                </li>
                                            </ul>
                                        </article>
                                    }
                                </div>
                            </section>
                        }

                        if (updatedEntries.Any())
                        {
                            <section class="payload-section">
                                <div class="payload-header">
                                    <h5>Upravené položky</h5>
                                    <span class="payload-count">@updatedEntries.Count</span>
                                </div>
                                <div class="payload-grid">
                                    @foreach (var kv in updatedEntries)
                                    {
                                        var item = kv.Value;
                                        var command = kv.Key;

                                        <article class="payload-card payload-card--updated">
                                            <ul class="item-field-list">
                                                <li class="item-field">
                                                    <span class="field-label">ID</span>
                                                    <span class="field-value">@command.Id</span>
                                                </li>
                                                <li class="@GetPayloadFieldClass(command.Name != item.Name)">
                                                    <span class="field-label">Název</span>
                                                    <span class="field-value">@command.Name</span>
                                                    @if (command.Name != item.Name)
                                                    {
                                                        <span class="field-original">Původně: @item.Name</span>
                                                    }
                                                </li>
                                                <li class="@GetPayloadFieldClass(command.Price != item.Price)">
                                                    <span class="field-label">Cena</span>
                                                    <span class="field-value">@command.Price Kč</span>
                                                    @if (command.Price != item.Price)
                                                    {
                                                        <span class="field-original">Původně: @item.Price Kč</span>
                                                    }
                                                </li>
                                                <li class="@GetPayloadFieldClass(command.InventoryNumber != item.InventoryNumber)">
                                                    <span class="field-label">Inventární číslo</span>
                                                    <span class="field-value">@command.InventoryNumber</span>
                                                    @if (command.InventoryNumber != item.InventoryNumber)
                                                    {
                                                        <span class="field-original">Původně: @item.InventoryNumber</span>
                                                    }
                                                </li>
                                                <li class="@GetPayloadFieldClass(command.RegistrationNumber != item.RegistrationNumber)">
                                                    <span class="field-label">Registrační číslo</span>
                                                    <span class="field-value">@command.RegistrationNumber</span>
                                                    @if (command.RegistrationNumber != item.RegistrationNumber)
                                                    {
                                                        <span class="field-original">Původně: @item.RegistrationNumber</span>
                                                    }
                                                </li>
                                                <li class="@GetPayloadFieldClass(command.SerialNumber != item.SerialNumber)">
                                                    <span class="field-label">Sériové číslo</span>
                                                    <span class="field-value">@(command.SerialNumber ?? "-----")</span>
                                                    @if (command.SerialNumber != item.SerialNumber)
                                                    {
                                                        <span class="field-original">Původně: @(item.SerialNumber ?? "-----")</span>
                                                    }
                                                </li>
                                                <li class="@GetPayloadFieldClass(command.DateOfPurchase != item.DateOfPurchase)">
                                                    <span class="field-label">Datum nákupu</span>
                                                    <span class="field-value">@command.DateOfPurchase:d</span>
                                                    @if (command.DateOfPurchase != item.DateOfPurchase)
                                                    {
                                                        <span class="field-original">Původně: @item.DateOfPurchase:d</span>
                                                    }
                                                </li>
                                                @if (command.DateOfSale is not null || item.DateOfSale is not null)
                                                {
                                                    <li class="@GetPayloadFieldClass(command.DateOfSale != item.DateOfSale)">
                                                        <span class="field-label">Datum prodeje</span>
                                                        <span class="field-value">@(
                                                            command.DateOfSale?.ToString("d") ?? "-----")</span>
                                                        @if (command.DateOfSale != item.DateOfSale)
                                                        {
                                                            <span class="field-original">Původně: @(item.DateOfSale?.ToString("d") ?? "-----")</span>
                                                        }
                                                    </li>
                                                }
                                                <li class="@GetPayloadFieldClass(command.Location.Building != item.Location.Building || command.Location.Room != item.Location.Room)">
                                                    <span class="field-label">Umístění</span>
                                                    <span class="field-value">Budova @command.Location.Building, Místnost @command.Location.Room</span>
                                                    @if (command.Location.Building != item.Location.Building || command.Location.Room != item.Location.Room)
                                                    {
                                                        <span class="field-original">Původně: Budova @item.Location.Building, Místnost @item.Location.Room</span>
                                                    }
                                                </li>
                                                @if (!string.IsNullOrWhiteSpace(command.Location.AdditionalNote) || !string.IsNullOrWhiteSpace(item.Location.AdditionalNote))
                                                {
                                                    <li class="@GetPayloadFieldClass(command.Location.AdditionalNote != item.Location.AdditionalNote)">
                                                        <span class="field-label">Poznámka</span>
                                                        <span class="field-value">@(command.Location.AdditionalNote ?? "-----")</span>
                                                        @if (command.Location.AdditionalNote != item.Location.AdditionalNote)
                                                        {
                                                            <span class="field-original">Původně: @(item.Location.AdditionalNote ?? "-----")</span>
                                                        }
                                                    </li>
                                                }
                                                <li class="item-field">
                                                    <span class="field-label">Spravuje</span>
                                                    <span class="field-value">@(!string.IsNullOrEmpty(item.Employee.EmailAddress) ? item.Employee.EmailAddress : "-----")</span>
                                                </li>
                                                <li class="@GetPayloadFieldClass(command.Description != item.Description)">
                                                    <span class="field-label">Popis</span>
                                                    <span class="field-value">@command.Description</span>
                                                    @if (command.Description != item.Description)
                                                    {
                                                        <span class="field-original">Původně: @item.Description</span>
                                                    }
                                                </li>
                                                <li class="@GetPayloadFieldClass(command.DocumentNumber != item.DocumentNumber)">
                                                    <span class="field-label">Číslo dokladu</span>
                                                    <span class="field-value">@command.DocumentNumber</span>
                                                    @if (command.DocumentNumber != item.DocumentNumber)
                                                    {
                                                        <span class="field-original">Původně: @(item.DocumentNumber ?? "-----")</span>
                                                    }
                                                </li>
                                                <li class="item-field">
                                                    <span class="field-label">Přidáno</span>
                                                    <span class="field-value">@item.CreatedAt:g</span>
                                                </li>
                                                @if (item.LastUpdatedAt is not null)
                                                {
                                                    <li class="item-field">
                                                        <span class="field-label">Upraveno</span>
                                                        <span class="field-value">@item.LastUpdatedAt:g</span>
                                                    </li>
                                                }
                                            </ul>
                                        </article>
                                    }
                                </div>
                            </section>
                        }

                        if (deletedEntries.Any())
                        {
                            <section class="payload-section">
                                <div class="payload-header">
                                    <h5>Smazané položky</h5>
                                    <span class="payload-count">@deletedEntries.Count</span>
                                </div>
                                <div class="payload-grid">
                                    @foreach (var item in deletedEntries)
                                    {
                                        <article class="payload-card payload-card--deleted">
                                            <ul class="item-field-list">
                                                <li class="item-field">
                                                    <span class="field-label">ID</span>
                                                    <span class="field-value">@item.Id</span>
                                                </li>
                                                <li class="item-field">
                                                    <span class="field-label">Název</span>
                                                    <span class="field-value">@item.Name</span>
                                                </li>
                                                <li class="item-field">
                                                    <span class="field-label">Cena</span>
                                                    <span class="field-value">@item.Price Kč</span>
                                                </li>
                                                <li class="item-field">
                                                    <span class="field-label">Inventární číslo</span>
                                                    <span class="field-value">@item.InventoryNumber</span>
                                                </li>
                                                <li class="item-field">
                                                    <span class="field-label">Registrační číslo</span>
                                                    <span class="field-value">@item.RegistrationNumber</span>
                                                </li>
                                                <li class="item-field">
                                                    <span class="field-label">Sériové číslo</span>
                                                    <span class="field-value">@(item.SerialNumber ?? "-----")</span>
                                                </li>
                                                <li class="item-field">
                                                    <span class="field-label">Datum nákupu</span>
                                                    <span class="field-value">@item.DateOfPurchase:d</span>
                                                </li>
                                                @if (item.DateOfSale is not null)
                                                {
                                                    <li class="item-field">
                                                        <span class="field-label">Datum prodeje</span>
                                                        <span class="field-value">@item.DateOfSale:d</span>
                                                    </li>
                                                }
                                                <li class="item-field">
                                                    <span class="field-label">Umístění</span>
                                                    <span class="field-value">Budova @item.Location.Building, Místnost @item.Location.Room</span>
                                                </li>
                                                @if (!string.IsNullOrWhiteSpace(item.Location.AdditionalNote))
                                                {
                                                    <li class="item-field">
                                                        <span class="field-label">Poznámka</span>
                                                        <span class="field-value">@item.Location.AdditionalNote</span>
                                                    </li>
                                                }
                                                <li class="item-field">
                                                    <span class="field-label">Spravuje</span>
                                                    <span class="field-value">@(!string.IsNullOrEmpty(item.Employee.EmailAddress) ? item.Employee.EmailAddress : "-----")</span>
                                                </li>
                                                <li class="item-field">
                                                    <span class="field-label">Popis</span>
                                                    <span class="field-value">@item.Description</span>
                                                </li>
                                                <li class="item-field">
                                                    <span class="field-label">Číslo dokladu</span>
                                                    <span class="field-value">@(
                                                        item.DocumentNumber ?? "-----")</span>
                                                </li>
                                                <li class="item-field">
                                                    <span class="field-label">Přidáno</span>
                                                    <span class="field-value">@item.CreatedAt:g</span>
                                                </li>
                                                @if (item.LastUpdatedAt is not null)
                                                {
                                                    <li class="item-field">
                                                        <span class="field-label">Upraveno</span>
                                                        <span class="field-value">@item.LastUpdatedAt:g</span>
                                                    </li>
                                                }
                                            </ul>
                                        </article>
                                    }
                                </div>
                            </section>
                        }
                    }

                    <div class="suggestion-actions">
                        <button class="btn-secondary" type="button" @onclick="() => OpenAcceptSuggestion(suggestion)">Schválit</button>
                        <button class="btn-destructive" type="button" @onclick="() => OpenDeclineSuggestion(suggestion)">Odmítnout</button>
                    </div>
                </article>
            }
        </div>

        <div class="items-pagination">
            <button class="btn-secondary" type="button" @onclick="() => LoadSuggestions(CurrentOffset - Limit)" disabled="@(!CanGoPrev)">◀</button>
            <span>@(CurrentOffset / Limit + 1) / @((int)Math.Ceiling((double)TotalItemsCount / Limit))</span>
            <button class="btn-secondary" type="button" @onclick="() => LoadSuggestions(CurrentOffset + Limit)" disabled="@(!CanGoNext)">▶</button>
        </div>
    }
    else
    {
        <div class="items-empty-state">
            <p>Žádné návrhy nebyly nalezeny.</p>
        </div>
    }
</div>
@if (ShowAcceptSuggestionModal && SelectedSuggestion is not null)
{
    <div class="modal-overlay">
        <div class="modal-panel">
            <div class="modal-header">
                <h4>Schválit návrh</h4>
                <button class="btn-secondary" type="button" @onclick="CloseAcceptSuggestionModal">Zavřít</button>
            </div>

            <div class="modal-body">
                <AcceptPropertySuggestionForm Suggestion="SelectedSuggestion" OnChange="() => OnAcceptSuggestion()" OnClose="CloseAcceptSuggestionModal" />
            </div>
        </div>
    </div>
}

@if (ShowDeclineSuggestionModal && SelectedSuggestion is not null)
{
    <div class="modal-overlay">
        <div class="modal-panel">
            <div class="modal-header">
                <h4>Odmítnout návrh</h4>
                <button class="btn-secondary" type="button" @onclick="CloseDeclineSuggestionModal">Zavřít</button>
            </div>

            <div class="modal-body">
                <DeclinePropertySuggestionForm Suggestion="SelectedSuggestion" OnChange="() => OnDeclineSuggestion()" OnClose="CloseDeclineSuggestionModal" />
            </div>
        </div>
    </div>
}

@code
{
    [Inject] private HttpClient Client { get; set; } = default!;
    [Parameter] public EventCallback<bool> OnClose { get; set; }
    [Parameter] public EventCallback<bool> OnChange { get; set; }

    private List<PropertySuggestionDto> Suggestions { get; set; } = [];
    private Dictionary<Guid, PropertyItemDto> DeletedItems { get; set; } = [];
    private Dictionary<UpdatePropertyItemRequestBody, PropertyItemDto> UpdatedItems { get; set; } = [];

    private int Limit { get; set; } = 1;
    private int CurrentOffset { get; set; }
    private int TotalItemsCount { get; set; }

    private bool CanGoPrev => CurrentOffset > 0;
    private bool CanGoNext => CurrentOffset + Limit < TotalItemsCount;

    protected override async Task OnInitializedAsync() => await LoadSuggestions(0);

    private async Task LoadSuggestions(int offset)
    {
        UpdatedItems.Clear();
        DeletedItems.Clear();

        CurrentOffset = Math.Max(0, offset);

        var (sort, descending) = SelectedOrderOption.Split("_") switch { var parts => (parts[0], parts[1] == "desc") };

        var parameters = new List<string>
        {
            $"limit={Limit}",
            $"offset={CurrentOffset}",
            $"order={sort}",
            $"desc={descending}",
            $"status={PropertySuggestionDtoStatus.PENDING}"
        };

        if (!string.IsNullOrEmpty(SearchTerm))
            parameters.Add($"searchQuery={SearchTerm}");

        var response = await Client.GetAsync($"/api/properties/suggestions?{string.Join("&", parameters)}");

        if (response.StatusCode != HttpStatusCode.OK) throw new Exception("Something went wrong during the request to get the suggestions.");

        var content = await response.Content.ReadFromJsonAsync<IndexByAdminPropertySuggestionResponse>() ?? throw new NullReferenceException();

        Suggestions = content.Data;
        Limit = content.Limit;
        TotalItemsCount = content.TotalCount;

        if (!Suggestions.Any()) return;

        foreach (var suggestion in Suggestions)
        {
            foreach (var id in suggestion.Payload!.DeleteCommands)
            {
                DeletedItems[id] = await GetItem(id);
            }
            foreach (var command in suggestion.Payload!.UpdateCommands)
            {
                UpdatedItems[command] = await GetItem(command.Id);
            }
        }
    }

    private string? SearchTerm { get; set; }

    private string SelectedOrderOption { get; set; } = "createdat_asc";
    private readonly List<(string Value, string Label)> OrderOptions = new()
    {
        ("name_asc", "Název (A-Z)"),
        ("name_desc", "Název (Z-A)"),
        ("createdat_asc", "Datum přidání (nejstarší první)"),
        ("createdat_desc", "Datum přidání (nejnovější první)")
    };

    private async Task<PropertyItemDto> GetItem(Guid id)
    {
        var response = await Client.GetAsync($"/api/properties/items/{id}");

        if (response.StatusCode != HttpStatusCode.OK) throw new Exception("Something went wrong during the request to get the item.");

        return await response.Content.ReadFromJsonAsync<PropertyItemDto>() ?? throw new NullReferenceException();
    }

    private bool ShowAcceptSuggestionModal { get; set; }
    private bool ShowDeclineSuggestionModal { get; set; }
    private PropertySuggestionDto? SelectedSuggestion { get; set; }

    private async Task OnAcceptSuggestion()
    {
        await LoadSuggestions(0);
        await OnChange.InvokeAsync(true);
        CloseAcceptSuggestionModal();
    }

    private async Task OnDeclineSuggestion()
    {
        await LoadSuggestions(0);
        await OnChange.InvokeAsync(true);
        CloseDeclineSuggestionModal();
    }

    private void OpenAcceptSuggestion(PropertySuggestionDto suggestion) => (SelectedSuggestion, ShowAcceptSuggestionModal) = (suggestion, true);
    private void CloseAcceptSuggestionModal() => (ShowAcceptSuggestionModal, SelectedSuggestion) = (false, null);
    private void OpenDeclineSuggestion(PropertySuggestionDto suggestion) => (SelectedSuggestion, ShowDeclineSuggestionModal) = (suggestion, true);
    private void CloseDeclineSuggestionModal() => (ShowDeclineSuggestionModal, SelectedSuggestion) = (false, null);

    private IEnumerable<KeyValuePair<UpdatePropertyItemRequestBody, PropertyItemDto>> GetUpdatedEntries(PropertySuggestionDto suggestion)
        => suggestion.Payload is null
            ? Enumerable.Empty<KeyValuePair<UpdatePropertyItemRequestBody, PropertyItemDto>>()
            : UpdatedItems.Where(kv => suggestion.Payload.UpdateCommands.Any(cmd => cmd.Id == kv.Key.Id));

    private IEnumerable<PropertyItemDto> GetDeletedEntries(PropertySuggestionDto suggestion)
        => suggestion.Payload is null
            ? Enumerable.Empty<PropertyItemDto>()
            : DeletedItems.Where(kv => suggestion.Payload.DeleteCommands.Contains(kv.Key)).Select(kv => kv.Value);

    private (string Text, string Color) GetCzechStatus(PropertySuggestionDtoStatus status)
        => status switch
        {
            PropertySuggestionDtoStatus.PENDING => ("Nevyřízený", "goldenrod"),
            PropertySuggestionDtoStatus.DECLINED => ("Odmítnutý", "red"),
            _ => ("Neznámý", "gray")
        };

    private static string GetPayloadFieldClass(bool changed)
        => changed ? "item-field item-field--changed" : "item-field";
}
