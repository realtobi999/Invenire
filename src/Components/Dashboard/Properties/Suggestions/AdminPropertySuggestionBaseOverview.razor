@using Invenire.Api.Properties

<h4>Přehled návrhů</h4>

@if (Property is not null && Property.SuggestionsSummary is not null)
{
    <ul>
        <li>
            <strong>Celkový počet:</strong> @Property.SuggestionsSummary.TotalSuggestions
        </li>
        <li>
            <strong>Celkový počet přijatých:</strong> 
            <span style="color:green">@Property.SuggestionsSummary.TotalApprovedSuggestions</span>
        </li>
        <li>
            <strong>Celkový počet odmítnutých:</strong> 
            <span style="color:red">@Property.SuggestionsSummary.TotalDeclinedSuggestions</span>
        </li>
        <li>
            <strong>Celkový počet nevyřízených:</strong> 
            <span style="color:goldenrod">@Property.SuggestionsSummary.TotalPendingSuggestions</span>
        </li>
    </ul>

    <button @onclick="() => ShowAllSuggestionModal = true">Zobrazit</button>

    @if (ShowAllSuggestionModal)
    {
        <div style="
                    position: fixed;
                    top: 0;
                    left: 0;
                    width: 100%;
                    height: 100%;
                    background-color: rgba(0,0,0,0.5);
                    z-index: 9999;
                    display: flex;
                    justify-content: center;
                    align-items: center;
                    overflow: auto; /* allow modal to scroll if too tall */
                    padding: 1rem;  /* optional: spacing around modal */
                ">
            <div style="
                        background: white;
                        border-radius: 6px;
                        max-height: 90vh;  /* don't exceed viewport height */
                        overflow-y: auto;  /* scroll inside modal */
                        padding: 1rem;
                        min-width: 300px;
                        max-width: 90%;
                    ">
                    <AdminPropertySuggestionOverview OnClose="() => ShowAllSuggestionModal = false"/>
            </div>
        </div>
    }
}
else
{
    <p>Zatím nebyli přidané žádné návrhy</p>
}

@code {
    [Inject] public HttpClient Client { get; set; } = default!;
    [Parameter] public PropertyDto? Property { get; set; }
    [Parameter] public EventCallback<bool> OnChange { get; set; }

    private bool ShowAllSuggestionModal { get; set; }
}