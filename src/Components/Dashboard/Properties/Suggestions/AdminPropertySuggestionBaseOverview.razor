@using Invenire.Api.Properties

@if (Property?.SuggestionsSummary is PropertyDtoSuggestionsSummary summary)
{
    <div class="section-heading">
        <h4>Přehled návrhů</h4>
    </div>

    <div class="stat-grid">
        <div class="stat-card">
            <span class="stat-label">Celkový počet</span>
            <span class="stat-value">@((summary.TotalSuggestions ?? 0).ToString("N0"))</span>
        </div>
        <div class="stat-card stat-card--success">
            <span class="stat-label">Přijaté</span>
            <span class="stat-value">@((summary.TotalApprovedSuggestions ?? 0).ToString("N0"))</span>
        </div>
        <div class="stat-card stat-card--danger">
            <span class="stat-label">Odmítnuté</span>
            <span class="stat-value">@((summary.TotalDeclinedSuggestions ?? 0).ToString("N0"))</span>
        </div>
        <div class="stat-card stat-card--warning">
            <span class="stat-label">Nevyřízené</span>
            <span class="stat-value">@((summary.TotalPendingSuggestions ?? 0).ToString("N0"))</span>
        </div>
    </div>

    <div class="action-row">
        <button class="btn-secondary" @onclick="() => ShowAllSuggestionModal = true" disabled="@(summary.TotalPendingSuggestions.GetValueOrDefault() == 0)">Zobrazit nevyřízené</button>
    </div>
}
else
{
    <div class="empty-state">
        @if (Property?.ItemsSummary is not null)
        {
            <p>Zatím nebyly přidány žádné návrhy.</p>
        }
        else
        {
            <p>Zatím nebyly přidané žádné položky.</p>
        }
    </div>
}

@if (ShowAllSuggestionModal)
{
    <div class="modal-overlay">
        <div class="modal-panel modal-panel--wide">
            <AdminPropertySuggestionOverview OnClose="() => ShowAllSuggestionModal=false" OnChange="HandleSuggestionsChanged" />
        </div>
    </div>
}

@code
{
    [Parameter] public PropertyDto? Property { get; set; }
    [Parameter] public EventCallback<bool> OnChange { get; set; }

    private bool ShowAllSuggestionModal { get; set; }

    private async Task HandleSuggestionsChanged()
    {
        await OnChange.InvokeAsync(true);
    }
}
