@using System.Net
@using Blazored.LocalStorage
@using Invenire.Common.Errors
@using System.Threading.Tasks
@using Invenire.Api.Properties
@using Invenire.Api.Users.Employees
@using Invenire.Api.Properties.Items
@using Invenire.Api.Organizations.Create
@using Invenire.Api.Properties.Items.Update
@using Invenire.Api.Properties.Items.Delete
@using Invenire.Api.Properties.Items.IndexByAdmin
@using Invenire.Components.Forms.Properties.Items
@using Invenire.Components.Forms.Properties.Suggestions
@using System.Formats.Asn1

<div class="items-overview">
    <div class="modal-toolbar">
        <div class="modal-toolbar-header">
            <h3>Všechny položky</h3>
            <button class="btn-secondary" type="button" @onclick="() => OnClose.InvokeAsync(true)">Zavřít</button>
        </div>
        <p class="muted-text">Prohlížejte položky, navrhujte úpravy a označujte je ke smazání pro vytvoření návrhu.</p>
    </div>

    <div class="items-toolbar">
        <div class="form-control grow">
            <label for="items-search">Hledat</label>
            <input id="items-search"
                   class="input-control"
                   type="text"
                   @bind="SearchTerm"
                   @bind:after="() => LoadItems(0)"
                   placeholder="Hledat položky..." />
        </div>
        <div class="form-control">
            <label for="order-select">Řazení</label>
            <select id="order-select"
                    @bind="SelectedOrderOption"
                    @bind:after="() => LoadItems(0)">
                @foreach (var option in OrderOptions)
                {
                    <option value="@option.Value">@option.Label</option>
                }
            </select>
        </div>
        <button class="btn-secondary" type="button" @onclick="ToggleFilters">
            @(ShowFilteringOptions ? "Zrušit filtrování" : "Filtrovat")
        </button>
    </div>

    @if (ShowFilteringOptions)
    {
        <section class="filter-panel">
            <div class="filter-grid">
                <div class="form-control">
                    <label>Cena od</label>
                    <input class="input-control" type="number" min="0" @bind="PriceMin" />
                </div>
                <div class="form-control">
                    <label>Cena do</label>
                    <input class="input-control" type="number" min="0" @bind="PriceMax" />
                </div>
                <div class="form-control">
                    <label>Datum nákupu od</label>
                    <input class="input-control" type="date" @bind="DateOfPurchaseFrom" />
                </div>
                <div class="form-control">
                    <label>Datum nákupu do</label>
                    <input class="input-control" type="date" @bind="DateOfPurchaseTo" />
                </div>
                <div class="form-control">
                    <label>Datum přidání od</label>
                    <input class="input-control" type="date" @bind="CreatedAtFrom" />
                </div>
                <div class="form-control">
                    <label>Datum přidání do</label>
                    <input class="input-control" type="date" @bind="CreatedAtTo" />
                </div>
                <div class="form-control">
                    <label>Budova</label>
                    <input class="input-control" type="text" @bind="Building" />
                </div>
                <div class="form-control">
                    <label>Místnost</label>
                    <input class="input-control" type="text" @bind="Room" />
                </div>
                <div class="form-control">
                    <label>Vygenerovaný kód</label>
                    <select class="input-control" @bind="WithGeneratedCode">
                        <option value="">Nezáleží</option>
                        <option value="true">S kódem</option>
                        <option value="false">Bez kódu</option>
                    </select>
                </div>
            </div>
            <div class="filter-actions">
                <button class="btn-secondary" type="button" @onclick="() => LoadItems(0)">Použít</button>
                <button class="btn-secondary" type="button" @onclick="async () => await ClearFilters()">Vymazat</button>
            </div>
        </section>
    }

    <div class="limit-row">
        <span class="limit-meta">Na stránce @Items.Count z @TotalItemsCount položek</span>
        <div>
            <label for="limit_slider">Limit položek</label>
            <input id="limit_slider"
                   class="range-control"
                   type="range"
                   min="28"
                   max="200"
                   step="4"
                   @bind="Limit"
                   @bind:after="() => LoadItems(CurrentOffset)" />
        </div>
    </div>

    @if (Items.Any())
    {
        <section class="bulk-panel">
            <div class="bulk-group">
                <button class="btn-secondary" type="button" @onclick="() => SelectItems(Items)" disabled="@(Items.Except(DeletedItems).All(i => SelectedItems.Contains(i)))">Vybrat vše</button>
                <button class="btn-secondary" type="button" @onclick="ClearSelectedItems" disabled="@(!SelectedItems.Any())">Zrušit výběr</button>
                <span>Počet vybraných: @SelectedItems.Count</span>
            </div>
            <div class="bulk-group">
                <button class="btn-secondary" type="button" @onclick="DeleteSelectedItems" disabled="@(!SelectedItems.Any())">Označit vybrané jako smazané</button>
                <button class="btn-secondary" type="button" @onclick="ClearDeletedItems" disabled="@(!DeletedItems.Any())">Ponechat všechny smazané položky</button>
            </div>
            <div class="bulk-group">
                <button class="btn-secondary" type="button" @onclick="() => ShowCreateSuggestionModal = true" disabled="@(!HasPendingChanges)">Vytvořit návrh</button>
                <button class="btn-secondary" type="button" @onclick="async () => { await ClearDeletedItems(); await ClearUpdatedItems(); }" disabled="@(!HasPendingChanges)">Zrušit změny</button>
            </div>
        </section>

        <div class="items-grid">
            @foreach (var item in Items.Select(i => UpdatedItemDtos.GetValueOrDefault(i.Id, i)))
            {
                var isPendingUpdate = UpdatedItemDtos.ContainsKey(item.Id);
                var original = isPendingUpdate ? Items.FirstOrDefault(i => i.Id == item.Id) : item;
                var isEditing = EditedItems.ContainsKey(item.Id);

                <article class="@GetItemCardClass(item)" @onclick="() => SelectItem(item)" tabindex="0">
                    <div class="item-card-header">
                        <div>
                            <p class="muted-text item-id">ID: @item.Id</p>
                            <h5>@item.Name</h5>
                        </div>
                        <span class="item-price"><span>@item.Price</span><span>Kč</span></span>
                    </div>

                    @if (isEditing)
                    {
                        var edit = EditedItems[item.Id].Updated;
                        <div class="item-edit-grid" @onclick:stopPropagation="true">
                            <div class="form-control">
                                <label>Název</label>
                                <input class="input-control" @bind="edit.Name" />
                            </div>
                            <div class="form-control">
                                <label>Cena</label>
                                <input class="input-control" type="number" @bind="edit.Price" />
                            </div>
                            <div class="form-control">
                                <label>Inventární číslo</label>
                                <input class="input-control" @bind="edit.InventoryNumber" required />
                            </div>
                            <div class="form-control">
                                <label>Registrační číslo</label>
                                <input class="input-control" @bind="edit.RegistrationNumber" />
                            </div>
                            <div class="form-control">
                                <label>Sériové číslo</label>
                                <input class="input-control" @bind="edit.SerialNumber" />
                            </div>
                            <div class="form-control">
                                <label>Datum nákupu</label>
                                <input class="input-control" type="date" @bind="edit.DateOfPurchase" />
                            </div>
                            <div class="form-control">
                                <label>Datum prodeje</label>
                                <input class="input-control" type="date" @bind="edit.DateOfSale" />
                            </div>
                            <div class="form-control">
                                <label>Budova</label>
                                <input class="input-control" @bind="edit.Location.Building" />
                            </div>
                            <div class="form-control">
                                <label>Místnost</label>
                                <input class="input-control" @bind="edit.Location.Room" />
                            </div>
                            <div class="form-control">
                                <label>Poznámka k umístění</label>
                                <input class="input-control" @bind="edit.Location.AdditionalNote" />
                            </div>
                            <div class="form-control">
                                <label>Spravuje</label>
                                <p class="muted-text">@(string.IsNullOrEmpty(edit.Employee.EmailAddress) ? "-----" : edit.Employee.EmailAddress)</p>
                            </div>
                            <div class="form-control">
                                <label>Popis</label>
                                <textarea class="input-control" rows="2" @bind="edit.Description"></textarea>
                            </div>
                            <div class="form-control">
                                <label>Číslo dokladu</label>
                                <input class="input-control" @bind="edit.DocumentNumber" />
                            </div>
                        </div>
                    }
                    else
                    {
                        <ul class="item-field-list">
                            <li class="item-field">
                                <span class="field-label">ID</span>
                                <span class="field-value">@item.Id</span>
                            </li>
                            <li class="@GetFieldClass(isPendingUpdate && item.Name != original!.Name)">
                                <span class="field-label">Název</span>
                                <span class="field-value">@item.Name</span>
                                @if (isPendingUpdate && item.Name != original!.Name)
                                {
                                    <span class="field-original">Původně: @original!.Name</span>
                                }
                            </li>
                            <li class="@GetFieldClass(isPendingUpdate && item.Price != original!.Price)">
                                <span class="field-label">Cena</span>
                                <span class="field-value">@item.Price Kč</span>
                                @if (isPendingUpdate && item.Price != original!.Price)
                                {
                                    <span class="field-original">Původně: @original!.Price Kč</span>
                                }
                            </li>
                            <li class="@GetFieldClass(isPendingUpdate && item.InventoryNumber != original!.InventoryNumber)">
                                <span class="field-label">Inventární číslo</span>
                                <span class="field-value">@item.InventoryNumber</span>
                                @if (isPendingUpdate && item.InventoryNumber != original!.InventoryNumber)
                                {
                                    <span class="field-original">Původně: @original!.InventoryNumber</span>
                                }
                            </li>
                            <li class="@GetFieldClass(isPendingUpdate && item.RegistrationNumber != original!.RegistrationNumber)">
                                <span class="field-label">Registrační číslo</span>
                                <span class="field-value">@item.RegistrationNumber</span>
                                @if (isPendingUpdate && item.RegistrationNumber != original!.RegistrationNumber)
                                {
                                    <span class="field-original">Původně: @original!.RegistrationNumber</span>
                                }
                            </li>
                            <li class="@GetFieldClass(isPendingUpdate && item.SerialNumber != original!.SerialNumber)">
                                <span class="field-label">Sériové číslo</span>
                                <span class="field-value">@(item.SerialNumber ?? "-----")</span>
                                @if (isPendingUpdate && item.SerialNumber != original!.SerialNumber)
                                {
                                    <span class="field-original">Původně: @(original!.SerialNumber ?? "-----")</span>
                                }
                            </li>
                            <li class="@GetFieldClass(isPendingUpdate && item.DateOfPurchase != original!.DateOfPurchase)">
                                <span class="field-label">Datum nákupu</span>
                                <span class="field-value">@item.DateOfPurchase.ToUserTimeString()</span>
                                @if (isPendingUpdate && item.DateOfPurchase != original!.DateOfPurchase)
                                {
                                    <span class="field-original">Původně: @original!.DateOfPurchase.ToUserTimeString()</span>
                                }
                            </li>
                            @if (item.DateOfSale is not null || original!.DateOfSale is not null)
                            {
                                <li class="@GetFieldClass(isPendingUpdate && item.DateOfSale != original!.DateOfSale)">
                                    <span class="field-label">Datum prodeje</span>
                                    <span class="field-value">@(item.DateOfSale?.ToUserTimeString() ?? "-----")</span>
                                    @if (isPendingUpdate && item.DateOfSale != original!.DateOfSale)
                                    {
                                        <span class="field-original">Původně: @(original!.DateOfSale?.ToUserTimeString() ?? "-----")</span>
                                    }
                                </li>
                            }
                            <li class="@GetFieldClass(isPendingUpdate && item.Location.Building != original!.Location.Building)">
                                <span class="field-label">Budova</span>
                                <span class="field-value">@item.Location.Building</span>
                                @if (isPendingUpdate && item.Location.Building != original!.Location.Building)
                                {
                                    <span class="field-original">Původně: @original!.Location.Building</span>
                                }
                            </li>
                            <li class="@GetFieldClass(isPendingUpdate && item.Location.Room != original!.Location.Room)">
                                <span class="field-label">Místnost</span>
                                <span class="field-value">@item.Location.Room</span>
                                @if (isPendingUpdate && item.Location.Room != original!.Location.Room)
                                {
                                    <span class="field-original">Původně: @original!.Location.Room</span>
                                }
                            </li>
                            @if (!string.IsNullOrWhiteSpace(item.Location.AdditionalNote) || !string.IsNullOrWhiteSpace(original!.Location.AdditionalNote))
                            {
                                <li class="@GetFieldClass(isPendingUpdate && item.Location.AdditionalNote != original!.Location.AdditionalNote)">
                                    <span class="field-label">Poznámka k umístění</span>
                                    <span class="field-value">@(item.Location.AdditionalNote ?? "-----")</span>
                                    @if (isPendingUpdate && item.Location.AdditionalNote != original!.Location.AdditionalNote)
                                    {
                                        <span class="field-original">Původně: @(original!.Location.AdditionalNote ?? "-----")</span>
                                    }
                                </li>
                            }
                            <li class="@GetFieldClass(isPendingUpdate && item.Employee.EmailAddress != original!.Employee.EmailAddress)">
                                <span class="field-label">Spravuje</span>
                                <span class="field-value">@(string.IsNullOrEmpty(item.Employee.EmailAddress) ? "-----" : item.Employee.EmailAddress)</span>
                                @if (isPendingUpdate && item.Employee.EmailAddress != original!.Employee.EmailAddress)
                                {
                                    <span class="field-original">Původně: @(string.IsNullOrEmpty(original!.Employee.EmailAddress) ? "-----" : original!.Employee.EmailAddress)</span>
                                }
                            </li>
                            <li class="@GetFieldClass(isPendingUpdate && item.Description != original!.Description)">
                                <span class="field-label">Popis</span>
                                <span class="field-value">@(!string.IsNullOrWhiteSpace(item.Description) ? item.Description : "------")</span>
                                @if (isPendingUpdate && item.Description != original!.Description)
                                {
                                    <span class="field-original">Původně: @(original!.Description ?? "------")</span>
                                }
                            </li>
                            <li class="@GetFieldClass(isPendingUpdate && item.DocumentNumber != original!.DocumentNumber)">
                                <span class="field-label">Číslo dokladu</span>
                                <span class="field-value">@(!string.IsNullOrWhiteSpace(item.DocumentNumber) ? item.DocumentNumber : "-----")</span>
                                @if (isPendingUpdate && item.DocumentNumber != original!.DocumentNumber)
                                {
                                    <span class="field-original">Původně: @(original!.DocumentNumber ?? "-----")</span>
                                }
                            </li>
                            <li class="item-field">
                                <span class="field-label">Přidáno</span>
                                <span class="field-value">@item.CreatedAt.ToUserTimeString()</span>
                            </li>
                            <li class="item-field">
                                <span class="field-label">Upraveno</span>
                                <span class="field-value">@(item.LastUpdatedAt.ToUserTimeString() ?? "-----")</span>
                            </li>
                            <li class="item-field">
                                <span class="field-label">Datum generace kódu</span>
                                <span class="field-value">@(item.LastCodeGeneratedAt.ToUserTimeString() ?? "-----")</span>
                            </li>
                        </ul>
                    }

                    <div class="item-card-actions">
                        @if (isEditing)
                        {
                            <button class="btn-secondary" type="button" @onclick="async () => await UpdateItem(item)" @onclick:stopPropagation="true">Uložit úpravy</button>
                        }
                        <button class="btn-secondary" type="button" @onclick="() => EditItem(item)" @onclick:stopPropagation="true" disabled="@(DeletedItemIds.Contains(item.Id))">
                            @(isEditing ? "Zrušit úpravy" : "Upravit")
                        </button>
                        @if (!isEditing && UpdatedItemDtos.ContainsKey(item.Id))
                        {
                            <button class="btn-secondary" type="button" @onclick="async () => { UpdatedItemDtos.Remove(item.Id); await SavePersistentState(); }" @onclick:stopPropagation="true">Vrátit změny</button>
                        }
                        <button class="btn-destructive" type="button" @onclick="() => DeleteItem(item)" @onclick:stopPropagation="true" disabled="@isEditing">
                            @(DeletedItemIds.Contains(item.Id) ? "Zrušit smazání" : "Smazat")
                        </button>
                    </div>
                </article>
            }
        </div>

        <div class="items-pagination">
            <button class="btn-secondary" type="button" @onclick="() => LoadItems(CurrentOffset - Limit)" disabled="@(!CanGoPrev)">◀</button>
            <span>@(CurrentOffset / Limit + 1) / @((int)Math.Ceiling((double)TotalItemsCount / Limit))</span>
            <button class="btn-secondary" type="button" @onclick="() => LoadItems(CurrentOffset + Limit)" disabled="@(!CanGoNext)">▶</button>
        </div>
    }
    else
    {
        <div class="items-empty-state">
            <p>Žádné položky neodpovídají aktuálním kritériím.</p>
        </div>
    }
</div>

@if (ShowCreateSuggestionModal)
{
    <div class="modal-overlay">
        <div class="modal-panel">
            <div class="modal-header">
                <h4>Vytvořit návrh</h4>
                <button class="btn-secondary" type="button" @onclick="() => ShowCreateSuggestionModal = false">Zavřít</button>
            </div>

            <div class="modal-body">
                <CreatePropertySuggestionForm OnClose="() => ShowCreateSuggestionModal = false" OnSuccessfulCreation="() => OnSuggestionCreation()" ItemsToDelete="DeletedItems.ToList()" ItemsToUpdate="UpdatedItems.ToList()" />
            </div>
        </div>
    </div>
}


@code
{
    [Inject] private HttpClient Client { get; set; } = default!;
    [Inject] private ILocalStorageService Storage { get; set; } = default!;
    [Parameter] public EventCallback<bool> OnClose { get; set; }
    [Parameter] public EventCallback<bool> OnChange { get; set; }

    private const string DeletedItemsKey = "EmployeeInventoryDeletedItems";
    private const string UpdatedItemsKey = "EmployeeInventoryUpdatedItems";

    private int Limit { get; set; } = 28;
    private int CurrentOffset { get; set; }
    private int TotalItemsCount { get; set; }

    private string? SearchTerm { get; set; }

    private List<PropertyItemDto> Items { get; set; } = [];

    private string SelectedOrderOption { get; set; } = "createdat_asc";
    private readonly List<(string Value, string Label)> OrderOptions = new()
    {
        ("name_asc", "Název (A-Z)"),
        ("name_desc", "Název (Z-A)"),
        ("price_asc", "Cena (nejnižší první)"),
        ("price_desc", "Cena (nejvyšší první)"),
        ("dateofpurchase_asc", "Datum nákupu (nejstarší první)"),
        ("dateofpurchase_desc", "Datum nákupu (nejnovější první)"),
        ("createdat_asc", "Datum přidání (nejstarší první)"),
        ("createdat_desc", "Datum přidání (nejnovější první)")
    };

    private HashSet<Guid> DeletedItemIds { get; set; } = [];
    private Dictionary<Guid, PropertyItemDto> UpdatedItemDtos { get; set; } = new();

    private HashSet<PropertyItemDto> SelectedItems { get; set; } = [];
    private Dictionary<Guid, (PropertyItemDto Updated, PropertyItemDto Original)> EditedItems { get; set; } = new();

    private IEnumerable<PropertyItemDto> DeletedItems => Items.Where(i => DeletedItemIds.Contains(i.Id));
    private IEnumerable<PropertyItemDto> UpdatedItems => UpdatedItemDtos.Values;
    private bool HasPendingChanges => DeletedItemIds.Any() || UpdatedItemDtos.Any();


    protected override async Task OnInitializedAsync()
    {
        await LoadPersistentState();
        await LoadItems(0);
    }

    private async Task ToggleFilters()
    {
        ShowFilteringOptions = !ShowFilteringOptions;

        if (!ShowFilteringOptions)
        {
            await ClearFilters();
        }
    }

    private async Task LoadPersistentState()
    {
        DeletedItemIds = await Storage.GetItemAsync<HashSet<Guid>>(DeletedItemsKey) ?? new HashSet<Guid>();

        var updatedItemsStringKeys = await Storage.GetItemAsync<Dictionary<string, PropertyItemDto>>(UpdatedItemsKey);

        UpdatedItemDtos = updatedItemsStringKeys?.ToDictionary(
            kvp => Guid.Parse(kvp.Key),
            kvp => kvp.Value
        ) ?? new Dictionary<Guid, PropertyItemDto>();
    }

    private async Task SavePersistentState()
    {
        await Storage.SetItemAsync(DeletedItemsKey, DeletedItemIds);

        var updatedItemsStringKeys = UpdatedItemDtos.ToDictionary(
            kvp => kvp.Key.ToString(),
            kvp => kvp.Value
        );
        await Storage.SetItemAsync(UpdatedItemsKey, updatedItemsStringKeys);
    }

    private async Task LoadItems(int offset)
    {
        CurrentOffset = Math.Max(0, offset);

        var (sort, descending) = SelectedOrderOption.Split("_") switch { var parts => (parts[0], parts[1] == "desc") };

        var parameters = new List<string>
        {
            $"limit={Limit}",
            $"offset={CurrentOffset}",
            $"order={sort}",
            $"desc={descending}"
        };

        if (!string.IsNullOrEmpty(SearchTerm))
            parameters.Add($"searchQuery={SearchTerm}");

        if (ShowFilteringOptions)
        {
            if (PriceMin is not null)
                parameters.Add($"minPrice={PriceMin}");
            if (PriceMax is not null)
                parameters.Add($"maxPrice={PriceMax}");
            if (CreatedAtFrom is not null)
                parameters.Add($"createdAtFrom={new DateTimeOffset(CreatedAtFrom.Value, TimeSpan.Zero).UtcDateTime:O}");
            if (CreatedAtTo is not null)
                parameters.Add($"createdAtTo={new DateTimeOffset(CreatedAtTo.Value, TimeSpan.Zero).UtcDateTime:O}");
            if (DateOfPurchaseFrom is not null)
                parameters.Add($"dateOfPurchaseFrom={new DateTimeOffset(DateOfPurchaseFrom.Value, TimeSpan.Zero).UtcDateTime:O}");
            if (DateOfPurchaseTo is not null)
                parameters.Add($"dateOfPurchaseTo={new DateTimeOffset(DateOfPurchaseTo.Value, TimeSpan.Zero).UtcDateTime:O}");
            if (!string.IsNullOrEmpty(Room))
                parameters.Add($"room={Room}");
            if (!string.IsNullOrEmpty(Building))
                parameters.Add($"building={Building}");
            if (!string.IsNullOrEmpty(WithGeneratedCode))
                parameters.Add($"withGeneratedCode={WithGeneratedCode}");
        }

        var response = await Client.GetAsync($"/api/properties/items?{string.Join("&", parameters)}");

        if (response.StatusCode != HttpStatusCode.OK) throw new Exception("Something went wrong during the request to get the items.");

        var content = await response.Content.ReadFromJsonAsync<IndexByAdminPropertyItemResponse>() ?? throw new NullReferenceException();

        Items = content.Data;
        Limit = content.Limit;
        TotalItemsCount = content.TotalCount;

        StateHasChanged();
    }

    private bool CanGoPrev => CurrentOffset > 0;
    private bool CanGoNext => CurrentOffset + Limit < TotalItemsCount;

    private bool ShowFilteringOptions { get; set; }

    private decimal? PriceMin { get; set; }
    private decimal? PriceMax { get; set; }

    private DateTime? CreatedAtFrom { get; set; }
    private DateTime? CreatedAtTo { get; set; }

    private DateTime? DateOfPurchaseFrom { get; set; }
    private DateTime? DateOfPurchaseTo { get; set; }

    private string? Room { get; set; }
    private string? Building { get; set; }

    private string? WithGeneratedCode { get; set; }

    private async Task ClearFilters()
    {
        PriceMin = null;
        PriceMax = null;
        CreatedAtFrom = null;
        CreatedAtTo = null;
        DateOfPurchaseFrom = null;
        DateOfPurchaseTo = null;
        Room = null;
        Building = null;
        WithGeneratedCode = null;

        await LoadItems(0);
    }

    public void SelectItem(PropertyItemDto item)
    {
        if (DeletedItemIds.Contains(item.Id)) return;
        if (EditedItems.Keys.Contains(item.Id)) return;

        if (SelectedItems.RemoveWhere(i => i.Id == item.Id) == 0) SelectedItems.Add(item);
    }

    public void SelectItems(IEnumerable<PropertyItemDto> items)
    {
        foreach (var item in items)
        {
            if (DeletedItemIds.Contains(item.Id)) continue;

            SelectedItems.Add(item);
        }
    }

    public void ClearSelectedItems()
    {
        SelectedItems.Clear();
    }

    private async Task UpdateItem(PropertyItemDto item)
    {
        var updated = EditedItems[item.Id].Updated;
        var original = Items.FirstOrDefault(i => i.Id == updated.Id);

        EditedItems.Remove(item.Id);

        if (original is not null && updated.Equals(original))
        {
            UpdatedItemDtos.Remove(updated.Id);
        }
        else
        {
            UpdatedItemDtos[updated.Id] = updated;
        }

        await SavePersistentState();
    }

    private async Task ClearUpdatedItems()
    {
        UpdatedItemDtos.Clear();
        await SavePersistentState();
    }

    public void EditItem(PropertyItemDto item)
    {
        if (SelectedItems.Contains(item)) SelectedItems.Remove(item);

        if (EditedItems.ContainsKey(item.Id))
        {
            EditedItems.Remove(item.Id);
        }
        else
        {
            var itemToEdit = UpdatedItemDtos.GetValueOrDefault(item.Id, item);
            EditedItems[item.Id] = (Updated: PropertyItemDto.CloneThis(itemToEdit), Original: item);
        }
    }

    public async Task DeleteItem(PropertyItemDto item)
    {
        if (SelectedItems.Contains(item)) SelectedItems.Remove(item);

        UpdatedItemDtos.Remove(item.Id);

        if (!DeletedItemIds.Remove(item.Id))
        {
            DeletedItemIds.Add(item.Id);
        }

        await SavePersistentState();
    }

    public async Task DeleteSelectedItems()
    {
        foreach (var item in SelectedItems)
        {
            UpdatedItemDtos.Remove(item.Id);
            DeletedItemIds.Add(item.Id);
        }
        ClearSelectedItems();
        await SavePersistentState();
    }

    public async Task ClearDeletedItems()
    {
        DeletedItemIds.Clear();
        await SavePersistentState();
    }

    private bool ShowCreateSuggestionModal { get; set; }

    private string GetItemCardClass(PropertyItemDto item)
    {
        var classes = new List<string> { "item-card" };
        if (DeletedItemIds.Contains(item.Id)) classes.Add("item-card--deleted");
        else if (UpdatedItemDtos.ContainsKey(item.Id)) classes.Add("item-card--updated");
        if (SelectedItems.Any(i => i.Id == item.Id)) classes.Add("item-card--selected");
        if (EditedItems.ContainsKey(item.Id)) classes.Add("item-card--editing");
        return string.Join(" ", classes);
    }

    private static string GetFieldClass(bool changed)
        => changed ? "item-field item-field--changed" : "item-field";

    private async Task OnSuggestionCreation()
    {
        await ClearDeletedItems();
        await ClearUpdatedItems();

        await LoadItems(0);
        await OnChange.InvokeAsync(true);
    }
}
