@using System.Net
@using Invenire.Api.Properties
@using Invenire.Api.Properties.Items
@using Invenire.Api.Properties.Items.IndexByAdmin
@using Invenire.Components.Forms.Properties.Items

<div class="section-heading">
    <h4>Přehled vašich položek</h4>
</div>

@if (Property?.ItemsSummary is PropertyDtoItemsSummary summary)
{
    <div class="stat-grid">
        <div class="stat-card">
            <span class="stat-label">Celkový počet</span>
            <span class="stat-value">@((summary.TotalItems ?? 0).ToString("N0"))</span>
        </div>
        <div class="stat-card">
            <span class="stat-label">Celková hodnota</span>
            <span class="stat-value">@FormatCurrency(summary.TotalValue)</span>
        </div>
        <div class="stat-card">
            <span class="stat-label">Průměrná cena</span>
            <span class="stat-value">@FormatCurrency(summary.AveragePrice)</span>
        </div>
        <div class="stat-card">
            <span class="stat-label">Průměrné stáří</span>
            <span class="stat-value">@GetAverageAge(summary)</span>
        </div>
    </div>

    <div class="action-row">
        <button class="btn-secondary" type="button" @onclick="() => { OpenModal = true; }">Zobrazit položky</button>
    </div>
}
else
{
    <div class="empty-state">
        <p>Zatím nebyly přidány žádné položky.</p>
        <p class="muted-text">Jakmile admin přidá položky, uvidíte je právě zde.</p>
    </div>
}

@if (OpenModal)
{
    <div class="modal-overlay">
        <div class="modal-panel modal-panel--wide">
            <EmployeePropertyItemOverview OnClose="() => { OpenModal = false; }" OnChange="async () => { await OnChange.InvokeAsync(true); }" />
        </div>
    </div>
}

@code
{
    [Parameter] public PropertyDto? Property { get; set; }
    [Parameter] public EventCallback<bool> OnChange { get; set; }

    private bool OpenModal { get; set; }

    private static string GetAverageAge(PropertyDtoItemsSummary summary)
    {
        return summary.AverageAge is null ? "—" : $"{summary.AverageAge.Value:0.##} let";
    }

    private static string FormatCurrency(double? value)
    {
        return value is null ? "—" : $"{value.Value:0.##} Kč";
    }
}
