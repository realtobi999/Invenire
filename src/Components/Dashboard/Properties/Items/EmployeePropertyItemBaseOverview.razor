@using System.Net
@using Invenire.Api.Properties
@using Invenire.Api.Properties.Items
@using Invenire.Api.Properties.Items.IndexByAdmin
@using Invenire.Components.Forms.Properties.Items

<h4>Přehled položek</h4>

@if (Property is not null && Property.ItemsSummary is not null)
{
    <ul>
        <li><strong>Celkový počet:</strong> @Property.ItemsSummary.TotalItems</li>
    </ul>

    <button @onclick="() => ShowAllItemsModal = true">Zobrazit položky</button>

    @if (ShowAllItemsModal)
    {
        <div style="
                    position: fixed;
                    top: 0;
                    left: 0;
                    width: 100%;
                    height: 100%;
                    background-color: rgba(0,0,0,0.5);
                    z-index: 9999;
                    display: flex;
                    justify-content: center;
                    align-items: center;
                    overflow: auto; /* allow modal to scroll if too tall */
                    padding: 1rem;  /* optional: spacing around modal */
                ">
            <div style="
                        background: white;
                        border-radius: 6px;
                        max-height: 90vh;  /* don't exceed viewport height */
                        overflow-y: auto;  /* scroll inside modal */
                        padding: 1rem;
                        min-width: 300px;
                        max-width: 90%;
                    ">
                <EmployeePropertyItemOverview OnClose="() => ShowAllItemsModal = false"/>
            </div>
        </div>
    }
}
else
{
    <p>Zatím nebyli přidané žádné položky</p>
}

@code {
    [Parameter] public PropertyDto? Property { get; set; }

    private bool ShowAllItemsModal { get; set; }
}