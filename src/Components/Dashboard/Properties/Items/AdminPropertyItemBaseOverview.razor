@using System.Net
@using Invenire.Api.Properties
@using Invenire.Api.Properties.Items
@using Invenire.Api.Properties.Items.IndexByAdmin
@using Invenire.Components.Forms.Properties.Items

<div class="section-heading">
    <h4>Přehled položek</h4>
</div>

@if (Property?.ItemsSummary is PropertyDtoItemsSummary summary)
{
    <div class="stat-grid">
        <div class="stat-card">
            <span class="stat-label">Celkový počet</span>
            <span class="stat-value">@((summary.TotalItems ?? 0).ToString("N0"))</span>
        </div>
        <div class="stat-card">
            <span class="stat-label">Celková hodnota</span>
            <span class="stat-value">@FormatCurrency(summary.TotalValue)</span>
        </div>
        <div class="stat-card">
            <span class="stat-label">Průměrná cena</span>
            <span class="stat-value">@FormatCurrency(summary.AveragePrice)</span>
        </div>
        <div class="stat-card">
            <span class="stat-label">Průměrné stáří</span>
            <span class="stat-value">@GetAverageAge(summary)</span>
        </div>
    </div>

    <div class="action-row">
        <button class="btn-secondary" @onclick="OpenAllItemsModal">Spravovat položky</button>
        <button class="btn-secondary" @onclick="OpenImportItemsModal">Importovat</button>
        <button class="btn-secondary" @onclick="OpenExportItemsModal">Exportovat</button>
        <button class="btn-destructive" @onclick="OpenDeletionItemsModal" disabled="@(summary.TotalItems == 0)">Smazat všechny položky</button>
    </div>
}
else
{
    <div class="empty-state">
        <p>Zatím nebyly přidány žádné položky.</p>
        <div class="action-row">
            <button class="btn-secondary" @onclick="OpenImportItemsModal">Importovat položky</button>
        </div>
    </div>
}

@if (ShowAllItemsModal)
{
    <div class="modal-overlay">
        <div class="modal-panel modal-panel--wide">
            <AdminPropertyItemOverview OnClose="CloseAllItemsModal" OnChange="HandleItemsChanged" />
        </div>
    </div>
}

@if (ShowImportItemsModal)
{
    <div class="modal-overlay">
        <div class="modal-panel">
            <div class="modal-header">
                <h4>Import položek</h4>
                <button class="btn-secondary" type="button" @onclick="CloseImportItemsModal">Zavřít</button>
            </div>

            <div class="modal-body">
                <ImportPropertyItemsForm OnSuccessfulCreation="HandleImportSuccess" OnClose="CloseImportItemsModal" />
            </div>
        </div>
    </div>
}

@if (ShowExportItemsModal)
{
    <div class="modal-overlay">
        <div class="modal-panel">
            <div class="modal-header">
                <h4>Export položek</h4>
                <button class="btn-secondary" type="button" @onclick="CloseExportItemsModal">Zavřít</button>
            </div>

            <div class="modal-body">
                <ExportPropertyItemsForm OnClose="CloseExportItemsModal" OnSuccessfulExport="HandleExportSuccess" />
            </div>
        </div>
    </div>
}

@if (ShowDeletionItemsModal)
{
    <div class="modal-overlay">
        <div class="modal-panel">
            <div class="modal-header">
                <h4>Smazat všechny položky</h4>
                <button class="btn-secondary" type="button" @onclick="CloseDeletionItemsModal">Zavřít</button>
            </div>

            <div class="modal-body">
                <DeleteAllPropertyItemsForm OnSuccessfulDeletion="HandleDeletionSuccess" OnClose="CloseDeletionItemsModal" />
            </div>
        </div>
    </div>
}


@code
{
    [Parameter] public PropertyDto? Property { get; set; }
    [Parameter] public EventCallback<bool> OnChange { get; set; }

    private bool ShowAllItemsModal { get; set; }
    private bool ShowImportItemsModal { get; set; }
    private bool ShowExportItemsModal { get; set; }
    private bool ShowDeletionItemsModal { get; set; }

    private static string GetAverageAge(PropertyDtoItemsSummary summary)
        => summary.AverageAge is null ? "—" : $"{summary.AverageAge.Value:0.##} let";

    private static string FormatCurrency(double? value)
        => value is null ? "—" : $"{value.Value:0.##} Kč";

    private void OpenAllItemsModal() => ShowAllItemsModal = true;
    private void CloseAllItemsModal() => ShowAllItemsModal = false;
    private void OpenImportItemsModal() => ShowImportItemsModal = true;
    private void CloseImportItemsModal() => ShowImportItemsModal = false;
    private void OpenExportItemsModal() => ShowExportItemsModal = true;
    private void CloseExportItemsModal() => ShowExportItemsModal = false;
    private void OpenDeletionItemsModal() => ShowDeletionItemsModal = true;
    private void CloseDeletionItemsModal() => ShowDeletionItemsModal = false;

    private async Task HandleItemsChanged() => await OnChange.InvokeAsync(true);

    private async Task HandleImportSuccess()
    {
        ShowImportItemsModal = false;
        await OnChange.InvokeAsync(true);
    }

    private async Task HandleExportSuccess()
    {
        ShowExportItemsModal = false;
        await OnChange.InvokeAsync(true);
    }

    private async Task HandleDeletionSuccess()
    {
        ShowDeletionItemsModal = false;
        await OnChange.InvokeAsync(true);
    }
}
