@using Invenire.Api.Properties
@using System.Globalization
@using Invenire.Components.Forms.Properties.Items

<div class="section-heading">
    <h4>Přehled položek</h4>
</div>

@if (Property?.ItemsSummary is PropertyDtoItemsSummary summary)
{
    <div class="stat-grid">
        <div class="stat-card">
            <span class="stat-label">Celkový počet</span>
            <span class="stat-value">@((summary.TotalItems ?? 0).ToString("N0"))</span>
        </div>
        <div class="stat-card">
            <span class="stat-label">Celková hodnota</span>
            <span class="stat-value">@FormatCurrency(summary.TotalValue)</span>
        </div>
        <div class="stat-card">
            <span class="stat-label">Průměrná cena</span>
            <span class="stat-value">@FormatCurrency(summary.AveragePrice)</span>
        </div>
        <div class="stat-card">
            <span class="stat-label">Průměrné stáří</span>
            <span class="stat-value">@GetAverageAge(summary)</span>
        </div>
    </div>

    <div class="action-row">
        <button class="btn-secondary" @onclick="() => ItemsOpen = true">Spravovat</button>
        <button class="btn-secondary" @onclick="() => ImportOpen = true">Importovat</button>
        <button class="btn-secondary" @onclick="() => ExportOpen = true">Exportovat</button>
        <button class="btn-destructive" @onclick="() => DeleteOpen = true" disabled="@(summary.TotalItems == 0)">Smazat</button>
    </div>
}
else
{
    <div class="empty-state">
        <p>Zatím nebyly přidány žádné položky.</p>
        <div class="action-row">
            <button class="btn-secondary" @onclick="() => ImportOpen = true">Importovat</button>
        </div>
    </div>
}

@if (ItemsOpen)
{
    <div class="modal-overlay">
        <div class="modal-panel modal-panel--wide">
            <AdminPropertyItemOverview OnClose="() => ItemsOpen = false" OnChange="() => OnChange.InvokeAsync(true)" />
        </div>
    </div>
}

@if (ImportOpen)
{
    <div class="modal-overlay">
        <div class="modal-panel">
            <div class="modal-header">
                <h4>Import položek</h4>
                <button class="btn-secondary" type="button" @onclick="() => ImportOpen = false">Zavřít</button>
            </div>

            <div class="modal-body">
                <ImportPropertyItemsForm OnSuccessfulCreation="async () => { ImportOpen = false; await OnChange.InvokeAsync(true); }" />
            </div>
        </div>
    </div>
}

@if (ExportOpen)
{
    <div class="modal-overlay">
        <div class="modal-panel">
            <div class="modal-header">
                <h4>Export položek</h4>
                <button class="btn-secondary" type="button" @onclick="() => ExportOpen = false">Zavřít</button>
            </div>

            <div class="modal-body">
                <ExportPropertyItemsForm OnClose="() => ExportOpen = false" OnSuccessfulExport="async () => { ExportOpen = false; await OnChange.InvokeAsync(true); }" />
            </div>
        </div>
    </div>
}

@if (DeleteOpen)
{
    <div class="modal-overlay">
        <div class="modal-panel">
            <div class="modal-header">
                <h4>Smazat všechny položky</h4>
                <button class="btn-secondary" type="button" @onclick="() => DeleteOpen = false">Zavřít</button>
            </div>

            <div class="modal-body">
                <DeleteAllPropertyItemsForm OnSuccessfulDeletion="async () => { DeleteOpen = false; await OnChange.InvokeAsync(true); }" OnClose="() => DeleteOpen = false" />
            </div>
        </div>
    </div>
}

@code
{
    [Parameter] public PropertyDto? Property { get; set; }
    [Parameter] public EventCallback<bool> OnChange { get; set; }

    private bool ItemsOpen { get; set; }
    private bool ImportOpen { get; set; }
    private bool ExportOpen { get; set; }
    private bool DeleteOpen { get; set; }

    private static string GetAverageAge(PropertyDtoItemsSummary summary)
        => summary.AverageAge is null ? "—" : $"{summary.AverageAge.Value:0.##} let";

    private static string FormatCurrency(double? value)
        => value is null ? "—" : string.Format(CultureInfo.GetCultureInfo("cs-CZ"), "{0:N0} Kč", value);
}
