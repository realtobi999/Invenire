@using System.Net
@using Invenire.Common.Errors
@using Invenire.Api.Properties
@using Invenire.Components.Dashboard.Properties.Scans
@using Invenire.Components.Forms.Properties
@using Invenire.Components.Dashboard.Properties.Items
@using Invenire.Components.Dashboard.Properties.Suggestions

@if (Property is not null)
{
    <div class="stack">
        <section class="section-card">
            <div class="section-heading">
                <h3>Základní informace</h3>
            </div>
            <AdminPropertyBaseOverview Property="Property" />
        </section>

        <section class="section-card">
            <div class="section-heading">
                <h3>Položky</h3>
            </div>
            <AdminPropertyItemBaseOverview Property="Property" OnChange="() => ReloadProperty()" />
        </section>

        <section class="section-card">
            <div class="section-heading">
                <h3>Návrhy</h3>
            </div>
            <AdminPropertySuggestionBaseOverview Property="Property" OnChange="() => ReloadProperty()" />
        </section>

        <section class="section-card">
            <div class="section-heading">
                <h3>Inventury</h3>
            </div>
            <AdminPropertyScanBaseOverview Property="Property" OnChange="() => ReloadProperty()" />
        </section>
    </div>
}
else
{
    <section class="section-card">
        <div class="empty-state">
            <div>
                <h3>Zatím nemáte vytvořený majetek</h3>
                <p>Vytvořte svůj první záznam majetku, abyste mohli sledovat položky, návrhy i inventury.</p>
            </div>
            <CreatePropertyForm OnSuccessfulCreation="ReloadProperty" />
        </div>
    </section>
}

@code
{
    [Inject] private HttpClient Client { get; set; } = default!;


    private PropertyDto? Property { get; set; }

    protected override async Task OnInitializedAsync()
    {
        await SetProperty();
    }

    private async Task SetProperty()
    {
        var response = await Client.GetAsync("/api/properties");

        if (response.StatusCode != HttpStatusCode.OK)
        {
            var error = await response.Content.ReadFromJsonAsync<ErrorResponse>() ?? throw new NullReferenceException();

            if (error.Detail == "The organization doesn't have a property.")
            {
                return;
            }
            else
            {
                throw new Exception("Something went wrong during the request to get the property.");
            }
        }

        Property = await response.Content.ReadFromJsonAsync<PropertyDto>();
    }

    private async Task ReloadProperty()
    {
        await SetProperty();
        StateHasChanged();
    }
}
