@using Invenire.Api.Organizations
@using Invenire.Api.Organizations.Invitations
@using Invenire.Components.Forms.Organizations.Invitations

<button @onclick="() => ShowCreationFormModal = true ">Vytvořit</button>

@if (Organization?.Invitations is not null && Organization.Invitations.Any())
{
    <ul>
        @foreach (var invitation in PagedInvitations)
        {
            <li>
                <div>
                    <strong>ID:</strong> @invitation.Id <br />
                    <strong>Popis:</strong> @invitation.Description <br />
                    <strong>Vytvořeno:</strong> @invitation.CreatedAt.ToString("g") <br />
                    @if (invitation.LastUpdatedAt is not null)
                    {
                        <strong>Naposledy upraveno: </strong> @invitation.LastUpdatedAt?.ToString("g") <br />
                    }
                    @if (invitation.Employee is not null)
                    {
                        <strong>Pro: </strong>@($"{invitation.Employee.FullName} ({invitation.Employee.EmailAddress})")
                    }
                </div>
            </li>

            <button @onclick="() => ShowUpdateFormModal = true ">Upravit</button>
            <button @onclick="() => ShowDeletionFormModal = true ">Smazat</button>
        }
    </ul>

    <div class="pagination">
        <button @onclick="() => SetCurrentOffset(CurrentOffset - Limit)" disabled="@( !CanGoPrev )">
            Předchozí
        </button>
        <span>
            Pozvánka @(CurrentOffset / Limit + 1) / @((int)Math.Ceiling((double)TotalInvitationCount / Limit))
        </span>
        <button @onclick="() => SetCurrentOffset(CurrentOffset + Limit)" disabled="@( !CanGoNext )">
            Další
        </button>
    </div>
}
else
{
    <p>Žádné pozvánky nebyly nalezeny.</p>
}

@if (ShowCreationFormModal)
{
    <div>
        <div>
            <h4 style="display: inline-block; margin: 0;">Vytvořit novou pozvánku</h4>
            <button style="display: inline-block;" @onclick="() => ShowCreationFormModal = false">X</button>
        </div>
        <CreateOrganizationInvitationForm OnSuccessfulCreation="() => OnChange.InvokeAsync(true)" OnClose="() => ShowCreationFormModal = false"/>
    </div>
}

@if (ShowUpdateFormModal)
{
    <div>
        <div>
            <h4 style="display: inline-block; margin: 0;">Upravit pozvánku</h4>
            <button style="display: inline-block;" @onclick="() => ShowCreationFormModal = false">X</button>
        </div>
        <UpdateOrganizationInvitationForm Invitation="PagedInvitations.ToList()[CurrentOffset]" OnSuccessfulUpdate="() => OnChange.InvokeAsync(true)" OnClose="() => ShowUpdateFormModal = false"/>
    </div>
}

@if (ShowDeletionFormModal)
{
    <div>
        <DeleteOrganizationInvitationForm Invitation="PagedInvitations.ToList()[CurrentOffset]" OnSuccessfulDeletion="() => OnChange.InvokeAsync(true)" OnClose="() => ShowDeletionFormModal = false" />
    </div>
}


@code {
    [Inject] private HttpClient Client { get; set; } = default!;
    [Parameter] public OrganizationDto? Organization { get; set; }
    [Parameter] public EventCallback<bool> OnChange { get; set; }

    private bool ShowUpdateFormModal { get; set; }
    private bool ShowCreationFormModal { get; set; }
    private bool ShowDeletionFormModal { get; set; }

    private int Limit { get; set; } = 1;
    private int CurrentOffset { get; set; } = 0;
    private int TotalInvitationCount => Organization?.Invitations?.Count ?? 0;

    private IEnumerable<OrganizationInvitationDto> PagedInvitations => Organization?.Invitations?.Skip(CurrentOffset).Take(Limit) ?? Enumerable.Empty<OrganizationInvitationDto>();

    private bool CanGoPrev => CurrentOffset > 0;
    private bool CanGoNext => CurrentOffset + Limit < TotalInvitationCount;

    private void SetCurrentOffset(int newOffset)
    {
        if (newOffset < 0 || newOffset >= TotalInvitationCount)
            return;

        CurrentOffset = newOffset;
    }
}
