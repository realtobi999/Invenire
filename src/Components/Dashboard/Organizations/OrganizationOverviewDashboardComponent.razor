@using System.Net
@using Invenire.Api.Organizations
@using Invenire.Components.Forms.Organizations

@if (Organization is not null)
{
    <h3>Základní informace</h3>
    <ul>
        <li><strong>Id:</strong> @Organization.Id</li>
        <li><strong>Název:</strong> @Organization.Name</li>
        <li><strong>Vytvořeno:</strong> @Organization.CreatedAt.ToString("g")</li>
        @if (Organization.LastUpdatedAt is not null)
        {
            <li><strong>Naposledy upraveno:</strong> @Organization.LastUpdatedAt?.ToString("g")</li>
        }
    </ul>

    <button @onclick="() => ShowModal = true">Upravit informace</button>
}

@if (Organization is not null && ShowModal)
{
    <div>
        <div>
            <h4 style="display: inline-block; margin: 0;">Upravit informace organizace</h4>
            <button style="display: inline-block;" @onclick="() => ShowModal = false">X</button>
        </div>
        <UpdateOrganizationForm Organization="Organization" OnClose="() => ShowModal = false" OnSuccessfulUpdate="OnSuccessfulOrganizationUpdate"></UpdateOrganizationForm>
    </div>
}

@code {
    [Inject] private HttpClient Client { get; set; } = default!;

    private bool ShowModal { get; set; } = false;
    private OrganizationDto? Organization { get; set; }

    protected override async Task OnInitializedAsync()
    {
        await SetOrganization();
    }

    private async Task OnSuccessfulOrganizationUpdate()
    {
        ShowModal = false;
        await ReloadOrganization();
    }

    private async Task SetOrganization()
    {
        var response = await Client.GetAsync("/api/organizations");

        if (response.StatusCode != HttpStatusCode.OK) throw new Exception("Something went wrong during the request to get the organization."); 

        Organization = await response.Content.ReadFromJsonAsync<OrganizationDto>();
    }

    private async Task ReloadOrganization()
    {
        await SetOrganization();
        StateHasChanged();
    }
}