@using Blazored.LocalStorage
@using Invenire.Api.Users.Employees

@if (Employees.Any())
{
    var filtered = Filtered.ToList();

    <div class="employee-dropdown">
        <div class="filter-panel employee-dropdown-filter">
            <div class="filter-grid">
                <div class="form-control">
                    <label for="dropdown-order">Řazení</label>
                    <select id="dropdown-order" @bind="Order">
                        @foreach (var option in Orders)
                        {
                            <option value="@option.Value">@option.Label</option>
                        }
                    </select>
                </div>
                <div class="form-control grow">
                    <label for="dropdown-search">Hledat</label>
                    <input id="dropdown-search" type="text" placeholder="Hledat zaměstnance..." @bind="Search" />
                </div>
            </div>
            <p class="muted-text">Vyberte zaměstnance a modal se automaticky zavře.</p>
        </div>

        @if (filtered.Any())
        {
            <div class="employee-dropdown-list">
                @foreach (var employee in filtered)
                {
                    <button type="button" class="employee-option" @onclick="() => ChooseEmployee(employee)">
                        <span class="employee-avatar">@Initials(employee)</span>
                        <div class="employee-option-body">
                            <span class="employee-name">@employee.FullName</span>
                            <span class="employee-email">@employee.EmailAddress</span>
                        </div>
                        <span class="employee-option-cta">Vybrat</span>
                    </button>
                }
            </div>
        }
        else
        {
            <div class="employee-dropdown-empty empty-state">
                <p>Žádný zaměstnanec nebyl nalezen.</p>
                <p class="muted-text">Zkuste upravit vyhledávání nebo řazení.</p>
            </div>
        }
    </div>
}
else
{
    <div class="empty-state">
        <p>Vaše organizace zatím nemá zaměstnance.</p>
    </div>
}

@code
{
    [Inject] private ILocalStorageService Storage { get; set; } = default!;
    [Parameter] public EventCallback<bool> OnClose { get; set; }
    [Parameter] public EventCallback<EmployeeDto> OnEmployeeSelected { get; set; }

    private List<EmployeeDto> Employees { get; set; } = new();
    private string Search { get; set; } = "";
    private string Order { get; set; } = "name_asc";

    private readonly List<(string Value, string Label)> Orders = new()
    {
        ("name_asc", "Jméno (A-Z)"),
        ("name_desc", "Jméno (Z-A)"),
        ("email_asc", "Email (A-Z)"),
        ("email_desc", "Email (Z-A)")
    };

    private IEnumerable<EmployeeDto> Filtered
    {
        get
        {
            var filtered = Employees.Where(e =>
                string.IsNullOrWhiteSpace(Search) ||
                e.FullName.Contains(Search, StringComparison.OrdinalIgnoreCase) ||
                (e.FirstName?.Contains(Search, StringComparison.OrdinalIgnoreCase) ?? false) ||
                (e.LastName?.Contains(Search, StringComparison.OrdinalIgnoreCase) ?? false) ||
                (e.EmailAddress?.Contains(Search, StringComparison.OrdinalIgnoreCase) ?? false)
            );

            var (field, asc) = Order.Split('_') switch { var p => (p[0], p[1] == "asc") };

            return field switch
            {
                "name" => asc ? filtered.OrderBy(e => e.FullName) : filtered.OrderByDescending(e => e.FullName),
                "email" => asc ? filtered.OrderBy(e => e.EmailAddress) : filtered.OrderByDescending(e => e.EmailAddress),
                _ => filtered
            };
        }
    }

    protected override Task OnInitializedAsync() => LoadEmployees();

    private async Task LoadEmployees() => Employees = await Storage.GetItemAsync<List<EmployeeDto>>("Employees") ?? new();

    private async Task ChooseEmployee(EmployeeDto employee)
    {
        await OnClose.InvokeAsync(true);
        await OnEmployeeSelected.InvokeAsync(employee);
    }

    private string Initials(EmployeeDto employee)
    {
        var initials = new List<char>();

        if (!string.IsNullOrWhiteSpace(employee.FirstName))
            initials.Add(char.ToUpperInvariant(employee.FirstName!.Trim()[0]));

        if (!string.IsNullOrWhiteSpace(employee.LastName))
            initials.Add(char.ToUpperInvariant(employee.LastName!.Trim()[0]));

        if (initials.Count == 0 && !string.IsNullOrWhiteSpace(employee.FullName))
        {
            var segments = employee.FullName.Split(' ', StringSplitOptions.RemoveEmptyEntries);

            foreach (var segment in segments.Take(2))
            {
                initials.Add(char.ToUpperInvariant(segment[0]));
            }
        }

        if (initials.Count == 0 && !string.IsNullOrWhiteSpace(employee.EmailAddress))
            initials.Add(char.ToUpperInvariant(employee.EmailAddress![0]));

        return initials.Count == 0 ? "??" : new string(initials.Take(2).ToArray());
    }
}
