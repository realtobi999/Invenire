@using System.Net
@using Invenire.Api.Organizations
@using Invenire.Api.Users.Employees

@if (Organization?.Employees is not null && Organization.Employees.Any())
{
    var pagedEmployees = PagedEmployees.ToList();
    var (rangeStart, rangeEnd) = GetDisplayRange();

    <div class="employees-overview">
        <div class="stat-grid employees-summary">
            <div class="stat-card">
                <span class="stat-label">Celkem zaměstnanců</span>
                <span class="stat-value">@TotalCount</span>
            </div>
            <div class="stat-card">
                <span class="stat-label">Aktuálně zobrazeno</span>
                <span class="stat-value">@pagedEmployees.Count</span>
                <p class="muted-text">@GetFilterDescription()</p>
            </div>
        </div>

        <div class="filter-panel employees-filter-panel">
            <div class="filter-grid">
                <div class="form-control">
                    <label for="employee-order">Řazení</label>
                    <select id="employee-order" @bind="SelectedOrderOption" @bind:after="() => SetCurrentOffset(0)">
                        @foreach (var option in OrderOptions)
                        {
                            <option value="@option.Value">@option.Label</option>
                        }
                    </select>
                </div>
                <div class="form-control grow">
                    <label for="employee-search">Hledat</label>
                    <input id="employee-search" type="text" @bind="SearchTerm" @bind:after="() => SetCurrentOffset(0)" placeholder="Hledat zaměstnance..." />
                </div>
            </div>
        </div>

        <ul class="employees-list">
            @foreach (var employee in pagedEmployees)
            {
                <li class="employee-card">
                    <div class="employee-identity">
                        <span class="employee-avatar">@GetEmployeeInitials(employee)</span>
                        <div>
                            <p class="employee-name">@employee.FullName</p>
                            <p class="employee-email">@employee.EmailAddress</p>
                        </div>
                    </div>
                    <div class="employee-card-actions">
                        <button class="btn-destructive" type="button" @onclick="() => (SelectedEmployee, ShowDeletionModal) = (employee, true)">Odebrat</button>
                    </div>
                </li>
            }
        </ul>

        <div class="employees-pagination">
            <div class="employees-pagination-meta">
                <span>Zobrazuji @rangeStart-@rangeEnd z @TotalCount zaměstnanců</span>
            </div>
            <div class="employees-pagination-controls">
                <button class="btn-secondary" type="button" @onclick="() => SetCurrentOffset(CurrentOffset - Limit)" disabled="@(!CanGoPrev)">◀</button>
                <span>@(CurrentOffset / Limit + 1) / @((int)Math.Ceiling((double)TotalCount / Limit))</span>
                <button class="btn-secondary" type="button" @onclick="() => SetCurrentOffset(CurrentOffset + Limit)" disabled="@(!CanGoNext)">▶</button>
            </div>
        </div>
    </div>

    @if (ShowDeletionModal && SelectedEmployee is not null)
    {
        <div class="modal-overlay">
            <div class="modal-panel">
                <div class="modal-header">
                    <h4>Odebrat zaměstnance</h4>
                    <button class="btn-secondary" type="button" @onclick="CloseDeletionModal">Zavřít</button>
                </div>
                <div class="modal-body">
                    <p class="modal-description">Opravdu chcete odebrat zaměstnance z organizace?</p>

                    <div class="detail-list">
                        <div class="detail-item">
                            <span class="detail-label">Jméno</span>
                            <span class="detail-value">@SelectedEmployee.FullName</span>
                        </div>
                        <div class="detail-item">
                            <span class="detail-label">Email</span>
                            <span class="detail-value">@SelectedEmployee.EmailAddress</span>
                        </div>
                    </div>

                    <div class="modal-footer">
                        <button class="btn-secondary" type="button" @onclick="CloseDeletionModal">Ne, ponechat</button>
                        <button class="btn-destructive" type="button" @onclick="RemoveEmployee">Ano, odebrat</button>
                    </div>
                </div>
            </div>
        </div>
    }
}
else
{
    <section class="section-card empty-state">
        <p>Žádní zaměstnanci nebyli nalezeni.</p>
        <p class="muted-text">Jakmile přidáte zaměstnance, jejich přehled se zobrazí právě zde.</p>
    </section>
}

@code
{
    [Inject] private HttpClient Client { get; set; } = default!;
    [Parameter] public OrganizationDto? Organization { get; set; }
    [Parameter] public EventCallback<bool> OnSuccessfulDeletion { get; set; }

    private int Limit = 5;
    private int CurrentOffset { get; set; }
    private int TotalCount => SearchedEmployees.Count();
    private bool CanGoPrev => CurrentOffset > 0;
    private bool CanGoNext => CurrentOffset + Limit < TotalCount;

    private bool ShowDeletionModal { get; set; }

    private string SelectedOrderOption { get; set; } = "name_asc";
    private readonly List<(string Value, string Label)> OrderOptions = new()
    {
        ("name_asc", "Jméno (A-Z)"),
        ("name_desc", "Jméno (Z-A)"),
        ("email_asc", "Email (A-Z)"),
        ("email_desc", "Email (Z-A)")
    };

    private string SearchTerm { get; set; } = string.Empty;
    private IEnumerable<EmployeeDto> SearchedEmployees
    {
        get
        {
            var employees = Organization?.Employees ?? Enumerable.Empty<EmployeeDto>();
            var filtered = employees.Where(e =>
                e.FullName.Contains(SearchTerm, StringComparison.OrdinalIgnoreCase) ||
                e.EmailAddress.Contains(SearchTerm, StringComparison.OrdinalIgnoreCase));

            var (field, ascending) = SelectedOrderOption.Split('_') switch { var parts => (parts[0], parts[1] == "asc") };

            return field switch
            {
                "name" => ascending ? filtered.OrderBy(e => e.FullName) : filtered.OrderByDescending(e => e.FullName),
                "email" => ascending ? filtered.OrderBy(e => e.EmailAddress) : filtered.OrderByDescending(e => e.EmailAddress),
                _ => filtered
            };
        }
    }

    private IEnumerable<EmployeeDto> PagedEmployees => SearchedEmployees.Skip(CurrentOffset).Take(Limit);
    private EmployeeDto? SelectedEmployee { get; set; }

    private (int Start, int End) GetDisplayRange()
        => TotalCount == 0 ? (0, 0) : (CurrentOffset + 1, Math.Min(CurrentOffset + Limit, TotalCount));

    private string GetFilterDescription()
    {
        if (!string.IsNullOrWhiteSpace(SearchTerm))
        {
            return $"Filtrované podle \"{SearchTerm}\"";
        }

        var selectedOrder = OrderOptions.FirstOrDefault(o => o.Value == SelectedOrderOption);
        var label = string.IsNullOrWhiteSpace(selectedOrder.Label) ? SelectedOrderOption : selectedOrder.Label;

        return $"Řazení: {label}";
    }

    private string GetEmployeeInitials(EmployeeDto employee)
    {
        var initials = new List<char>();

        if (!string.IsNullOrWhiteSpace(employee.FirstName))
            initials.Add(char.ToUpperInvariant(employee.FirstName!.Trim()[0]));

        if (!string.IsNullOrWhiteSpace(employee.LastName))
            initials.Add(char.ToUpperInvariant(employee.LastName!.Trim()[0]));

        if (initials.Count == 0 && !string.IsNullOrWhiteSpace(employee.FullName))
        {
            var segments = employee.FullName.Split(' ', StringSplitOptions.RemoveEmptyEntries);

            foreach (var segment in segments.Take(2))
            {
                initials.Add(char.ToUpperInvariant(segment[0]));
            }
        }

        if (initials.Count == 0 && !string.IsNullOrWhiteSpace(employee.EmailAddress))
            initials.Add(char.ToUpperInvariant(employee.EmailAddress![0]));

        return initials.Count == 0 ? "??" : new string(initials.Take(2).ToArray());
    }

    private async Task RemoveEmployee()
    {
        if (SelectedEmployee is null) return;

        var response = await Client.DeleteAsync($"/api/organizations/employees/{SelectedEmployee.Id}");

        if (response.StatusCode != HttpStatusCode.NoContent)
            throw new Exception("Failed to remove employee from the organization.");

        CloseDeletionModal();
        await OnSuccessfulDeletion.InvokeAsync(true);
    }

    private void SetCurrentOffset(int offset) => CurrentOffset = Math.Max(0, Math.Min(offset, TotalCount - 1));

    private void CloseDeletionModal() => (ShowDeletionModal, SelectedEmployee) = (false, null);
}
