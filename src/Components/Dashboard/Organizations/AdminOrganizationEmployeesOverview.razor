@using System.Net
@using Invenire.Api.Organizations
@using Invenire.Api.Users.Employees

@if (Organization is not null)
{
    @if (Organization.Employees is not null && Organization.Employees.Any())
    {
        <!-- Ordering. -->
        <label for="OrderSelect">Řazení: </label>
        <select id="OrderSelect" @bind="SelectedOrderOption" @bind:after="() => CurrentOffset = 0">
            @foreach (var option in OrderOptions)
            {
                <option value="@option.Value">@option.Label</option>
            }
        </select>

        <!-- Searching. -->
        <input type="text" @bind="SearchTerm" placeholder="Hledat zaměstnance..." />

        <!-- Employees. -->
        <ul>
            @foreach (var employee in PagedEmployees)
            {
                <li>
                    <strong>@employee.FullName</strong> (@employee.EmailAddress)
                    <button @onclick="() => (SelectedEmployee, ShowDeletionModal) = (employee, true)">X</button>
                </li>
            }
        </ul>

        <!-- Pagination. -->
        <div class="pagination">
            <button @onclick="() => SetCurrentOffset(CurrentOffset - Limit)" disabled="@( !CanGoPrev )">
                Předchozí
            </button>
            <span>
                Stránka @(CurrentOffset / Limit + 1) / @((int)Math.Ceiling((double)TotalCount / Limit))
            </span>
            <button @onclick="() => SetCurrentOffset(CurrentOffset + Limit)" disabled="@( !CanGoNext )">
                Další
            </button>
        </div>

        <!-- Removing employee from a organization. -->
        @if (ShowDeletionModal)
        {
            <div class="modal">
                <div class="modal-content">
                    <h4>Opravdu chcete odebrat zaměstnance?</h4>
                    <p><strong>@SelectedEmployee!.FullName</strong> (@SelectedEmployee!.EmailAddress)</p>
                    <button @onclick="RemoveEmployee">Ano, odebrat</button>
                    <button @onclick="() => ShowDeletionModal = false">Ne</button>
                </div>
            </div>
        }
    }
    else
    {
        <p>Žádní zaměstnanci nebyli nalezeni.</p>
    }
}

@code {
    /* Public Parameters. */

    [Inject] public HttpClient Client { get; set; } = default!;
    [Parameter] public OrganizationDto? Organization { get; set; }
    [Parameter] public EventCallback<bool> OnSuccessfulDeletion { get; set; }

    /* Private Parameters. */

    /* Pagination. */
    private int Limit = 5;
    private int CurrentOffset { get; set; }
    private int TotalCount => SearchedEmployees.Count();
    private bool CanGoPrev => CurrentOffset > 0;
    private bool CanGoNext => CurrentOffset + Limit < TotalCount;

    /* Modals. */
    private bool ShowDeletionModal { get; set; }

    /* Ordering. */
    private string SelectedOrderOption { get; set; } = "name_asc";
    private readonly List<(string Value, string Label)> OrderOptions = new()
    {
        ("name_asc", "Jméno (A-Z)"),
        ("name_desc", "Jméno (Z-A)"),
        ("email_asc", "Email (A-Z)"),
        ("email_desc", "Email (Z-A)")
    };

    /* Searching. */
    private string SearchTerm { get; set; } = string.Empty;
    private IEnumerable<EmployeeDto> SearchedEmployees
    {
        get
        {
            var employees = Organization?.Employees ?? Enumerable.Empty<EmployeeDto>();
            var filtered = employees.Where(e => 
                e.FullName.Contains(SearchTerm, StringComparison.OrdinalIgnoreCase) || 
                e.EmailAddress.Contains(SearchTerm, StringComparison.OrdinalIgnoreCase));

            var (field, ascending) = SelectedOrderOption.Split('_') switch { var parts => (parts[0], parts[1] == "asc") };

            return field switch
            {
                "name" => ascending ? filtered.OrderBy(e => e.FullName) : filtered.OrderByDescending(e => e.FullName),
                "email" => ascending ? filtered.OrderBy(e => e.EmailAddress) : filtered.OrderByDescending(e => e.EmailAddress),
                _ => filtered
            };
        }
    }

    /* Other */
    private IEnumerable<EmployeeDto> PagedEmployees => SearchedEmployees.Skip(CurrentOffset).Take(Limit);
    private EmployeeDto? SelectedEmployee { get; set; }

    /* Private Methods. */

    private async Task RemoveEmployee()
    {
        if (SelectedEmployee is null) return;

        var response = await Client.DeleteAsync($"/api/organizations/employees/{SelectedEmployee.Id}");

        if (response.StatusCode != HttpStatusCode.NoContent)
            throw new Exception("Failed to remove employee from the organization.");

        (ShowDeletionModal, SelectedEmployee) = (false, null);
        await OnSuccessfulDeletion.InvokeAsync(true);
    }

    private void SetCurrentOffset(int offset) => CurrentOffset = Math.Max(0, Math.Min(offset, TotalCount - 1));
}