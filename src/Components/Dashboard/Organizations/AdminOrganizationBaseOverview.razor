@using Invenire.Api.Organizations
@using Invenire.Components.Forms.Organizations

@if (Organization is not null)
{
    <div class="detail-list">
        <div class="detail-item">
            <span class="detail-label">Id</span>
            <span class="detail-value">@Organization.Id</span>
        </div>
        <div class="detail-item">
            <span class="detail-label">Název</span>
            <span class="detail-value">@Organization.Name</span>
        </div>
        <div class="detail-item">
            <span class="detail-label">Vytvořeno</span>
            <span class="detail-value">@Organization.CreatedAt.ToUserTimeString()</span>
        </div>
        @if (Organization.LastUpdatedAt is not null)
        {
            <div class="detail-item">
                <span class="detail-label">Naposledy upraveno</span>
                <span class="detail-value">@Organization.LastUpdatedAt.ToUserTimeString()</span>
            </div>
        }
    </div>

    <button class="btn-secondary" @onclick="() => ShowModal = true">Upravit informace</button>

    @if (ShowModal)
    {
        <div class="modal-overlay">
            <div class="modal-panel">
                <div class="modal-header">
                    <h4>Upravit informace organizace</h4>
                    <button class="btn-secondary" type="button" @onclick="() => ShowModal = false">Zavřít</button>
                </div>
                <div class="modal-body">
                    <UpdateOrganizationForm Organization="Organization" OnClose="() => ShowModal = false" OnSuccessfulUpdate="OnSuccessfulOrganizationUpdate" />
                </div>
            </div>
        </div>
    }
}

@code 
{
    [Parameter] public OrganizationDto? Organization { get; set; }
    [Parameter] public EventCallback<bool> OnSuccessfulUpdate { get; set; }

    private bool ShowModal { get; set; } = false;

    private async Task OnSuccessfulOrganizationUpdate()
    {
        ShowModal = false;
        await OnSuccessfulUpdate.InvokeAsync(true);
    }
}
