@using System.Net
@using Invenire.Api.Properties.Items
@using Invenire.Api.Properties.Items.Update
@using Invenire.Api.Properties.Suggestions
@using Invenire.Api.Properties.Suggestions.Create
@using Invenire.Api.Properties.Suggestions.Update
@using Invenire.Common.Errors
@using Invenire.Api.Properties.Scans.Create;

<EditForm class="modal-form" Model="Body" OnSubmit="UpdateSuggestion" @ref="Form">
    <div class="form-group">
        <label>Text:</label>
        <InputTextArea @bind-Value="Body.Description" rows="4" />
        <ValidationMessage For="@(() => Body.Description)" />
    </div>

    <div class="form-actions">
        <button class="btn-secondary" type="button" @onclick="async () => { await OnClose.InvokeAsync(true); }">Zrušit</button>
        <button type="submit">Upravit</button>
    </div>
</EditForm>

@if (Errors.Count != 0)
{
    <div class="error-banner">
        <ul>
            @foreach (var error in Errors)
            {
                <li>@error</li>
            }
        </ul>
    </div>
}

@code
{
    [Inject] private HttpClient Client { get; set; } = default!;
    [Parameter] public List<PropertyItemDto> ItemsToDelete { get; set; } = [];
    [Parameter] public List<PropertyItemDto> ItemsToUpdate { get; set; } = [];
    [Parameter] public EventCallback<bool> OnClose { get; set; }
    [Parameter] public EventCallback<bool> OnSuccessfulCreation { get; set; }
    [Parameter] public PropertySuggestionDto? Suggestion { get; set; }

    private List<string> Errors { get; set; } = [];
    private ValidationMessageStore ValidationMessages { get; set; } = null!;
    private EditForm Form { get; set; } = null!;
    private UpdatePropertySuggestionRequestBody Body { get; set; } = new();

    protected override void OnAfterRender(bool first)
    {
        if (Form is not null && first)
        {
            ValidationMessages = new ValidationMessageStore(Form.EditContext!);
        }
    }

    protected override void OnParametersSet()
    {
        if (Suggestion is not null)
        {
            Body.Description = Suggestion.Description!;
        }
    }

    private async Task UpdateSuggestion()
    {
        Errors.Clear();
        ValidationMessages.Clear();

        Body.Payload = new PropertySuggestionPayloadDto
        {
            CreateCommands = [],
            DeleteCommands = ItemsToDelete.Select(i => i.Id).ToList(),
            UpdateCommands = ItemsToUpdate.Select(i => new UpdatePropertyItemRequestBody
            {
                Id = i.Id,
                EmployeeId = i.EmployeeId,
                InventoryNumber = i.InventoryNumber,
                RegistrationNumber = i.RegistrationNumber,
                Name = i.Name,
                Price = i.Price,
                SerialNumber = i.SerialNumber,
                DateOfPurchase = i.DateOfPurchase.ToUniversalTime(),
                DateOfSale = i.DateOfSale?.ToUniversalTime() ?? null,
                Location = new UpdatePropertyItemCommandLocation
                {
                    Room = i.Location.Room,
                    Building = i.Location.Building,
                    AdditionalNote = i.Location.AdditionalNote,
                },
                Description = i.Description,
                DocumentNumber = i.DocumentNumber,
            }).ToList()
        };

        var response = await Client.PutAsJsonAsync($"/api/properties/suggestions/{Suggestion?.Id}", Body);

        if (response.StatusCode == HttpStatusCode.NoContent)
        {
            await OnClose.InvokeAsync(true);
            await OnSuccessfulCreation.InvokeAsync(true);
        }
        else
        {
            var content = await response.Content.ReadFromJsonAsync<ErrorResponse>() ?? throw new NullReferenceException();

            if (content.Type == "ValidationException")
            {
                foreach (var error in content.Errors!)
                {
                    if (error.Contains("description"))
                    {
                        var field = Form.EditContext!.Field(nameof(Body.Description));
                        ValidationMessages.Add(field, ErrorTranslator.Translate(error, UpdatePropertySuggestionResponse.ErrorTranslations));
                    }
                    else
                    {
                        Errors.Add(ErrorTranslator.Translate(error, UpdatePropertySuggestionResponse.ErrorTranslations));
                    }
                }
                
                Form.EditContext!.NotifyValidationStateChanged();
            }
            else
            {
                Errors.Add(ErrorTranslator.Translate(content.Detail, UpdatePropertySuggestionResponse.ErrorTranslations));
            }
        }
    }
}
