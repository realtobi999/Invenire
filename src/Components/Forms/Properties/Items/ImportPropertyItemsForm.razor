@using System.Net
@using System.Text
@using System.Text.Json
@using Invenire.Common.Errors
@using System.Net.Http.Headers
@using Invenire.Api.Properties.Items
@using Invenire.Api.Properties.Items.CreateFromExcelFile
@using Invenire.Api.Properties.Items.CreateFromJsonFile

<div class="modal-stack">
    @if (IsProcessing)
    {
        <p class="modal-description">Žádost se zpracovává... Může to chvíli trvat.</p>
    }
    else if (!ShowColumnPickerModal)
    {
        <div class="modal-footer">
            <button class="btn-secondary" type="button" @onclick="OpenJsonFile">Načíst ze JSON souboru</button>
            <button type="button" @onclick="StartExcelImport">Načíst ze XLSX (Excel) souboru</button>
        </div>
    }
    else
    {
        <h4>Vyberte sloupce pro mapování dat</h4>

        @if (AvailableHeaders.Count == 0)
        {
            <p class="modal-description">Prosím, vyberte Excel soubor, aby bylo možné načíst záhlaví tabulky.</p>
            <button class="btn-secondary" type="button" @onclick="OpenXlsxFile">Vybrat XLSX soubor</button>
        }
        else
        {
            <p class="modal-description">Přiřaďte odpovídající záhlaví ke každé položce označené hvězdičkou.</p>

            @foreach (var property in PropertyColumns.Keys.ToList())
            {
                <div class="form-group">
                    <label>@GetTranslatedPropertyName(property):</label>
                    <select @bind="PropertyColumns[property]">
                        <option value="">(nepřiřazeno)</option>
                        @foreach (var header in AvailableHeaders)
                        {
                            <option value="@header.Letter">@header.Name (@header.Letter)</option>
                        }
                    </select>
                </div>
            }
        }

        <div class="modal-footer">
            <button class="btn-secondary" type="button" @onclick="GoBackToOptions">Zpět</button>
            <button class="btn-secondary" type="button" @onclick="CancelImportAsync">Zrušit</button>
            <button type="button" @onclick="HandleExcelFileSelectedFinal" disabled="@(AvailableHeaders.Count == 0)">Nahrát XLSX</button>
        </div>
    }
</div>

<InputFile id="HiddenJsonFileInput" OnChange="HandleJsonFileSelected" style="display:none" />
<InputFile id="HiddenXLSXFileInput" OnChange="HandleExcelHeaderReading" style="display:none" />

@if (Errors.Any())
{
    <div class="error-banner">
        <ul>
            @foreach (var error in Errors)
            {
                <li>@error</li>
            }
        </ul>
    </div>
}

@code {
    [Inject] private IJSRuntime JS { get; set; } = default!;
    [Inject] private HttpClient Client { get; set; } = default!;
    [Parameter] public EventCallback<bool> OnSuccessfulCreation { get; set; }
    [Parameter] public EventCallback<bool> OnClose { get; set; }

    private bool IsProcessing { get; set; }
    private List<string> Errors { get; set; } = [];
    private bool ShowColumnPickerModal { get; set; }
    private List<(string Name, string Letter)> AvailableHeaders { get; set; } = [];
    private IBrowserFile? SelectedExcelFile { get; set; }
    private byte[]? ExcelFileBytes { get; set; }

    private Dictionary<string, string> PropertyColumns { get; set; } = new()
    {
        { "InventoryNumber", "" },
        { "RegistrationNumber", "" },
        { "Name", "" },
        { "Price", "" },
        { "SerialNumber", "" },
        { "DateOfPurchase", "" },
        { "DateOfSale", "" },
        { "LocationBuilding", "" },
        { "LocationRoom", "" },
        { "LocationAdditionalNote", "" },
        { "Description", "" },
        { "DocumentNumber", "" },
        { "EmployeeEmailAddress", "" }
    };

    private readonly Dictionary<string, string> PropertyTranslations = new()
    {
        { "InventoryNumber", "Inventární číslo *" },
        { "RegistrationNumber", "Registrační číslo *" },
        { "Name", "Název *" },
        { "Price", "Cena *" },
        { "SerialNumber", "Sériové číslo" },
        { "DateOfPurchase", "Datum nákupu *" },
        { "DateOfSale", "Datum prodeje" },
        { "LocationBuilding", "Budova *" },
        { "LocationRoom", "Místnost *" },
        { "LocationAdditionalNote", "Poznámka k umístění" },
        { "Description", "Popis" },
        { "DocumentNumber", "Číslo dokumentu" },
        { "EmployeeEmailAddress", "Emailová adresa zaměstnance" }
    };

    private string GetTranslatedPropertyName(string propertyKey)
    {
        return PropertyTranslations.TryGetValue(propertyKey, out var translation) ? translation : propertyKey;
    }

    private void StartExcelImport()
    {
        Errors.Clear();
        AvailableHeaders.Clear();
        SelectedExcelFile = null;
        ExcelFileBytes = null;
        ShowColumnPickerModal = true;
    }

    private void GoBackToOptions()
    {
        ShowColumnPickerModal = false;
        Errors.Clear();
        AvailableHeaders.Clear();
        SelectedExcelFile = null;
        ExcelFileBytes = null;
    }

    private async Task CancelImportAsync()
    {
        GoBackToOptions();
        Errors.Clear();
        IsProcessing = false;

        if (OnClose.HasDelegate)
        {
            await OnClose.InvokeAsync(true);
        }
    }

    private async Task OpenJsonFile()
    {
        await JS.InvokeVoidAsync("eval", "document.getElementById('HiddenJsonFileInput').click()");
    }

    private async Task OpenXlsxFile()
    {
        await JS.InvokeVoidAsync("eval", "document.getElementById('HiddenXLSXFileInput').click()");
    }

    private async Task HandleJsonFileSelected(InputFileChangeEventArgs e)
    {
        Errors.Clear();
        if (e.File == null) return;

        if (e.File.Size > 1024 * 1024)
            IsProcessing = true;

        using var stream = new MemoryStream();
        await e.File.OpenReadStream(1024 * 1024 * 100).CopyToAsync(stream);
        stream.Position = 0;

        var body = new MultipartFormDataContent
        {
            { new StreamContent(stream) { Headers = { ContentType = new MediaTypeHeaderValue(e.File.ContentType) } }, "file", e.File.Name }
        };
        var response = await Client.PostAsync("/api/properties/items/json-file", body);

        if (response.StatusCode == HttpStatusCode.Created)
        {
            IsProcessing = false;
            await OnSuccessfulCreation.InvokeAsync(true);
        }
        else
        {
            IsProcessing = false;
            var content = await response.Content.ReadFromJsonAsync<ErrorResponse>() ?? throw new NullReferenceException();

            if (content.Type == "ValidationException")
            {
                foreach (var error in content.Errors!)
                {
                    Errors.Add(ErrorTranslator.Translate(content.Detail, CreateFromJsonFilePropertyItemsResponse.ErrorTranslations));
                }
            }
            else
            {
                Errors.Add(ErrorTranslator.Translate(content.Detail, CreateFromJsonFilePropertyItemsResponse.ErrorTranslations));
            }
        }
    }

    private async Task HandleExcelHeaderReading(InputFileChangeEventArgs e)
    {
        Errors.Clear();
        AvailableHeaders.Clear();
        SelectedExcelFile = e.File;

        if (e.File == null)
            return;

        try
        {
            using var stream = new MemoryStream();
            await e.File.OpenReadStream(maxAllowedSize: 1024 * 1024 * 100).CopyToAsync(stream);
            ExcelFileBytes = stream.ToArray();

            var headers = await JS.InvokeAsync<JsonElement>("excel_reader.get_headers_from_bytes", ExcelFileBytes);

            foreach (var header in headers.EnumerateArray())
            {
                var name = header.GetProperty("name").GetString() ?? "";
                var letter = header.GetProperty("letter").GetString() ?? "";
                AvailableHeaders.Add((name, letter));
            }
        }
        catch (Exception ex)
        {
            Errors.Add($"Chyba při čtení Excel souboru: {ex.Message}");
        }
    }

    private async Task HandleExcelFileSelectedFinal()
    {
        if (ExcelFileBytes is null || ExcelFileBytes.Length == 0)
        {
            Errors.Add("Excel soubor nebyl načten nebo je prázdný.");
            return;
        }

        Errors.Clear();
        IsProcessing = true;

        using var stream = new MemoryStream(ExcelFileBytes);
        var body = new MultipartFormDataContent
        {
            { new StreamContent(stream) { Headers = { ContentType = new MediaTypeHeaderValue(SelectedExcelFile!.ContentType) } }, "file", SelectedExcelFile!.Name }
        };

        var columns = string.Join("|", PropertyColumns.Where(kv => !string.IsNullOrEmpty(kv.Value)).Select(kv => $"{kv.Key};{kv.Value}"));
        var response = await Client.PostAsync($"/api/properties/items/excel-file?columns={Uri.EscapeDataString(columns)}", body);

        IsProcessing = false;

        if (response.StatusCode == HttpStatusCode.Created)
        {
            ShowColumnPickerModal = false;
            AvailableHeaders.Clear();
            ExcelFileBytes = null;
            SelectedExcelFile = null;

            foreach (var key in PropertyColumns.Keys.ToList())
                PropertyColumns[key] = "";

            await OnSuccessfulCreation.InvokeAsync(true);
        }
        else
        {
            var content = await response.Content.ReadFromJsonAsync<ErrorResponse>() ?? throw new NullReferenceException();

            if (content.Type == "ValidationException")
            {
                foreach (var error in content.Errors!)
                    Errors.Add(ErrorTranslator.Translate(error, CreateFromExcelFilePropertyItemsResponse.ErrorTranslations));
            }
            else
            {
                Errors.Add(ErrorTranslator.Translate(content.Detail, CreateFromExcelFilePropertyItemsResponse.ErrorTranslations));
            }
        }
    }
}
