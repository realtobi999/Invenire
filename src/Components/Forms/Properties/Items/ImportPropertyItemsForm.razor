@using System.Net
@using System.Text
@using System.Text.Json
@using Invenire.Common.Errors
@using System.Net.Http.Headers
@using Invenire.Api.Properties.Items
@using Invenire.Api.Properties.Items.CreateFromExcelFile
@using Invenire.Api.Properties.Items.CreateFromJsonFile

<div class="modal-stack">
    @if (Processing)
    {
        <p class="modal-description">Žádost se zpracovává... Může to chvíli trvat.</p>
    }
    else if (!Picker)
    {
        <div class="modal-footer">
            <button class="btn-secondary" type="button" @onclick="async () => { await OpenJson(); }">Načíst ze JSON souboru</button>
            <button type="button" @onclick="() => { StartExcel(); }">Načíst ze XLSX (Excel) souboru</button>
        </div>
    }
    else
    {
        @if (Headers.Count == 0)
        {
            <p class="modal-description">Prosím, vyberte Excel soubor, aby bylo možné načíst záhlaví tabulky.</p>
            <button class="btn-secondary" type="button" @onclick="async () => { await OpenXlsx(); }">Vybrat XLSX soubor</button>
        }
        else
        {
            <h4>Vyberte sloupce pro mapování dat</h4>
            
            <p class="modal-description">Přiřaďte odpovídající záhlaví ke každé položce označené hvězdičkou.</p>

            @foreach (var property in Columns.Keys.ToList())
            {
                <div class="form-group">
                    <label>@Translate(property):</label>
                    <select @bind="Columns[property]">
                        <option value="">(nepřiřazeno)</option>
                        @foreach (var header in Headers)
                        {
                            <option value="@header.Letter">@header.Name (@header.Letter)</option>
                        }
                    </select>
                </div>
            }
        }

        <div class="modal-footer">
            <button class="btn-secondary" type="button" @onclick="() => { BackToOptions(); }">Zpět</button>
            <button class="btn-secondary" type="button" @onclick="async () => { await CancelImport(); }">Zrušit</button>
            <button type="button" @onclick="async () => { await UploadExcel(); }" disabled="@(Headers.Count == 0)">Nahrát XLSX</button>
        </div>
    }
</div>

<InputFile id="HiddenJsonFileInput" OnChange="HandleJson" style="display:none" />
<InputFile id="HiddenXLSXFileInput" OnChange="ReadExcelHeaders" style="display:none" />

@if (Errors.Any())
{
    <div class="error-banner">
        <ul>
            @foreach (var error in Errors)
            {
                <li>@error</li>
            }
        </ul>
    </div>
}

@code
{
    [Inject] private IJSRuntime JS { get; set; } = default!;
    [Inject] private HttpClient Client { get; set; } = default!;
    [Parameter] public EventCallback<bool> OnSuccessfulCreation { get; set; }
    [Parameter] public EventCallback<bool> OnClose { get; set; }

    private bool Processing { get; set; }
    private List<string> Errors { get; set; } = [];
    private bool Picker { get; set; }
    private List<(string Name, string Letter)> Headers { get; set; } = [];
    private IBrowserFile? ExcelFile { get; set; }
    private byte[]? ExcelBytes { get; set; }

    private Dictionary<string, string> Columns { get; set; } = new()
    {
        { "InventoryNumber", "" },
        { "RegistrationNumber", "" },
        { "Name", "" },
        { "Price", "" },
        { "SerialNumber", "" },
        { "DateOfPurchase", "" },
        { "DateOfSale", "" },
        { "LocationBuilding", "" },
        { "LocationRoom", "" },
        { "LocationAdditionalNote", "" },
        { "Description", "" },
        { "DocumentNumber", "" },
        { "EmployeeEmailAddress", "" }
    };

    private readonly Dictionary<string, string> Translations = new()
    {
        { "InventoryNumber", "Inventární číslo *" },
        { "RegistrationNumber", "Registrační číslo *" },
        { "Name", "Název *" },
        { "Price", "Cena *" },
        { "SerialNumber", "Sériové číslo" },
        { "DateOfPurchase", "Datum nákupu *" },
        { "DateOfSale", "Datum prodeje" },
        { "LocationBuilding", "Budova *" },
        { "LocationRoom", "Místnost *" },
        { "LocationAdditionalNote", "Poznámka k umístění" },
        { "Description", "Popis" },
        { "DocumentNumber", "Číslo dokumentu" },
        { "EmployeeEmailAddress", "Emailová adresa zaměstnance" }
    };

    private MarkupString Translate(string propertyKey)
    {
        if (!Translations.TryGetValue(propertyKey, out var text))
            return new MarkupString(propertyKey);

        var html = text.Replace("*", "<span style=\"color: var(--color-danger); font-weight: bold;\">*</span>");
        return new MarkupString(html);
    }

    private void StartExcel()
    {
        Errors.Clear();
        Headers.Clear();
        ExcelFile = null;
        ExcelBytes = null;
        Picker = true;
    }

    private void BackToOptions()
    {
        Errors.Clear();
        Headers.Clear();
        Picker = false;
        ExcelFile = null;
        ExcelBytes = null;
    }

    private async Task CancelImport()
    {
        BackToOptions();
        Processing = false;

        await OnClose.InvokeAsync(true);
    }

    private async Task OpenJson()
    {
        await JS.InvokeVoidAsync("eval", "document.getElementById('HiddenJsonFileInput').click()");
    }

    private async Task OpenXlsx()
    {
        await JS.InvokeVoidAsync("eval", "document.getElementById('HiddenXLSXFileInput').click()");
    }

    private async Task HandleJson(InputFileChangeEventArgs e)
    {
        Errors.Clear();
        if (e.File == null)
        {
            return;
        }

        if (e.File.Size > 1024 * 1024)
        {
            Processing = true;
        }

        using var stream = new MemoryStream();
        await e.File.OpenReadStream(1024 * 1024 * 100).CopyToAsync(stream);
        stream.Position = 0;

        var body = new MultipartFormDataContent
        {
            { new StreamContent(stream) { Headers = { ContentType = new MediaTypeHeaderValue(e.File.ContentType) } }, "file", e.File.Name }
        };
        var response = await Client.PostAsync("/api/properties/items/json-file", body);

        if (response.StatusCode == HttpStatusCode.Created)
        {
            Processing = false;
            await OnSuccessfulCreation.InvokeAsync(true);
        }
        else
        {
            Processing = false;
            var content = await response.Content.ReadFromJsonAsync<ErrorResponse>() ?? throw new NullReferenceException();

            if (content.Type == "ValidationException")
            {
                foreach (var error in content.Errors!)
                {
                    Errors.Add(ErrorTranslator.Translate(content.Detail, CreateFromJsonFilePropertyItemsResponse.ErrorTranslations));
                }
            }
            else
            {
                Errors.Add(ErrorTranslator.Translate(content.Detail, CreateFromJsonFilePropertyItemsResponse.ErrorTranslations));
            }
        }
    }

    private async Task ReadExcelHeaders(InputFileChangeEventArgs e)
    {
        Errors.Clear();
        Headers.Clear();
        ExcelFile = e.File;

        if (e.File == null)
        {
            return;
        }

        try
        {
            using var stream = new MemoryStream();
            await e.File.OpenReadStream(maxAllowedSize: 1024 * 1024 * 100).CopyToAsync(stream);
            ExcelBytes = stream.ToArray();

            var headers = await JS.InvokeAsync<JsonElement>("excel_reader.get_headers_from_bytes", ExcelBytes);

            foreach (var header in headers.EnumerateArray())
            {
                var name = header.GetProperty("name").GetString() ?? "";
                var letter = header.GetProperty("letter").GetString() ?? "";
                Headers.Add((name, letter));
            }
        }
        catch (Exception ex)
        {
            Errors.Add($"Chyba při čtení Excel souboru: {ex.Message}");
        }
    }

    private async Task UploadExcel()
    {
        if (ExcelBytes is null || ExcelBytes.Length == 0)
        {
            Errors.Add("Excel soubor nebyl načten nebo je prázdný.");
            return;
        }

        Errors.Clear();
        Processing = true;

        using var stream = new MemoryStream(ExcelBytes);
        var body = new MultipartFormDataContent
        {
            { new StreamContent(stream) { Headers = { ContentType = new MediaTypeHeaderValue(ExcelFile!.ContentType) } }, "file", ExcelFile!.Name }
        };

        var columns = string.Join("|", Columns.Where(kv => !string.IsNullOrEmpty(kv.Value)).Select(kv => $"{kv.Key};{kv.Value}"));
        var response = await Client.PostAsync($"/api/properties/items/excel-file?columns={Uri.EscapeDataString(columns)}", body);

        Processing = false;

        if (response.StatusCode == HttpStatusCode.Created)
        {
            Picker = false;
            Headers.Clear();
            ExcelBytes = null;
            ExcelFile = null;

            foreach (var key in Columns.Keys.ToList())
            {
                Columns[key] = "";
            }

            await OnSuccessfulCreation.InvokeAsync(true);
        }
        else
        {
            var content = await response.Content.ReadFromJsonAsync<ErrorResponse>() ?? throw new NullReferenceException();

            if (content.Type == "ValidationException")
            {
                foreach (var error in content.Errors!)
                {
                    Errors.Add(ErrorTranslator.Translate(error, CreateFromExcelFilePropertyItemsResponse.ErrorTranslations));
                }
            }
            else
            {
                Errors.Add(ErrorTranslator.Translate(content.Detail, CreateFromExcelFilePropertyItemsResponse.ErrorTranslations));
            }
        }
    }
}
