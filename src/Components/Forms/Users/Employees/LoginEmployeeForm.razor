@using System.Net
@using Invenire.Common.Errors
@using Invenire.Api.Users.Employees.Login

<EditForm class="form-card" Model="Body" OnSubmit="Login" @ref="Form">
    <div class="form-group">
        <label>Emailová adresa:</label>
        <InputText @bind-Value="Body.EmailAddress" type="email" />
        <ValidationMessage For="@(() => Body.EmailAddress)" />
    </div>

    <div class="form-group">
        <label>Heslo:</label>
        <InputText @bind-Value="Body.Password" type="password" />
        <ValidationMessage For="@(() => Body.Password)" />
    </div>

    @if (Error is not null)
    {
        <div class="error-banner">
            @Error
        </div>
    }

    <div class="form-actions">
        <button type="submit">Přihlásit se</button>
    </div>
</EditForm>


@code
{
    [Inject] private HttpClient Client { get; set; } = default!;
    [Inject] private NavigationManager Navigation { get; set; } = default!;

    private string? Error { get; set; }
    private ValidationMessageStore ValidationMessages { get; set; } = null!;
    private EditForm Form { get; set; } = null!;
    private LoginEmployeeRequestBody Body { get; set; } = new();

    protected override void OnAfterRender(bool rendered)
    {
        if (rendered && Form is not null)
        {
            ValidationMessages = new ValidationMessageStore(Form.EditContext!);
        }
    }

    private async Task Login()
    {
        Error = null;
        ValidationMessages.Clear();

        var response = await Client.PostAsJsonAsync("/api/employees/login", Body);

        if (response.StatusCode == HttpStatusCode.NoContent)
        {
            Navigation.NavigateTo("/dashboard");
        }
        else
        {
            var content = await response.Content.ReadFromJsonAsync<ErrorResponse>() ?? throw new NullReferenceException();

            if (content.Type == "ValidationException")
            {
                foreach (var error in content.Errors!)
                {
                    var field = error switch
                    {
                        var e when e.Contains("email_address") => Form.EditContext!.Field(nameof(Body.EmailAddress)),
                        var e when e.Contains("password") => Form.EditContext!.Field(nameof(Body.Password)),
                        _ => throw new Exception($"Unknown error field: {error}")
                    };

                    ValidationMessages.Add(field, ErrorTranslator.Translate(error, LoginEmployeeResponse.ErrorTranslations));
                }

                Form.EditContext!.NotifyValidationStateChanged();
            }
            else
            {
                Error = ErrorTranslator.Translate(content.Detail, LoginEmployeeResponse.ErrorTranslations);
            }
        }
    }
}
