@using System.Net
@using Invenire.Common.Errors
@using Invenire.Api.Organizations.Create

<EditForm class="form-card" Model="Body" OnSubmit="CreateOrganization" @ref="Form">
    <div class="form-group">
        <label>Název:</label>
        <InputText @bind-Value="Body.Name" />
        <ValidationMessage For="@(() => Body.Name)" />
    </div>

    <div class="form-actions">
        <button type="submit">Vytvořit</button>
    </div>
</EditForm>

@if (Error is not null)
{
    <div class="error-banner">
        @Error
    </div>
}

@code
{
    [Inject] private HttpClient Client { get; set; } = default!;
    [Parameter] public EventCallback<bool> OnSuccessfulCreation { get; set; }

    private string? Error { get; set; }
    private ValidationMessageStore ValidationMessages { get; set; } = null!;
    
    private EditForm Form { get; set; } = null!;
    private CreateOrganizationRequestBody Body { get; set; } = new();

    protected override void OnAfterRender(bool first)
    {
        if (Form is not null && first)
        {
            ValidationMessages = new ValidationMessageStore(Form.EditContext!);
        }
    }

    private async Task CreateOrganization()
    {
        Error = null;
        ValidationMessages.Clear();

        var response = await Client.PostAsJsonAsync("/api/organizations", Body);

        if (response.StatusCode == HttpStatusCode.Created)
        {
            await OnSuccessfulCreation.InvokeAsync(true);
        }
        else
        {
            var content = await response.Content.ReadFromJsonAsync<ErrorResponse>() ?? throw new NullReferenceException();

            if (content.Type == "ValidationException")
            {
                foreach (var error in content.Errors!)
                {
                    var field = error switch
                    {
                        var e when e.Contains("name") => Form.EditContext!.Field(nameof(Body.Name)),
                        _ => throw new Exception($"Unknown error field: {error}")
                    };

                    ValidationMessages.Add(field, ErrorTranslator.Translate(error, CreateOrganizationResponse.ErrorTranslations));
                }

                Form.EditContext!.NotifyValidationStateChanged();
            }
            else
            {
                Error = ErrorTranslator.Translate(content.Detail, CreateOrganizationResponse.ErrorTranslations);
            }
        }
    }
}
