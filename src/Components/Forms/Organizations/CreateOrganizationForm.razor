@using System.Net
@using Invenire.Common.Errors
@using Invenire.Api.Organizations.Create

<EditForm Model="Body" OnSubmit="HandleCreation" @ref="Form">
    <div>
        <label>Název:</label>
        <InputText @bind-Value="Body.Name" />
        <ValidationMessage For="@(() => Body.Name)" />
    </div>

    <button type="submit">Vytvořit</button>
</EditForm>

@if (ErrorGeneralMessage is not null)
{
    <div>
        @ErrorGeneralMessage
    </div>
}

@code {
    [Inject] private HttpClient Client { get; set; } = default!;
    [Inject] private NavigationManager Navigation { get; set; } = default!;
    [Parameter] public EventCallback<bool> OnSuccessfulCreation { get; set; }

    private string? ErrorGeneralMessage;
    private ValidationMessageStore ErrorValidationMessages = null!;

    private EditForm Form = null!;
    private CreateOrganizationRequestBody Body = new();

    protected override void OnAfterRender(bool rendered)
    {
        if (Form is not null && rendered)
        {
            ErrorValidationMessages = new ValidationMessageStore(Form?.EditContext!);
        }
    }

    private async Task HandleCreation()
    {
        ErrorGeneralMessage = null;
        ErrorValidationMessages.Clear();

        var response = await Client.PostAsJsonAsync("/api/organizations", Body);

        if (response.StatusCode == HttpStatusCode.Created)
        {
            await OnSuccessfulCreation.InvokeAsync(true);
        }
        else
        {
            var content = await response.Content.ReadFromJsonAsync<ErrorResponse>() ?? throw new NullReferenceException();

            if (content.Type == "ValidationException")
            {
                foreach (var error in content.Errors!)
                {
                    var field = error switch
                    {
                        var e when e.Contains("name") => Form.EditContext!.Field(nameof(Body.Name)),
                        _ => throw new Exception($"Unknown error field: {error}")
                    };

                    ErrorValidationMessages.Add(field, ErrorTranslator.Translate(error, CreateOrganizationResponse.ErrorTranslations));
                }

                Form.EditContext!.NotifyValidationStateChanged();
            }
            else
            {
                ErrorGeneralMessage = ErrorTranslator.Translate(content.Detail, CreateOrganizationResponse.ErrorTranslations);
            }
        }
    }
}
