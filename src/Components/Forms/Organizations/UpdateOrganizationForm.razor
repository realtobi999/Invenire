@using System.Net
@using Invenire.Common.Errors
@using Invenire.Api.Organizations
@using Invenire.Api.Organizations.Update

@if (Organization is not null)
{
    <EditForm class="modal-form" Model="Body" OnSubmit="UpdateOrganization" @ref="Form">
        <div class="form-group">
            <label>Název:</label>
            <InputText class="input-wide" @bind-Value="Body.Name" />
            <ValidationMessage For="@(() => Body.Name)" />
        </div>

        <div class="form-actions">
            <button class="btn-secondary" type="button" @onclick="async () => { await OnClose.InvokeAsync(true); }">Zrušit</button>
            <button type="submit">Uložit</button>
        </div>
    </EditForm>
}

@if (Error is not null)
{
    <div class="error-banner">
        @Error
    </div>
}

@code
{
    [Inject] private HttpClient Client { get; set; } = default!;
    [Parameter] public OrganizationDto? Organization { get; set; }
    [Parameter] public EventCallback<bool> OnClose { get; set; }
    [Parameter] public EventCallback<bool> OnSuccessfulUpdate { get; set; }

    private string? Error { get; set; }
    private ValidationMessageStore ValidationMessages { get; set; } = null!;
    private EditForm Form { get; set; } = null!;
    private UpdateOrganizationRequestBody Body { get; set; } = new();

    protected override void OnAfterRender(bool rendered)
    {
        if (Form is not null && rendered)
        {
            ValidationMessages = new ValidationMessageStore(Form.EditContext!);
        }
    }

    protected override void OnParametersSet()
    {
        if (Organization is not null)
        {
            Body.Name = Organization.Name;
        }
    }

    private async Task UpdateOrganization()
    {
        Error = null;
        ValidationMessages.Clear();

        var response = await Client.PutAsJsonAsync("/api/organizations", Body);

        if (response.StatusCode == HttpStatusCode.NoContent)
        {
            await OnSuccessfulUpdate.InvokeAsync(true);
        }
        else
        {
            var content = await response.Content.ReadFromJsonAsync<ErrorResponse>() ?? throw new NullReferenceException();

            if (content.Type == "ValidationException")
            {
                foreach (var error in content.Errors!)
                {
                    var field = error switch
                    {
                        var e when e.Contains("name") => Form.EditContext!.Field(nameof(Body.Name)),
                        _ => throw new Exception($"Unknown error field: {error}")
                    };

                    ValidationMessages.Add(field, ErrorTranslator.Translate(error, UpdateOrganizationResponse.ErrorTranslations));
                }

                Form.EditContext!.NotifyValidationStateChanged();
            }
            else
            {
                Error = ErrorTranslator.Translate(content.Detail, UpdateOrganizationResponse.ErrorTranslations);
            }
        }
    }
}
