@using System.Net
@using Invenire.Api.Organizations.Invitations

<div class="modal-stack">
    <p class="modal-description">Opravdu chcete smazat pozvánku?</p>
    @if (Invitation?.Employee is not null)
    {
        <div class="detail-list">
            <div class="detail-item">
                <span class="detail-label">Jméno</span>
                <span class="detail-value">@Invitation.Employee.FullName</span>
            </div>
            <div class="detail-item">
                <span class="detail-label">Email</span>
                <span class="detail-value">@Invitation.Employee.EmailAddress</span>
            </div>
        </div>
    }
    <div class="modal-footer">
        <button class="btn-secondary" type="button" @onclick="() => OnClose.InvokeAsync(true)">Zpět</button>
        <button class="btn-destructive" type="button" @onclick="DeleteInvitation">Ano, smazat</button>
    </div>
</div>

@code
{
    [Inject] private HttpClient Client { get; set; } = default!;
    [Parameter] public EventCallback<bool> OnClose { get; set; }
    [Parameter] public EventCallback<bool> OnSuccessfulDeletion { get; set; }
    [Parameter] public OrganizationInvitationDto? Invitation { get; set; }

    public async Task DeleteInvitation()
    {
        var response = await Client.DeleteAsync($"/api/organizations/invitations/{Invitation!.Id}");

        if (response.StatusCode != HttpStatusCode.NoContent) throw new Exception("Something went wrong during the request to delete the invitation.");

        await OnClose.InvokeAsync(true);
        await OnSuccessfulDeletion.InvokeAsync(true);
    }
}
