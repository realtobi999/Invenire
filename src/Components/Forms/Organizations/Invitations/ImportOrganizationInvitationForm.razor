@using System.Net.Http.Headers
@using System.Net
@using Invenire.Api.Organizations.Invitations.CreateFromCsvFile
@using Invenire.Api.Organizations.Invitations.CreateFromJsonFile
@using Invenire.Common.Errors

<div class="modal-stack">
    @if (Processing)
    {
        <p class="modal-description">Žádost se zpracovává... Může to chvíli trvat.</p>
    }
    else
    {
        <div class="modal-stack import-help">
            <div class="form-group">
                <label>Jak vytvořit JSON soubor</label>
                <ul class="modal-description import-help-list">
                    <li>Soubor musí obsahovat pole objektů.</li>
                    <li>Každý objekt musí mít klíč <code>employee_email_address</code>.</li>
                    <li>Klíč <code>description</code> je volitelný.</li>
                </ul>
                <textarea class="import-example" readonly rows="7">
[
    {
        "description": "Připoj se k nám!",
        "employee_email_address": "zamestnanec@firma.cz"
    }
]
                </textarea>
            </div>

            <div class="form-group">
                <label>Jak vytvořit CSV soubor</label>
                <ul class="modal-description import-help-list">
                    <li>První řádek musí být hlavička.</li>
                    <li>Hlavička musí obsahovat sloupce <code>description</code> a <code>employee_email_address</code>.</li>
                    <li>Každý další řádek reprezentuje jednu pozvánku.</li>
                </ul>
                <textarea class="import-example" readonly rows="4">
description,employee_email_address
Připoj se k nám!,zamestnanec@firma.cz
                </textarea>
            </div>
        </div>

        <div class="modal-footer">
            <button class="btn-secondary" type="button" @onclick="async () => { await OpenJson(); }">Načíst ze JSON souboru</button>
            <button class="btn-secondary" type="button" @onclick="async () => { await OpenCsv(); }">Načíst ze CSV souboru</button>
        </div>
    }
</div>

<InputFile id="HiddenJsonFileInput" OnChange="HandleJson" style="display:none" />
<InputFile id="HiddenCsvFileInput" OnChange="HandleCsv" style="display:none" />

@if (Errors.Any())
{
    <div class="error-banner">
        <ul>
            @foreach (var error in Errors)
            {
                <li>@error</li>
            }
        </ul>
    </div>
}

@code
{
    [Inject] private IJSRuntime JS { get; set; } = default!;
    [Inject] private HttpClient Client { get; set; } = default!;
    [Parameter] public EventCallback<bool> OnSuccessfulCreation { get; set; }

    private bool Processing { get; set; }
    private List<string> Errors { get; set; } = [];

    private async Task OpenJson()
    {
        await JS.InvokeVoidAsync("eval", "document.getElementById('HiddenJsonFileInput').click()");
    }

    private async Task OpenCsv()
    {
        await JS.InvokeVoidAsync("eval", "document.getElementById('HiddenCsvFileInput').click()");
    }

    private async Task HandleJson(InputFileChangeEventArgs e)
    {
        Errors.Clear();

        if (e.File == null)
        {
            return;
        }

        Processing = true;

        using var stream = new MemoryStream();
        await e.File.OpenReadStream(1024 * 1024 * 100).CopyToAsync(stream);
        stream.Position = 0;

        var body = new MultipartFormDataContent
        {
            { new StreamContent(stream) { Headers = { ContentType = new MediaTypeHeaderValue(e.File.ContentType) } }, "file", e.File.Name }
        };
        var response = await Client.PostAsync("/api/organization/invitations/json-file", body);

        if (response.StatusCode == HttpStatusCode.Created)
        {
            Processing = false;
            await OnSuccessfulCreation.InvokeAsync(true);
        }
        else
        {
            Processing = false;
            var content = await response.Content.ReadFromJsonAsync<ErrorResponse>() ?? throw new NullReferenceException();

            if (content.Type == "ValidationException")
            {
                foreach (var error in content.Errors!)
                {
                    Errors.Add(ErrorTranslator.Translate(error, CreateFromJsonFileOrganizationInvitationResponse.ErrorTranslations));
                }
            }
            else
            {
                Errors.Add(ErrorTranslator.Translate(content.Detail, CreateFromJsonFileOrganizationInvitationResponse.ErrorTranslations));
            }
        }
    }

    private async Task HandleCsv(InputFileChangeEventArgs e)
    {
        Errors.Clear();

        if (e.File == null)
        {
            return;
        }

        Processing = true;

        using var stream = new MemoryStream();
        await e.File.OpenReadStream(1024 * 1024 * 100).CopyToAsync(stream);
        stream.Position = 0;

        var body = new MultipartFormDataContent
        {
            { new StreamContent(stream) { Headers = { ContentType = new MediaTypeHeaderValue(e.File.ContentType) } }, "file", e.File.Name }
        };
        var response = await Client.PostAsync("/api/organization/invitations/csv-file", body);

        if (response.StatusCode == HttpStatusCode.Created)
        {
            Processing = false;
            await OnSuccessfulCreation.InvokeAsync(true);
        }
        else
        {
            Processing = false;
            var content = await response.Content.ReadFromJsonAsync<ErrorResponse>() ?? throw new NullReferenceException();

            if (content.Type == "ValidationException")
            {
                foreach (var error in content.Errors!)
                {
                    Errors.Add(ErrorTranslator.Translate(error, CreateFromCsvFileOrganizationInvitationResponse.ErrorTranslations));
                }
            }
            else
            {
                Errors.Add(ErrorTranslator.Translate(content.Detail, CreateFromCsvFileOrganizationInvitationResponse.ErrorTranslations));
            }
        }
    }
}