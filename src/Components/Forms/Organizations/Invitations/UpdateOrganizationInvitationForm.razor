@using System.Net
@using Invenire.Common.Errors
@using Invenire.Api.Organizations.Invitations
@using Invenire.Api.Organizations.Invitations.Update

<EditForm Model="Body" OnSubmit="HandleCreation" @ref="Form">
    <div>
        <div style="display:flex; align-items:flex-start; gap:10px;">
            <label style="white-space:nowrap;">Text:</label>
            <InputTextArea @bind-Value="Body.Description" style="width:80%; height:100px; resize:vertical;" />
        </div>
        <ValidationMessage For="@(() => Body.Description)" />
    </div>

    <button type="submit">Uložit</button>
    <button @onclick="() => OnClose.InvokeAsync(true)">Zrušit</button>
</EditForm>

@if (ErrorGeneralMessage is not null)
{
    <div>
        @ErrorGeneralMessage
    </div>
}

@code
{
    [Inject] private HttpClient Client { get; set; } = default!;
    [Parameter] public EventCallback<bool> OnClose { get; set; }
    [Parameter] public EventCallback<bool> OnSuccessfulUpdate { get; set; }
    [Parameter] public OrganizationInvitationDto? Invitation { get; set; }

    private string? ErrorGeneralMessage;
    private ValidationMessageStore ErrorValidationMessages = null!;

    private EditForm Form = null!;
    private UpdateOrganizationInvitationRequestBody Body = new();

    protected override void OnAfterRender(bool rendered)
    {
        if (Form is not null && rendered)
        {
            ErrorValidationMessages = new ValidationMessageStore(Form?.EditContext!);
        }
    }

    protected override void OnParametersSet()
    {
        if (Invitation is not null)
        {
            Body.Description = Invitation.Description;
        }
    }

    private async Task HandleCreation()
    {
        ErrorGeneralMessage = null;
        ErrorValidationMessages.Clear();

        var response = await Client.PutAsJsonAsync($"/api/organizations/invitations/{Invitation!.Id}", Body);

        if (response.StatusCode == HttpStatusCode.NoContent)
        {
            await OnClose.InvokeAsync(true);
            await OnSuccessfulUpdate.InvokeAsync(true);
        }
        else
        {
            var content = await response.Content.ReadFromJsonAsync<ErrorResponse>() ?? throw new NullReferenceException();

            if (content.Type == "ValidationException")
            {
                foreach (var error in content.Errors!)
                {
                    var field = error switch
                    {
                        var e when e.Contains("description") => Form.EditContext!.Field(nameof(Body.Description)),
                        _ => throw new Exception($"Unknown error field: {error}")
                    };

                    ErrorValidationMessages.Add(field, ErrorTranslator.Translate(error, UpdateOrganizationInvitationResponse.ErrorTranslations));
                }

                Form.EditContext!.NotifyValidationStateChanged();
            }
            else
            {
                ErrorGeneralMessage = ErrorTranslator.Translate(content.Detail, UpdateOrganizationInvitationResponse.ErrorTranslations);
            }
        }
    }
}
