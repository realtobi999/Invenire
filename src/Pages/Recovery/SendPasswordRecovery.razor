@using Invenire.Api.Users
@using Invenire.Api.Users.Admin.Recovery.Send
@using Invenire.Common.Errors
@using System.Net

@page "/password-recovery/send"

<div class="auth-layout verification-page">
    <section class="surface-card verification-hero">
        <div class="verification-heading">
            <div class="status-pill">
                <span class="status-dot success"></span>
                Obnova Hesla
            </div>
            <h1>Získejte zpět přístup</h1>
            <p>Vyberte typ účtu a odešlete si bezpečný odkaz na nastavení nového hesla.</p>
        </div>
        <div class="verification-progress">
            <div class="step step--completed">
                <span>Identifikace</span>
            </div>
            <div class="step-divider"></div>
            <div class="step step--active">
                <span>Odeslání odkazu</span>
            </div>
            <div class="step-divider"></div>
            <div class="step">
                <span>Nové heslo</span>
            </div>
        </div>
    </section>

    @if (IsLoading)
    {
        <section class="surface-card verification-card stack">
            <div class="loading-state">
                <div class="pulse-bar"></div>
                <p>Odesíláme odkaz…</p>
            </div>
        </section>
    }
    else if (IsEmailSent)
    {
        <section class="surface-card verification-card stack">
            <div class="message-block">
                <h2>Odkaz byl úspěšně odeslán</h2>
                <p>
                    Zkontrolujte schránku na adrese <strong>@Body.EmailAddress</strong> a během chvíle nastavte nové heslo pro @(SelectedRole == "Admin" ? "administrátorský" : "zaměstnanecký") účet.
                </p>
            </div>

            <div class="info-grid">
                <div>
                    <span class="label">Tip</span>
                    <p>Podívejte se i do složek Spam nebo Promo akce, e-mail může skončit také tam.</p>
                </div>
                <div class="info-action">
                    <span class="label">Potřebujete znovu?</span>
                    <button class="btn-secondary" type="button" @onclick="() => IsEmailSent = false">Poslat znovu</button>
                </div>
            </div>
        </section>
    }
    else
    {
        <section class="surface-card verification-card stack">
            <div class="recovery-grid">
                <div>
                    <label>Vyberte typ účtu</label>
                    <InputSelect @bind-Value="SelectedRole">
                        <option value="Employee">Zaměstnanec</option>
                        <option value="Admin">Admin</option>
                    </InputSelect>
                </div>
            </div>

            <EditForm Model="Body" OnSubmit="SendPasswordRecoveryAsync" @ref="Form">
                <div class="form-card">
                    <div class="form-group">
                        <label>Email:</label>
                        <InputText @bind-Value="Body.EmailAddress" type="email" autocomplete="email" />
                        <ValidationMessage For="@(() => Body.EmailAddress)" />
                    </div>

                    @if (ErrorGeneralMessage is not null)
                    {
                        <div class="error-banner">
                            @ErrorGeneralMessage
                        </div>
                    }
                    
                    <div class="form-actions">
                        <button type="submit">Odeslat odkaz</button>
                    </div>
                </div>
            </EditForm>
        </section>
    }
</div>


@code 
{
    [Inject] private HttpClient Client { get; set; } = default!;

    private bool IsLoading { get; set; }
    private bool IsEmailSent { get; set;}
    private string SelectedRole { get; set; } = "Employee";

    private EditForm Form = null!;
    private SendPasswordRecoveryRequestBody Body = new();

    private string? ErrorGeneralMessage;
    private ValidationMessageStore ErrorValidationMessages = null!;

    protected override void OnAfterRender(bool first)
    {
        if (Form is not null && first)
        {
            ErrorValidationMessages = new ValidationMessageStore(Form?.EditContext!);
        }
    }

    private async Task SendPasswordRecoveryAsync()
    {
        IsLoading = true;
        ErrorGeneralMessage = null;
        ErrorValidationMessages.Clear();
        
        var response = await Client.PostAsJsonAsync($"/api/{SelectedRole.ToLower()}s/password-recovery/send", Body);

        if (response.StatusCode == HttpStatusCode.NoContent)
        {
            IsLoading = false;
            IsEmailSent = true;
        }
        else
        {
            IsLoading = false;
            var content = await response.Content.ReadFromJsonAsync<ErrorResponse>() ?? throw new NullReferenceException();

            if (content.Type == "ValidationException")
            {
                foreach (var error in content.Errors!)
                {
                    var field = error switch
                    {
                        var e when e.Contains("email_address") => Form.EditContext!.Field(nameof(Body.EmailAddress)),
                        _ => throw new Exception($"Unknown error field: {error}")
                    };

                    ErrorValidationMessages.Add(field, ErrorTranslator.Translate(error, SendPasswordRecoveryResponse.ErrorTranslations));
                }

                Form.EditContext!.NotifyValidationStateChanged();
            }
            else
            {
                ErrorGeneralMessage = ErrorTranslator.Translate(content.Detail, SendPasswordRecoveryResponse.ErrorTranslations);
            }
        }
    }
}
