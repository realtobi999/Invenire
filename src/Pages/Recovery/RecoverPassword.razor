@using System.Net
@using System.Net.Http.Headers
@using Invenire.Api.Users
@using Invenire.Api.Users.Admin.Recovery.Recover
@using Invenire.Common.Errors
@using Invenire.Common.Extensions
@using Microsoft.AspNetCore.WebUtilities

@page "/password-recovery/recover"

<div class="auth-layout verification-page recovery-layout">
    <section class="surface-card verification-hero">
        <div class="verification-heading">
            <div class="status-pill">
                <span class="status-dot success"></span>
                Obnova Hesla
            </div>
            <h1>Obnovení hesla</h1>
            <p>Odkaz z e-mailu vás přivedl sem. Zadejte nové heslo a dokončete celý proces.</p>
        </div>
        <div class="verification-progress">
            <div class="step step--completed">
                <span>Identifikace</span>
            </div>
            <div class="step-divider"></div>
            <div class="step step--completed">
                <span>Odeslání odkazu</span>
            </div>
            <div class="step-divider"></div>
            <div class="step step--active">
                <span>Nové heslo</span>
            </div>
        </div>
    </section>

    <section class="verification-card recovery-info">
        <div>
            <h2>Bezpečné heslo</h2>
            <p>Vytvořte kombinaci, kterou nepoužíváte jinde. Krátké a jednoduché heslo ohrožuje váš tým.</p>
        </div>
        <ul class="requirements-list">
            <li>Minimálně 8 znaků</li>
            <li>Alespoň jedno velké písmeno</li>
            <li>Alespoň jedna číslice</li>
        </ul>
    </section>

    <section class="verification-card stack">
        <EditForm Model="Body" OnSubmit="RecoverPasswordAsync" @ref="Form">
            <div class="form-card">
                <div class="form-group">
                    <label>Nové heslo:</label>
                    <InputText @bind-Value="Body.NewPassword" type="password" autocomplete="new-password" />
                    <ValidationMessage For="@(() => Body.NewPassword)" />
                </div>
                <div class="form-group">
                    <label>Potvrzení nového hesla:</label>
                    <InputText @bind-Value="Body.NewPasswordConfirm" type="password" autocomplete="new-password" />
                    <ValidationMessage For="@(() => Body.NewPasswordConfirm)" />
                </div>

                @if (GeneralError is not null)
                {
                    <div class="error-banner">
                        @GeneralError
                    </div>
                }

                <div class="form-actions">
                    <button type="submit" disabled="@(!Ready)">
                        @(Submitting ? "Zpracováváme…" : "Nastavit heslo")
                    </button>
                </div>
            </div>
        </EditForm>
    </section>
</div>

@code
{
    [Inject] private HttpClient Client { get; set; } = default!;
    [Inject] private NavigationManager Navigation { get; set; } = default!;

    private string? Token { get; set; }
    private JwtRole? Role { get; set; }
    private bool Submitting { get; set; }

    private EditForm Form { get; set; } = null!;
    private RecoverPasswordRequestBody Body { get; set; } = new();

    private string? GeneralError { get; set; }
    private ValidationMessageStore ValidationErrors { get; set; } = null!;

    private bool Ready
    {
        get
        {
            return !Submitting && Token is not null && Role is not null;
        }
    }

    protected override async Task OnInitializedAsync()
    {
        var uri = Navigation.ToAbsoluteUri(Navigation.Uri);

        if (Token is null && QueryHelpers.ParseQuery(uri.Query).TryGetValue("token", out var token) && !string.IsNullOrWhiteSpace(token))
        {
            Token = token;
        }

        if (Token is null)
        {
            GeneralError = "Odkaz pro obnovu hesla není platný. Požádejte prosím o nový.";
            return;
        }

        if (Role is null)
        {
            using var request = new HttpRequestMessage(HttpMethod.Get, "/api/server/auth/role");
            request.Headers.Authorization = new AuthenticationHeaderValue("Bearer", Token);

            var response = await Client.SendAsync(request);

            if (response.IsSuccessStatusCode)
            {
                Role = (await response.Content.ReadAsStringAsync()).ToEnum<JwtRole>();
            }
            else
            {
                GeneralError = "Odkaz se nepodařilo ověřit. Vyžádejte si prosím nový.";
            }
        }
    }

    protected override void OnAfterRender(bool first)
    {
        if (first && Form is not null)
        {
            ValidationErrors = new ValidationMessageStore(Form.EditContext!);
        }
    }

    private async Task RecoverPasswordAsync()
    {
        Submitting = true;
        GeneralError = null;
        ValidationErrors.Clear();

        try
        {
            if (Token is null)
            {
                throw new InvalidOperationException("Missing recovery token");
            }

            var segment = Role!.Value switch
            {
                var role when role == JwtRole.Admin => "admins",
                var role when role == JwtRole.Employee => "employees",
                _ => throw new ArgumentOutOfRangeException(nameof(Role), Role, null)
            };

            using var request = new HttpRequestMessage(HttpMethod.Post, $"/api/{segment}/password-recovery/recover");
            request.Content = JsonContent.Create(Body);
            request.Headers.Authorization = new AuthenticationHeaderValue("Bearer", Token);
            var response = await Client.SendAsync(request);

            if (response.StatusCode == HttpStatusCode.NoContent)
            {
                Navigation.NavigateTo("/login");
            }
            else
            {
                var content = await response.Content.ReadFromJsonAsync<ErrorResponse>() ?? throw new NullReferenceException();

                if (content.Type == "ValidationException")
                {
                    foreach (var error in content.Errors!)
                    {
                        var field = error switch
                        {
                            var e when e.Contains("new_password_confirm") => Form.EditContext!.Field(nameof(Body.NewPasswordConfirm)),
                            var e when e.Contains("new_password") => Form.EditContext!.Field(nameof(Body.NewPassword)),
                            _ => throw new Exception($"Unknown error field: {error}")
                        };

                        ValidationErrors.Add(field, ErrorTranslator.Translate(error, RecoverPasswordResponse.ErrorTranslations));
                    }

                    Form.EditContext!.NotifyValidationStateChanged();
                }
                else
                {
                    GeneralError = ErrorTranslator.Translate(content.Detail, RecoverPasswordResponse.ErrorTranslations);
                }
            }
        }
        finally
        {
            Submitting = false;
        }
    }
}
