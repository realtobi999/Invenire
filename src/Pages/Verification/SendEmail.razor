@using Invenire.Api.Users
@using Invenire.Api.Users.Admin
@using Invenire.Common.Extensions
@using Invenire.Api.Users.Employees
@using System.Net

@page "/send-email"

<div class="auth-layout verification-page">
    <section class="surface-card verification-hero">
        <div class="verification-heading">
            <div class="status-pill">
                <span class="status-dot success"></span>
                Ověření
            </div>
            <h1>Připravujeme pro vás přístup</h1>
            <p>Ověřte svůj e-mail a pokračujte v nastavení účtu i organizace.</p>
        </div>
        <div class="verification-progress">
            <div class="step step--completed">
                <span>Registrace</span>
            </div>
            <div class="step-divider"></div>
            <div class="step step--active">
                <span>Ověření e-mailu</span>
            </div>
            <div class="step-divider"></div>
            <div class="step">
                <span>Vstup do aplikace</span>
            </div>
        </div>
    </section>

    <section class="surface-card verification-card stack">
        @if (Loading)
        {
            <div class="loading-state">
                <div class="pulse-bar"></div>
                <p>Odesíláme ověřovací e-mail…</p>
            </div>
        }
        else
        {
            <div class="message-block">
                <h2>Ověřovací odkaz byl odeslán</h2>
                <p>
                    Zkontrolujte schránku na adrese <strong>@Email</strong> a klikněte na odkaz pro dokončení registrace.
                </p>
            </div>

            <div class="info-grid">
                <div>
                    <span class="label">Tip</span>
                    <p>Pokud e-mail nevidíte, prohledejte složku spam nebo promo akce.</p>
                </div>
                <div class="info-action">
                    <span class="label">Potřebujete znovu?</span>
                    <button class="btn-secondary" type="button" @onclick="async () => { await SendEmailAsync(); }">Poslat znovu</button>
                </div>
            </div>
        }
    </section>
</div>

@code 
{
    [Inject] private HttpClient Client { get; set; } = default!;
    [Inject] private NavigationManager Navigation { get; set; } = default!;

    private bool Loading { get; set; }
    private string? Email { get; set; }
    private JwtRole? Role { get; set; }

    protected override async Task OnInitializedAsync()
    {
        await SendEmailAsync();
    }

    private async Task SendEmailAsync()
    {
        Loading = true;

        if (Role is null)
        {
            Role = (await (await Client.GetAsync("/api/server/auth/role")).Content.ReadAsStringAsync()).ToEnum<JwtRole>();
        }

        if (Role == JwtRole.Admin)
        {
            if (Email is null)
            {
                var admin = await (await Client.GetAsync("/api/admins/profile")).Content.ReadFromJsonAsync<AdminDto>();

                if (admin is null) throw new NullReferenceException();

                Email = admin.EmailAddress;
            }

            await Client.PostAsync("/api/admins/email-verification/send", null);
        }
        else if (Role == JwtRole.Employee)
        {
            if (Email is null)
            {
                var employee = await (await Client.GetAsync("/api/employees/profile")).Content.ReadFromJsonAsync<EmployeeDto>();

                if (employee is null) throw new NullReferenceException();

                Email = employee.EmailAddress;
            }

            await Client.PostAsync("/api/employees/email-verification/send", null);
        }

        Loading = false;
    }
}
