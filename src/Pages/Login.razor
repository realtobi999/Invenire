@using Invenire.Components.Forms.Users.Admins
@using Invenire.Components.Forms.Users.Employees

@page "/login"

<div class="auth-layout">
    <div class="page-header">
        <span class="pill">
            <span class="status-dot success"></span>
            Přístup
        </span>
        <h1>@Header</h1>
        <p>Vyberte roli, kterou zastáváte. Přihlášení je zabezpečeno tokeny a uloženými relacemi.</p>
    </div>

    <div class="surface-card">
        <label>Vyberte typ přihlášení</label>
        <select @bind="Role">
            <option value="Employee">Zaměstnanec</option>
            <option value="Admin">Admin</option>
        </select>
    </div>

    <div class="form-stack">
        @if (Role == "Employee")
        {
            <LoginEmployeeForm />
        }
        else if (Role == "Admin")
        {
            <LoginAdminForm />
        }
    </div>

    <div class="surface-card">
        <p style="margin: 0.5rem 0 0.5rem 0;">Nemáte ještě účet? <NavLink class="nav-link" href="/register">Zaregistrujte se zde</NavLink>.</p>
        <p style="margin: 0.5rem 0 0.5rem 0;">Zapomněli jste heslo? <NavLink class="nav-link" href="/password-recovery/send">Resetujte ho zde</NavLink>.</p>
    </div>
</div>

@code
{
    private string Role { get; set; } = "Employee";
    private string Header
    {
        get
        {
            return Role switch
            {
                "Admin" => "Přihlaste se jako admin",
                "Employee" => "Přihlaste se jako zaměstnanec",
                _ => throw new Exception()
            };
        }
    }
}
