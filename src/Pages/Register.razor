@using Invenire.Components.Forms.Users.Admins
@using Invenire.Components.Forms.Users.Employees

@page "/register"

<div class="auth-layout">
    <div class="page-header">
        <span class="pill">
            <span class="status-dot"></span>
            Nový účet
        </span>
        <h1>@Header</h1>
        <p>Zvolte typ uživatele a dokončete registraci v několika jednoduchých krocích.</p>
    </div>

    <div class="surface-card">
        <label>Vyberte typ registrace</label>
        <select @bind="Role">
            <option value="Employee">Zaměstnanec</option>
            <option value="Admin">Admin</option>
        </select>
    </div>

    <div class="form-stack">
        @if (Role == "Employee")
        {
            <RegisterEmployeeForm />
        }
        else if (Role == "Admin")
        {
            <RegisterAdminForm />
        }
    </div>

    <div class="surface-card">
        <p style="margin: 0.5rem 0 0.5rem 0;">Máte již účet? <NavLink class="nav-link" href="/login">Přihlaste se zde</NavLink>.</p>
    </div>
</div>

@code
{
    private string Role { get; set; } = "Employee";
    private string Header
    {
        get
        {
            return Role switch
            {
                "Admin" => "Zaregistrujte se jako admin",
                "Employee" => "Zaregistrujte se jako zaměstnanec",
                _ => throw new Exception()
            };
        }
    }
}
